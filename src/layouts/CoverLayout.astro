---
export interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
}
const { title, description, canonicalURL } = Astro.props;
const url = canonicalURL ?? Astro.url;
const siteUrl = "https://n0brains.com";
const orgLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "n0brains",
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  sameAs: [
    "https://x.com/n0brainsai",
    "https://t.me/n0brainssignals",
    "https://www.instagram.com/n0brainsai",
    "https://bsky.app/profile/n0brains.com",
    "https://github.com/sbynode-ux/n0brains-mcp",
  ],
  description: "Pre-trade conditions intelligence for people and agents, delivered via web, REST, WebSocket, webhook, MCP, and x402.",
};
const siteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "n0brains",
  url: siteUrl,
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#03050a" />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:site_name" content="n0brains" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${siteUrl}/og-default.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-default.png`} />
    <!-- Fonts (same families as the site) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(siteLd)} />
    <script is:inline>
      (() => {
        const KEY = "n0brains_first_touch_v1";
        const TTL = 30 * 24 * 60 * 60 * 1000;
        try {
          const prior = JSON.parse(localStorage.getItem(KEY) || "null");
          if (prior && Date.now() - Number(prior.captured_at || 0) < TTL) return;
          const q = new URLSearchParams(location.search);
          let referrer = null;
          if (document.referrer) {
            const ref = new URL(document.referrer);
            if (ref.hostname !== location.hostname) referrer = ref.origin;
          }
          localStorage.setItem(KEY, JSON.stringify({
            utm_source: q.get("utm_source"),
            utm_medium: q.get("utm_medium"),
            utm_campaign: q.get("utm_campaign"),
            utm_content: q.get("utm_content"),
            utm_term: q.get("utm_term"),
            signup_referrer: referrer,
            landing_path: location.pathname,
            captured_at: Date.now(),
          }));
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

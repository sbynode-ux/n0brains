---
import "../styles/global.css";
import DocsSidebar from "../components/DocsSidebar.astro";
import LangSwitcher from "../components/LangSwitcher.astro";
import {
  useTranslations,
  toLocale,
  navHref,
  navLabel,
  localizePath,
  stripLocale,
  LOCALES,
  DEFAULT_LOCALE,
  TRANSLATED_PATHS,
} from "../i18n/ui";

export interface Props {
  title: string;
  description: string;
  canonicalURL?: string | URL;
  homepage?: boolean;
  ogType?: "website" | "article";
  ogImage?: string;        // absolute or /-rooted path
  noIndex?: boolean;
  keywords?: string[];
}

const {
  title,
  description,
  canonicalURL,
  homepage = false,
  ogType = "website",
  ogImage = "/og-default.png",
  noIndex = false,
  keywords = [],
} = Astro.props;

const url        = canonicalURL ?? Astro.url;
const navPath    = Astro.url.pathname;
const siteUrl    = "https://n0brains.com";

// ── i18n ──
const locale       = toLocale(Astro.currentLocale);
const navBase      = stripLocale(navPath);
const t            = useTranslations(locale);
const nav          = (p: string) => navHref(p, locale);
const baseNoSlash  = navBase !== "/" ? navBase.replace(/\/$/, "") : "/";
const isTranslated = TRANSLATED_PATHS.has(baseNoSlash);
const fullTitle  = homepage ? "n0brains — Check the trade before you take it" : `${title} — n0brains`;
const absoluteOg = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
const year       = new Date().getFullYear();

// JSON-LD: site-wide on home, article on blog posts (via ogType)
const orgLd = {
  "@context":  "https://schema.org",
  "@type":     "Organization",
  name:        "n0brains",
  url:         siteUrl,
  logo:        `${siteUrl}/favicon.svg`,
  sameAs: [
    "https://x.com/n0brainsai",
    "https://t.me/n0brainssignals",
    "https://www.instagram.com/n0brainsai",
    "https://www.youtube.com/@n0brainsai",
    "https://bsky.app/profile/n0brains.com",
    "https://github.com/sbynode-ux/n0brains-mcp",
  ],
  description:
    "Pre-trade conditions intelligence for people and agents, delivered via web, REST, WebSocket, webhook, MCP, and x402.",
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: homepage
    ? [{ "@type": "ListItem", position: 1, name: "n0brains", item: siteUrl }]
    : [
        { "@type": "ListItem", position: 1, name: "n0brains", item: siteUrl },
        { "@type": "ListItem", position: 2, name: title, item: String(url).startsWith("http") ? String(url) : `${siteUrl}${url}` },
      ],
};

const softwareAppLd = homepage ? {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "n0brains",
  url: siteUrl,
  description: "Pre-trade conditions assessment covering crowding, event risk, liquidity, volatility, market structure, and stop geometry, delivered through web and agent APIs.",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  offers: [
    { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free tier — 60 req/min, 15-minute signal delay, REST API" },
    { "@type": "Offer", price: "39.99", priceCurrency: "USD", description: "Pro tier — 600 req/min, real-time signals, REST + WebSocket + Webhooks" },
  ],
  featureList: [
    "Real-time whale tracking",
    "Funding and liquidation alerts",
    "On-chain flows",
    "Daily macro conditions and event-risk context",
    "Manipulation detection",
    "Narrative heatmap",
    "Trust and rug scoring",
    "Semantic signal search",
    "Wallet DNA classification",
    "Market-state consensus endpoint (BTC + ETH)",
    "Real-position DEX liquidation map (Hyperliquid + GMX)",
  ],
  provider: {
    "@type": "Organization",
    name: "n0brains",
    url: siteUrl,
    logo: `${siteUrl}/og-default.png`,
  },
} : null;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="canonical" href={url} />
    {isTranslated && LOCALES.map((loc) => (
      <link rel="alternate" hreflang={loc} href={`${siteUrl}${localizePath(navPath, loc)}`} />
    ))}
    {isTranslated && (
      <link rel="alternate" hreflang="x-default" href={`${siteUrl}${localizePath(navPath, DEFAULT_LOCALE)}`} />
    )}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="n0brains RSS"     href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="n0brains podcast" href="/podcast.xml" />

    <!-- Open Graph -->
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={url} />
    <meta property="og:site_name"   content="n0brains" />
    <meta property="og:type"        content={ogType} />
    <meta property="og:image"       content={absoluteOg} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={absoluteOg} />

    <!-- Color -->
    <meta name="theme-color" content="#050505" />

    <!-- Fonts: prefer locally-hosted (in /fonts) when self-hosting; otherwise CDN -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap"
      rel="stylesheet"
    />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    {softwareAppLd && <script type="application/ld+json" set:html={JSON.stringify(softwareAppLd)} />}
    <script is:inline>
      (() => {
        const KEY = "n0brains_first_touch_v1";
        const TTL = 30 * 24 * 60 * 60 * 1000;
        try {
          const prior = JSON.parse(localStorage.getItem(KEY) || "null");
          if (prior && Date.now() - Number(prior.captured_at || 0) < TTL) return;
          const q = new URLSearchParams(location.search);
          let referrer = null;
          if (document.referrer) {
            const ref = new URL(document.referrer);
            if (ref.hostname !== location.hostname) referrer = ref.origin;
          }
          localStorage.setItem(KEY, JSON.stringify({
            utm_source: q.get("utm_source"),
            utm_medium: q.get("utm_medium"),
            utm_campaign: q.get("utm_campaign"),
            utm_content: q.get("utm_content"),
            utm_term: q.get("utm_term"),
            signup_referrer: referrer,
            landing_path: location.pathname,
            captured_at: Date.now(),
          }));
        } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">{t("Skip to content")}</a>
    <div id="scroll-progress" aria-hidden="true"></div>

    <!-- Rotating announcement bar: alternates the Founding-20 promo and the
         Coinbase-Bazaar / agentic.market listing. One bar (no stacking); the two
         slides cross-fade on a CSS timer. -->
    <div class="founding-banner banner-rotator" role="region" aria-label="Announcements">
      <a class="br-slide br-slide-1" href={`${nav("/pricing")}?utm_source=site&utm_medium=banner&utm_campaign=founding20`}>
        🏁 <strong>Founding&nbsp;20</strong> {t("— code")} <span class="fb-code">RACE</span> {t("at checkout = 1 month Pro free, in exchange for honest feedback. 20 seats, then it's gone →")}
      </a>
      <a class="br-slide br-slide-2" href="/docs/x402?utm_source=site&utm_medium=banner&utm_campaign=x402_bazaar">
        🤖 {t("n0brains is live on the")} <strong>Coinbase x402 Bazaar</strong> &amp; <strong>agentic.market</strong> — {t("your AI agent can pay-per-call in USDC, no signup →")}
      </a>
    </div>

    <header id="site-header">
      <div class="inner">
        <a href={nav("/home")} class="logo" id="header-logo" aria-label="n0brains home">
          &lt;<span>n0</span>brains /&gt;
        </a>
        {homepage && (
          <span class="header-hero-text" id="header-hero-text" aria-hidden="true">
            {t("// Every call. On the record.")}
          </span>
        )}
        <nav class="rail" aria-label="Primary">
          <div class="rail-cluster">
            <span class="rail-label">{t("product")}</span>
            <div class="rail-links">
              <a href={nav("/check")} class={navBase.startsWith("/check") ? "active" : ""}>{navLabel("check", locale)}</a>
              <a href={nav("/docs/")} class={navBase.startsWith("/docs") && !navBase.startsWith("/docs/quickstart") ? "active" : ""}>{navLabel("docs", locale)}</a>
              <a href={nav("/docs/quickstart")} class={navBase.startsWith("/docs/quickstart") ? "active" : ""}>{navLabel("quickstart", locale)}</a>
              <a href={nav("/proof")} class={navBase.startsWith("/proof") ? "active" : ""}>{navLabel("proof", locale)}</a>
              <a href={nav("/charts")} class={navBase.startsWith("/charts") ? "active" : ""}>{navLabel("charts", locale)}</a>
              <a href={nav("/pricing")} class={navBase.startsWith("/pricing") ? "active" : ""}>{navLabel("pricing", locale)}</a>
            </div>
          </div>
          <span class="rail-divider" aria-hidden="true"></span>
          <div class="rail-cluster">
            <span class="rail-label">{t("research")}</span>
            <div class="rail-links">
              <a href={nav("/intel")} class={navBase.startsWith("/intel") ? "active" : ""}>{navLabel("intel", locale)}</a>
              <a href={nav("/blog")} class={navBase.startsWith("/blog") ? "active" : ""}>{navLabel("blog", locale)}</a>
              <a href={nav("/podcast")} class={navBase.startsWith("/podcast") ? "active" : ""}>{navLabel("podcast", locale)}</a>
            </div>
          </div>
          <span class="rail-divider" aria-hidden="true"></span>
          <div class="rail-auth">
            <a href={nav("/login")} class={navBase.startsWith("/login") ? "active" : ""} data-nav-login data-dash-label={t("dashboard")}>{t("login")}</a>
            <a href="/signup" class="rail-cta" data-nav-cta data-logout-label={t("log out")} data-login-href={nav("/login")}>{t("start free →")}</a>
          </div>
        </nav>
        <LangSwitcher variant="header" />
        <button id="nav-burger" class="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="nav-sheet">
          <span></span><span></span><span></span>
        </button>
      </div>
    </header>

    <div id="nav-sheet" class="nav-sheet" hidden>
      <nav aria-label="Mobile">
        {[
          ["/check", "check", "01"],
          ["/docs/", "docs", "02"],
          ["/docs/quickstart", "quickstart", "03"],
          ["/proof", "proof", "04"],
          ["/charts", "charts", "05"],
          ["/pricing", "pricing", "06"],
          ["/intel", "intel", "07"],
          ["/blog", "blog", "08"],
          ["/podcast", "podcast", "09"],
        ].map(([href, label, idx]) => {
          const active = href === "/docs/"
            ? navBase.startsWith("/docs") && !navBase.startsWith("/docs/quickstart")
            : navBase.startsWith(href);
          return (
            <a href={nav(href)} class={`sheet-link ${active ? "active" : ""}`}>
              <span class="sheet-name">{navLabel(label, locale)}{active && <span class="sheet-here"> {t("· here")}</span>}</span>
              <span class="sheet-idx">{idx}</span>
            </a>
          );
        })}
        <div class="sheet-actions">
          <a href={nav("/login")} class="sheet-btn sheet-btn-ghost" data-nav-login data-dash-label={t("dashboard")}>{t("login")}</a>
          <a href="/signup" class="sheet-btn sheet-btn-solid" data-nav-cta data-logout-label={t("log out")} data-login-href={nav("/login")}>{t("start free →")}</a>
        </div>
        <p class="sheet-signoff" aria-hidden="true">{t("// every call. on the record.")}</p>
      </nav>
    </div>

    {navBase.startsWith("/docs") && !navBase.startsWith("/docs/quickstart") && (
      <DocsSidebar current={navBase} locale={locale} />
    )}
    <main id="main">
      <slot />
    </main>

    <footer>
      <div class="inner">
        <p>© {year} <a href="https://n0brains.com">n0brains.com</a> — {t("Every call. On the record.")}</p>
        <div class="footer-socials">
          <a href="https://x.com/n0brainsai" target="_blank" rel="noopener noreferrer" aria-label="n0brains on X" title="X / Twitter">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644z"/></svg>
          </a>
          <a href="https://t.me/n0brainssignals" target="_blank" rel="noopener noreferrer" aria-label="n0brains on Telegram" title="Telegram">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          </a>
          <a href="https://www.instagram.com/n0brainsai" target="_blank" rel="noopener noreferrer" aria-label="n0brains on Instagram" title="Instagram">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
          <a href="https://www.youtube.com/@n0brainsai" target="_blank" rel="noopener noreferrer" aria-label="n0brains on YouTube" title="YouTube">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
        <p class="footer-links">
          <a href={nav("/about")}>{t("about")}</a>
          <a href="/status">{t("status")}</a>
          <a href="/changelog">{t("changelog")}</a>
          <a href="/privacy">{t("privacy")}</a>
          <a href="/terms">{t("terms")}</a>
          <a href="/rss.xml">{t("rss")}</a>
          <a href={nav("/contact")}>{t("contact")}</a>
        </p>
        <p class="footer-disclaimer">
          {t("n0brains provides analytical market data and intelligence for informational purposes only. It is not financial, investment, or trading advice, is not personalized to you, and is not a recommendation to buy, sell, hold, or size any position.")}
          {" "}{t("See")} <a href="/terms">{t("terms")}</a> §8.
        </p>
      </div>
    </footer>

    <script>
      (() => {
        /* Logged-in nav: login → dashboard, start-free CTA → log out
           (desktop rail + mobile sheet). auth_token may be expired —
           /dashboard itself re-validates. */
        try {
          if (localStorage.getItem("auth_token")) {
            /* Match by data-attr, not href — the login link is localized
               (/tr/login etc) so an exact href selector missed it and the
               nav showed "login" to signed-in users on non-English pages. */
            document.querySelectorAll('[data-nav-login]').forEach((a) => {
              a.textContent = a.dataset.dashLabel || "dashboard";
              a.setAttribute("href", "/dashboard");
              a.classList.toggle("active", window.location.pathname.replace(/^\/(es|tr|ru)(?=\/|$)/, "").startsWith("/dashboard"));
            });
            document.querySelectorAll('[data-nav-cta]').forEach((a) => {
              a.textContent = a.dataset.logoutLabel || "log out";
              a.setAttribute("href", a.dataset.loginHref || "/login");
              a.classList.add("is-logout");
              a.addEventListener("click", () => {
                localStorage.removeItem("auth_token");
                localStorage.removeItem("tier");
                localStorage.removeItem("api_key");
              });
            });
            /* In-content signup buttons (home hero, /proof, charts) stop
               pushing signup at people who already signed up. Prose links
               are left alone — /signup itself bounces authed visitors.
               href*= so localized /tr/signup and /signup?redirect both match. */
            document.querySelectorAll('a.btn-primary[href*="/signup"], a.btn-secondary[href*="/signup"], a.lm-cta[href*="/signup"]').forEach((a) => {
              a.textContent = "open dashboard →";
              a.setAttribute("href", "/dashboard");
            });
          }
        } catch { /* storage blocked — leave login link */ }

        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const header = document.getElementById("site-header");
        const hero   = document.getElementById("hero");
        const bar    = document.getElementById("scroll-progress");

        /* Scroll-linked state: glass header, hero text swap, progress bar.
           One rAF-throttled passive listener; transform/class writes only. */
        let ticking = false;
        const hint = document.getElementById("scroll-hint");
        const update = () => {
          const y = window.scrollY;
          header?.classList.toggle("glass", y > 8);
          if (hero) header?.classList.toggle("scrolled", hero.getBoundingClientRect().bottom < 60);
          if (bar) {
            const max = document.documentElement.scrollHeight - window.innerHeight;
            (bar as HTMLElement).style.transform = `scaleX(${max > 80 ? Math.min(y / max, 1) : 0})`;
          }
          if (hint) hint.classList.toggle("hidden", y > 40);
        };
        window.addEventListener("scroll", () => {
          if (!ticking) {
            requestAnimationFrame(() => { update(); ticking = false; });
            ticking = true;
          }
        }, { passive: true });
        update();

        /* Mobile nav sheet. */
        const burger = document.getElementById("nav-burger");
        const sheet = document.getElementById("nav-sheet");
        if (burger && sheet) {
          const setOpen = (open: boolean) => {
            sheet.hidden = !open;
            burger.setAttribute("aria-expanded", String(open));
            burger.classList.toggle("open", open);
            document.documentElement.style.overflow = open ? "hidden" : "";
          };
          burger.addEventListener("click", () =>
            setOpen(sheet.hidden));
          document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && !sheet.hidden) setOpen(false);
          });
          sheet.addEventListener("click", (e) => {
            if ((e.target as HTMLElement).closest("a")) setOpen(false);
          });
        }

        /* Legacy .post-card reveal (blog / intel lists). */
        const cards = document.querySelectorAll(".post-card");
        if (cards.length) {
          const io = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const card = entry.target;
                const delay = (card as HTMLElement).dataset.delay || 0;
                setTimeout(() => card.classList.add("visible"), Number(delay));
                io.unobserve(card);
              }
            });
          }, { threshold: 0.12 });
          cards.forEach((card, i) => {
            (card as HTMLElement).dataset.delay = String(i * 80);
            io.observe(card);
          });
        }

        /* data-reveal scroll choreography. Only elements still below the fold
           get hidden (no flash above the fold, no-JS users see everything).
           Beyond explicit attributes, common content blocks across the whole
           site are auto-instrumented so every page participates. */
        if (!reduceMotion) {
          const els: HTMLElement[] = Array.from(document.querySelectorAll("[data-reveal]"));
          const staggerGroups = document.querySelectorAll(
            "[data-reveal-stagger], .pricing-grid, .ep-list, .changelog-items"
          );
          staggerGroups.forEach((group) => {
            Array.from(group.children).forEach((child, i) => {
              const el = child as HTMLElement;
              if (!el.hasAttribute("data-reveal")) el.setAttribute("data-reveal", "up");
              el.style.setProperty("--reveal-delay", `${Math.min(i, 5) * 70}ms`);
              els.push(el);
            });
          });
          const AUTO = ".docs-page > .card, .content > *, .about-section > *, .ep-card, .changelog-entry";
          document.querySelectorAll(AUTO).forEach((node) => {
            const el = node as HTMLElement;
            if (el.hasAttribute("data-reveal")) return;
            if (el.matches("[data-reveal-stagger], .pricing-grid, .ep-list, .changelog-items, script, style")) return;
            el.setAttribute("data-reveal", "up");
            els.push(el);
          });
          const vh = window.innerHeight;
          const rio = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const el = entry.target as HTMLElement;
                el.classList.add("reveal-in");
                /* Drop residual transform after the transition so 3D tilt /
                   hover transforms aren't overridden later. */
                el.addEventListener("transitionend", () => {
                  el.classList.remove("reveal-init", "reveal-in");
                }, { once: true });
                rio.unobserve(el);
              }
            });
          }, { threshold: 0.1, rootMargin: "0px 0px -8% 0px" });
          els.forEach((el) => {
            if (el.getBoundingClientRect().top > vh * 0.88) {
              el.classList.add("reveal-init");
              rio.observe(el);
            }
          });
        }

        /* Terminal decode effect: section labels + [data-scramble] unscramble
           when they enter view. Screen readers get the final text via aria-label. */
        if (!reduceMotion) {
          const CHARS = "!<>-_\\/[]{}=+*^?#";
          const scramble = (el: HTMLElement) => {
            const final = el.textContent || "";
            if (!final.trim()) return;
            el.setAttribute("aria-label", final.trim());
            let frame = 0;
            const total = 16;
            const tick = () => {
              frame++;
              const settled = Math.floor((frame / total) * final.length);
              let out = final.slice(0, settled);
              for (let i = settled; i < final.length; i++) {
                out += final[i] === " " ? " " : CHARS[(Math.random() * CHARS.length) | 0];
              }
              el.textContent = out;
              if (frame < total) requestAnimationFrame(tick);
              else el.textContent = final;
            };
            requestAnimationFrame(tick);
          };
          const sio = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                scramble(entry.target as HTMLElement);
                sio.unobserve(entry.target);
              }
            });
          }, { threshold: 0.5 });
          document.querySelectorAll(".section-label, [data-scramble]").forEach((el) => sio.observe(el));

          /* Header tagline decodes the first time it swaps in. */
          const headerHero = document.getElementById("header-hero-text");
          if (headerHero && header) {
            let done = false;
            new MutationObserver(() => {
              if (!done && header.classList.contains("scrolled")) {
                done = true;
                scramble(headerHero);
              }
            }).observe(header, { attributes: true, attributeFilter: ["class"] });
          }
        }

        /* Cursor spotlight on source cards — pointer devices only. */
        if (window.matchMedia("(hover: hover)").matches) {
          document.querySelectorAll(".source-card").forEach((card) => {
            card.addEventListener("mousemove", (e) => {
              const r = card.getBoundingClientRect();
              const me = e as MouseEvent;
              (card as HTMLElement).style.setProperty("--mx", `${me.clientX - r.left}px`);
              (card as HTMLElement).style.setProperty("--my", `${me.clientY - r.top}px`);
            }, { passive: true });
          });

          /* 3D tilt on pricing cards — inline transform so it composes with
             (and overrides) any CSS hover transform while the pointer moves. */
          if (!reduceMotion) {
            document.querySelectorAll(".pricing-card").forEach((node) => {
              const card = node as HTMLElement;
              card.addEventListener("mousemove", (e) => {
                const r = card.getBoundingClientRect();
                const me = e as MouseEvent;
                const rx = ((me.clientY - r.top) / r.height - 0.5) * -4;
                const ry = ((me.clientX - r.left) / r.width - 0.5) * 4;
                card.style.transition = "transform 0.08s ease-out";
                card.style.transform =
                  `perspective(900px) rotateX(${rx.toFixed(2)}deg) rotateY(${ry.toFixed(2)}deg) translateY(-4px)`;
              }, { passive: true });
              card.addEventListener("mouseleave", () => {
                card.style.transition = "";
                card.style.transform = "";
              });
            });
          }
        }
      })();
    </script>
  </body>
</html>

---
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  homepage?: boolean;
}

const { title, description, canonicalURL, homepage } = Astro.props;
const url = canonicalURL ?? Astro.url;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — n0brains</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="n0brains RSS" href="/rss.xml" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:site_name" content="n0brains" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header id="site-header">
      <div class="inner">
        <a href="/" class="logo" id="header-logo">&lt;<span>n0</span>brains /&gt;</a>
        {homepage && <span class="header-hero-text" id="header-hero-text">think less ship more.</span>}
        <nav>
          <a href="/">home</a>
          <a href="/about">about</a>
          <a href="/rss.xml">rss</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="inner">
        <p>© {new Date().getFullYear()} <a href="https://n0brains.com">n0brains.com</a> — think less, ship more.</p>
      </div>
    </footer>

    {homepage && (
      <script>
        (() => {
          const header = document.getElementById("site-header");
          const hero = document.getElementById("hero");
          let ticking = false;

          const update = () => {
            if (!hero) return;
            const heroBottom = hero.getBoundingClientRect().bottom;
            if (heroBottom < 60) {
              header.classList.add("scrolled");
            } else {
              header.classList.remove("scrolled");
            }
          };

          const onScroll = () => {
            if (!ticking) {
              window.requestAnimationFrame(() => {
                update();
                ticking = false;
              });
              ticking = true;
            }
          };

          window.addEventListener("scroll", onScroll, { passive: true });
          update();
        })();
      </script>
    )}
  </body>
</html>


---
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
  canonicalURL?: string | URL;
  homepage?: boolean;
  ogType?: "website" | "article";
  ogImage?: string;        // absolute or /-rooted path
  noIndex?: boolean;
  keywords?: string[];
}

const {
  title,
  description,
  canonicalURL,
  homepage = false,
  ogType = "website",
  ogImage = "/og-default.png",
  noIndex = false,
  keywords = [],
} = Astro.props;

const url        = canonicalURL ?? Astro.url;
const siteUrl    = "https://n0brains.com";
const fullTitle  = homepage ? "n0brains — Crypto signals that prove their own edge" : `${title} — n0brains`;
const absoluteOg = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
const year       = new Date().getFullYear();

// JSON-LD: site-wide on home, article on blog posts (via ogType)
const orgLd = {
  "@context":  "https://schema.org",
  "@type":     "Organization",
  name:        "n0brains",
  url:         siteUrl,
  logo:        `${siteUrl}/favicon.svg`,
  sameAs: [
    "https://x.com/n0brainsai",
    "https://t.me/n0brainssignals",
    "https://www.instagram.com/n0brainsai",
    "https://bsky.app/profile/n0brains.com",
    "https://github.com/sbynode-ux/n0brains",
  ],
  description:
    "Crypto signal API for autonomous trading agents. 10+ sources, machine-classified, delivered via REST, WebSocket, or webhook.",
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: homepage
    ? [{ "@type": "ListItem", position: 1, name: "n0brains", item: siteUrl }]
    : [
        { "@type": "ListItem", position: 1, name: "n0brains", item: siteUrl },
        { "@type": "ListItem", position: 2, name: title, item: String(url).startsWith("http") ? String(url) : `${siteUrl}${url}` },
      ],
};

const softwareAppLd = homepage ? {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "n0brains",
  url: siteUrl,
  description: "AI-powered crypto intelligence platform. Real-time signals from whales, funding, on-chain flows, news, macro, and congress trades — fused, scored, and delivered via REST, WebSocket, or Webhook API.",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  offers: [
    { "@type": "Offer", price: "0", priceCurrency: "USD", description: "Free tier — 60 req/min, 15-minute signal delay, REST API" },
    { "@type": "Offer", price: "19.99", priceCurrency: "USD", description: "Pro tier — 600 req/min, real-time signals, REST + WebSocket + Webhooks" },
  ],
  featureList: [
    "Real-time whale tracking",
    "Funding and liquidation alerts",
    "On-chain flows",
    "Macro Pulse daily BTC and ETH directional bias",
    "Manipulation detection",
    "Narrative heatmap",
    "Trust and rug scoring",
    "Semantic signal search",
    "Congress trades signal",
    "Wallet DNA classification",
  ],
  provider: {
    "@type": "Organization",
    name: "n0brains",
    url: siteUrl,
    logo: `${siteUrl}/og-default.png`,
  },
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="canonical" href={url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="n0brains RSS"     href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="n0brains podcast" href="/podcast.xml" />

    <!-- Open Graph -->
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={url} />
    <meta property="og:site_name"   content="n0brains" />
    <meta property="og:type"        content={ogType} />
    <meta property="og:image"       content={absoluteOg} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={absoluteOg} />

    <!-- Color -->
    <meta name="theme-color" content="#050505" />

    <!-- Fonts: prefer locally-hosted (in /fonts) when self-hosting; otherwise CDN -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap"
      rel="stylesheet"
    />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    {softwareAppLd && <script type="application/ld+json" set:html={JSON.stringify(softwareAppLd)} />}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <div id="scroll-progress" aria-hidden="true"></div>

    <a class="founding-banner" href="/pricing?utm_source=site&utm_medium=banner&utm_campaign=founding20">
      🏁 <strong>Founding&nbsp;20</strong> — code <span class="fb-code">RACE</span> at checkout = 1&nbsp;month Pro free, in exchange for honest feedback. 20 seats, then it's gone&nbsp;→
    </a>

    <header id="site-header">
      <div class="inner">
        <a href="/" class="logo" id="header-logo" aria-label="n0brains home">
          &lt;<span>n0</span>brains /&gt;
        </a>
        {homepage && (
          <span class="header-hero-text" id="header-hero-text" aria-hidden="true">
            // We publish our win-rate.
          </span>
        )}
        <nav aria-label="Primary">
          <a href="/docs/">docs</a>
          <a href="/docs/quickstart">quickstart</a>
          <a href="/proof">proof</a>
          <a href="/charts/liqmap">charts</a>
          <a href="/about">about</a>
          <a href="/intel">intel</a>
          <a href="/blog">blog</a>
          <a href="/podcast">podcast</a>
          <a href="/login">login</a>
          <a href="/dashboard">account</a>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer>
      <div class="inner">
        <p>© {year} <a href="https://n0brains.com">n0brains.com</a> — We publish our win-rate.</p>
        <div class="footer-socials">
          <a href="https://x.com/n0brainsai" target="_blank" rel="noopener noreferrer" aria-label="n0brains on X" title="X / Twitter">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644z"/></svg>
          </a>
          <a href="https://t.me/n0brainssignals" target="_blank" rel="noopener noreferrer" aria-label="n0brains on Telegram" title="Telegram">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          </a>
          <a href="https://www.instagram.com/n0brainsai" target="_blank" rel="noopener noreferrer" aria-label="n0brains on Instagram" title="Instagram">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
        </div>
        <p class="footer-links">
          <a href="/privacy">privacy</a>
          <a href="/terms">terms</a>
          <a href="/rss.xml">rss</a>
          <a href="/contact">contact</a>
        </p>
        <p class="footer-disclaimer">
          n0brains provides analytical market data and intelligence for informational
          purposes only. It is not financial, investment, or trading advice, is not
          personalized to you, and is not a recommendation to buy, sell, hold, or size
          any position. See <a href="/terms">terms</a> §8.
        </p>
      </div>
    </footer>

    <script>
      (() => {
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const header = document.getElementById("site-header");
        const hero   = document.getElementById("hero");
        const bar    = document.getElementById("scroll-progress");

        /* Scroll-linked state: glass header, hero text swap, progress bar.
           One rAF-throttled passive listener; transform/class writes only. */
        let ticking = false;
        const update = () => {
          const y = window.scrollY;
          header?.classList.toggle("glass", y > 8);
          if (hero) header?.classList.toggle("scrolled", hero.getBoundingClientRect().bottom < 60);
          if (bar) {
            const max = document.documentElement.scrollHeight - window.innerHeight;
            (bar as HTMLElement).style.transform = `scaleX(${max > 80 ? Math.min(y / max, 1) : 0})`;
          }
        };
        window.addEventListener("scroll", () => {
          if (!ticking) {
            requestAnimationFrame(() => { update(); ticking = false; });
            ticking = true;
          }
        }, { passive: true });
        update();

        /* Legacy .post-card reveal (blog / intel lists). */
        const cards = document.querySelectorAll(".post-card");
        if (cards.length) {
          const io = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const card = entry.target;
                const delay = (card as HTMLElement).dataset.delay || 0;
                setTimeout(() => card.classList.add("visible"), Number(delay));
                io.unobserve(card);
              }
            });
          }, { threshold: 0.12 });
          cards.forEach((card, i) => {
            (card as HTMLElement).dataset.delay = String(i * 80);
            io.observe(card);
          });
        }

        /* data-reveal scroll choreography. Only elements still below the fold
           get hidden (no flash above the fold, no-JS users see everything). */
        if (!reduceMotion) {
          const els: HTMLElement[] = Array.from(document.querySelectorAll("[data-reveal]"));
          document.querySelectorAll("[data-reveal-stagger]").forEach((group) => {
            Array.from(group.children).forEach((child, i) => {
              const el = child as HTMLElement;
              if (!el.hasAttribute("data-reveal")) el.setAttribute("data-reveal", "up");
              el.style.setProperty("--reveal-delay", `${Math.min(i, 5) * 70}ms`);
              els.push(el);
            });
          });
          const vh = window.innerHeight;
          const rio = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("reveal-in");
                rio.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1, rootMargin: "0px 0px -8% 0px" });
          els.forEach((el) => {
            if (el.getBoundingClientRect().top > vh * 0.88) {
              el.classList.add("reveal-init");
              rio.observe(el);
            }
          });
        }

        /* Cursor spotlight on source cards — pointer devices only. */
        if (window.matchMedia("(hover: hover)").matches) {
          document.querySelectorAll(".source-card").forEach((card) => {
            card.addEventListener("mousemove", (e) => {
              const r = card.getBoundingClientRect();
              const me = e as MouseEvent;
              (card as HTMLElement).style.setProperty("--mx", `${me.clientX - r.left}px`);
              (card as HTMLElement).style.setProperty("--my", `${me.clientY - r.top}px`);
            }, { passive: true });
          });
        }
      })();
    </script>
  </body>
</html>

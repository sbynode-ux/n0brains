---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="liquidation heatmap"
  description="n0brains live liquidation heatmap — real on-chain DEX positions (Hyperliquid + GMX) with exact liquidation prices, plotted as a price × time density map. Where leveraged positions cluster to liquidate. Free, live. Not financial advice."
>
  <section class="about-section lm-wide">
    <h1>liquidation heatmap</h1>
    <p class="legal-updated">
      Where leveraged positions cluster to liquidate, over time — the bright bands
      are liquidity magnets. This reads <strong>real on-chain positions</strong>
      (Hyperliquid + GMX) with their <em>exact</em> liquidation prices, captured
      every 15&nbsp;minutes and stacked into a price&nbsp;×&nbsp;time map. Free and
      live. Analytical data, <strong>not financial advice</strong>.
    </p>

    <div class="lm-controls">
      <div id="lm-coins" class="lm-tabs" role="tablist" aria-label="coin"></div>
    </div>

    <div id="lm-banner" class="proof-banner proof-loading" role="status">
      <span class="dot"></span><span class="banner-text">loading heatmap…</span>
    </div>

    <div id="lm-wrap" class="lm-wrap">
      <canvas id="lm-canvas" class="lm-canvas"></canvas>
    </div>
    <p class="meta" id="lm-meta"></p>
    <p class="lm-disclaimer" id="lm-disclaimer"></p>
  </section>

  <style is:global>
    /* widen this page past the global .about-section 600px cap (heatmap needs room) */
    .about-section.lm-wide { max-width: 1100px; }
  </style>
  <style>
    .lm-controls { display:flex; gap:1.25rem; flex-wrap:wrap; align-items:center; margin:1.75rem 0 1rem; }
    .lm-tabs { display:flex; gap:.4rem; flex-wrap:wrap; }
    .lm-tabs button {
      background:transparent; border:1px solid var(--border,#2a2a3a);
      color:var(--text,#cfd2dc); padding:.4rem .85rem; border-radius:7px;
      cursor:pointer; font-size:.82rem; font-family:inherit; line-height:1;
      transition:background .12s,border-color .12s;
    }
    .lm-tabs button:hover { border-color:var(--accent,#5b8cff); }
    .lm-tabs button.active { background:var(--accent,#5b8cff); color:#fff; border-color:var(--accent,#5b8cff); }
    .lm-wrap { width:100%; overflow-x:auto; margin-top:.25rem; min-height:140px; }
    .lm-canvas { display:block; width:100%; max-width:1080px; height:auto; border-radius:6px; background:#0d0b1a; }
    .lm-disclaimer { font-size:.72rem; color:#6b7280; margin-top:.4rem; max-width:64ch; }
    .proof-banner.proof-ok .dot { background:#2ecc71; }
  </style>

  <script is:inline>
  (function () {
    "use strict";
    const API = "https://api.n0brains.com";
    const COINS = ["BTC","ETH"];           // DEX real-position coins
    const REFRESH_MS = 60000;
    let coin = "BTC", timer = null, reqId = 0;

    const $ = (id) => document.getElementById(id);
    const fmtPx = (p) => {
      p = +p;
      if (p >= 1000) return "$" + p.toLocaleString(undefined, { maximumFractionDigits: 0 });
      if (p >= 1)    return "$" + p.toFixed(2);
      return "$" + p.toPrecision(3);
    };
    const fmtUsd = (n) => {
      n = Math.abs(+n||0);
      if (n>=1e9) return "$"+(n/1e9).toFixed(2)+"B";
      if (n>=1e6) return "$"+(n/1e6).toFixed(0)+"M";
      if (n>=1e3) return "$"+(n/1e3).toFixed(0)+"K";
      return "$"+n.toFixed(0);
    };

    // Coinglass-style colormap: dark purple (low) → blue → teal → green → yellow (high).
    // Intensity is 0..1 (log-scaled). Returns "rgb(r,g,b)".
    function heatColor(t) {
      t = Math.max(0, Math.min(1, t));
      // piecewise gradient stops
      const stops = [
        [0.00, [13, 11, 26]],    // near-bg dark
        [0.18, [40, 22, 90]],    // purple
        [0.40, [38, 70, 150]],   // blue
        [0.60, [20, 150, 150]],  // teal
        [0.80, [40, 200, 90]],   // green
        [1.00, [240, 240, 40]],  // yellow
      ];
      for (let i = 1; i < stops.length; i++) {
        if (t <= stops[i][0]) {
          const [t0, c0] = stops[i-1], [t1, c1] = stops[i];
          const f = (t - t0) / (t1 - t0 || 1);
          const r = Math.round(c0[0] + (c1[0]-c0[0])*f);
          const g = Math.round(c0[1] + (c1[1]-c0[1])*f);
          const b = Math.round(c0[2] + (c1[2]-c0[2])*f);
          return `rgb(${r},${g},${b})`;
        }
      }
      return "rgb(240,240,40)";
    }

    function buildCoinTabs() {
      const el = $("lm-coins");
      el.innerHTML = COINS.map((c) =>
        `<button data-coin="${c}" role="tab" class="${c===coin?'active':''}">${c}</button>`).join("");
      el.querySelectorAll("button").forEach((b) =>
        b.addEventListener("click", () => { coin = b.dataset.coin; syncTabs(); load(); }));
    }
    function syncTabs() {
      document.querySelectorAll("#lm-coins button").forEach((b) =>
        b.classList.toggle("active", b.dataset.coin === coin));
    }
    function banner(state, text) {
      const b = $("lm-banner");
      b.className = "proof-banner " + state;
      b.querySelector(".banner-text").textContent = text;
    }

    function render(d) {
      const grid = d.grid || [], cols = d.cols || 0, rows = d.rows || 0;
      const canvas = $("lm-canvas"), wrap = $("lm-wrap");
      if (!cols || !rows || !grid.length) {
        banner("proof-loading", d.note || "heatmap builds as snapshots accumulate (every 15 min)");
        const ctx = canvas.getContext("2d");
        canvas.width = 1000; canvas.height = 200;
        ctx.fillStyle = "#0d0b1a"; ctx.fillRect(0,0,canvas.width,canvas.height);
        ctx.fillStyle = "#6b7280"; ctx.font = "14px system-ui";
        ctx.fillText("Heatmap is building — first snapshots captured, more every 15 min.", 24, 100);
        $("lm-meta").textContent = ""; $("lm-disclaimer").textContent = d.disclaimer || "";
        return;
      }

      // log-scale normalize between min and max nonzero (NOT log(v)/log(max),
      // which bunches everything near 1.0 → all-green). Spread the actual range
      // [minNonzero, max] across the full 0..1 colormap.
      let maxV = 0, minV = Infinity;
      for (const r of grid) for (const v of r) { if (v > maxV) maxV = v; if (v > 0 && v < minV) minV = v; }
      if (!isFinite(minV)) minV = maxV || 1;
      const lMin = Math.log(minV), lMax = Math.log(maxV);
      const denom = (lMax - lMin) || 1;
      const norm = (v) => v <= 0 ? 0 : (Math.log(v) - lMin) / denom;

      // canvas geometry: price axis (left gutter) + time axis (bottom)
      const padL = 70, padB = 26, padT = 10, padR = 10;
      const plotW = Math.max(360, Math.min(1000, cols * 10));
      const plotH = Math.max(320, Math.min(680, rows * 7));
      const W = padL + plotW + padR, H = padT + plotH + padB;
      // hi-DPI
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      canvas.width = W * dpr; canvas.height = H * dpr;
      canvas.style.width = W + "px"; canvas.style.height = H + "px";
      const ctx = canvas.getContext("2d");
      ctx.setTransform(dpr,0,0,dpr,0,0);
      ctx.fillStyle = "#0d0b1a"; ctx.fillRect(0,0,W,H);

      const cellW = plotW / cols, cellH = plotH / rows;
      // cells (grid[0] = highest price = top row)
      for (let ri = 0; ri < rows; ri++) {
        for (let ciIdx = 0; ciIdx < cols; ciIdx++) {
          const v = grid[ri][ciIdx];
          if (v > 0) {
            ctx.fillStyle = heatColor(norm(v));
            ctx.fillRect(padL + ciIdx*cellW, padT + ri*cellH, Math.ceil(cellW)+0.5, Math.ceil(cellH)+0.5);
          }
        }
      }

      // price axis labels (Y)
      ctx.fillStyle = "#8b909c"; ctx.font = "11px system-ui"; ctx.textAlign = "right";
      const prices = d.prices || [];
      const yticks = 7;
      for (let k = 0; k <= yticks; k++) {
        const idx = Math.round((rows - 1) * k / yticks);
        const py = padT + idx*cellH + cellH/2;
        const price = prices[idx];
        if (price != null) {
          ctx.fillStyle = "#23262f"; ctx.fillRect(padL, py, plotW, 0.5);
          ctx.fillStyle = "#8b909c"; ctx.fillText(fmtPx(price), padL-6, py+3);
        }
      }

      // spot line (latest spot, dashed yellow) at its price row
      const spot = (d.spots && d.spots.length) ? d.spots[d.spots.length-1] : null;
      if (spot != null && d.price_min != null && d.price_max != null && d.price_max > d.price_min) {
        const frac = (d.price_max - spot) / (d.price_max - d.price_min);
        const sy = padT + Math.max(0, Math.min(1, frac)) * plotH;
        ctx.strokeStyle = "#f5c518"; ctx.lineWidth = 1.4; ctx.setLineDash([5,3]);
        ctx.beginPath(); ctx.moveTo(padL, sy); ctx.lineTo(padL+plotW, sy); ctx.stroke();
        ctx.setLineDash([]);
        ctx.fillStyle = "#f5c518"; ctx.textAlign = "left"; ctx.font = "bold 11px system-ui";
        ctx.fillText("spot " + fmtPx(spot), padL+6, sy-4);
      }

      // time axis labels (X) — first / mid / last
      ctx.fillStyle = "#8b909c"; ctx.font = "11px system-ui"; ctx.textAlign = "center";
      const times = d.times || [];
      const fmtT = (ts) => { const dt = new Date(ts*1000);
        return (dt.getMonth()+1) + "/" + dt.getDate() + " " + String(dt.getHours()).padStart(2,"0") + ":" + String(dt.getMinutes()).padStart(2,"0"); };
      [0, Math.floor(cols/2), cols-1].forEach((ci) => {
        if (times[ci] != null) ctx.fillText(fmtT(times[ci]), padL + ci*cellW + cellW/2, H-8);
      });

      $("lm-canvas") && (wrap.scrollLeft = wrap.scrollWidth);  // keep latest in view
      const span = times.length>1 ? Math.round((times[times.length-1]-times[0])/3600) : 0;
      $("lm-meta").innerHTML =
        `<strong>${coin}</strong> · ${cols} snapshots · ${span}h of history · ` +
        `price ${fmtPx(d.price_min)}–${fmtPx(d.price_max)} · real DEX positions (HL+GMX)`;
      $("lm-disclaimer").textContent = d.disclaimer || "";
      banner("proof-ok", "live");
    }

    async function load() {
      const my = ++reqId;
      banner("proof-loading", "loading " + coin + " heatmap…");
      try {
        const r = await fetch(API + "/charts/liqmap-heatmap/dex/" + encodeURIComponent(coin), { cache: "no-store" });
        if (my !== reqId) return;
        if (!r.ok) { banner("proof-error", "error " + r.status); return; }
        const data = await r.json();
        if (my !== reqId) return;
        render(data);
      } catch (e) {
        if (my !== reqId) return;
        banner("proof-error", "fetch failed — retrying…");
      }
    }

    function start() {
      buildCoinTabs(); load();
      timer = setInterval(load, REFRESH_MS);
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) { clearInterval(timer); timer = null; }
        else if (!timer) { load(); timer = setInterval(load, REFRESH_MS); }
      });
    }
    if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", start);
    else start();
  })();
  </script>
</BaseLayout>

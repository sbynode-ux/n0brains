---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="stock market liquidation heatmap"
  description="n0brains live stock market liquidation map — where leveraged positions on tokenized stocks, indices, metals and commodities (NVDA, TSLA, S&P 500, gold, oil…) cluster to liquidate. Real on-chain positions from Hyperliquid HIP-3 perp DEXs. Free, live. Not financial advice."
>
  <section class="about-section lm-wide">
    <a href="/charts" class="lm-back">← charts</a>
    <p class="lm-kicker"><span class="lm-livedot"></span>On-chain HIP-3 · live · <a href="/charts/liqmap" class="lm-accent" style="text-decoration:underline">cryptocurrency →</a></p>
    <h1 class="lm-h1">STOCK MARKET<br /><span class="lm-accent">LIQUIDATION</span></h1>
    <p class="legal-updated">
      Where leveraged positions on <strong>tokenized stocks, indices, metals and
      commodities</strong> cluster to liquidate — bright bands are liquidity magnets
      the price tends to gravitate toward. We read these as risk levels (where to
      place stops and targets), not as a direction to trade — liquidity predicts
      volatility, not which way price goes. Two views:
      <strong>estimate</strong> models liquidation density from live
      <strong>Hyperliquid HIP-3</strong> open interest across standard leverage
      tiers (the Coinglass-style projection); <strong>real</strong> shows only the
      actual on-chain positions the protocol settles against — 100% real, but a thin
      book looks sparse. Analytical data, <strong>not financial advice</strong>.
    </p>

    <div class="lm-controls">
      <div id="lm-coins" class="lm-tabs" role="tablist" aria-label="symbol"></div>
      <div id="lm-venue" class="lm-tabs" role="tablist" aria-label="data source">
        <button data-venue="est" class="active" role="tab" title="Modeled liquidation density from live open interest across leverage tiers — the Coinglass-style estimate">estimate · modeled</button>
        <button data-venue="dex" role="tab" title="Real on-chain HIP-3 positions only — sparse but 100% real, no model">HIP-3 · real (live)</button>
      </div>
      <div id="lm-range" class="lm-tabs" role="tablist" aria-label="time range">
        <button data-days="1" class="active" role="tab">24h</button>
        <button data-days="7" role="tab">7d</button>
        <button data-days="30" role="tab">30d</button>
        <button data-days="180" role="tab">max</button>
      </div>
      <div id="lm-zoom" class="lm-tabs" role="tablist" aria-label="price zoom">
        <button data-zoom="auto" class="active" role="tab">auto</button>
        <button data-zoom="0.03" role="tab">±3%</button>
        <button data-zoom="0.06" role="tab">±6%</button>
        <button data-zoom="0.12" role="tab">±12%</button>
        <button data-zoom="1" role="tab">full</button>
      </div>
      <div id="lm-overlays" class="lm-tabs" role="group" aria-label="overlays">
        <button data-ov="real" class="active" role="tab" title="Real NYSE/NASDAQ session price (Yahoo, delayed) — gaps are closed-market hours">real price</button>
        <button data-ov="walls" class="active" role="tab" title="Listed-options open-interest walls (CBOE, delayed) — strike magnets + max pain">options walls</button>
      </div>
      <label class="lm-thresh" title="Hide weaker levels — drag up to show only the strongest liquidity bands">
        liquidity threshold <span id="lm-thresh-val">0.70</span>
        <input id="lm-thresh-input" type="range" min="0" max="0.9" step="0.01" value="0.70" aria-label="liquidity threshold" />
      </label>
      <div id="lm-palette" class="lm-swatches" role="group" aria-label="color scheme">
        <button data-pal="viridis" class="active" title="viridis" style="background:linear-gradient(90deg,#28165a,#149696,#28c85a,#f0f028)"></button>
        <button data-pal="bluered" title="blue → red" style="background:linear-gradient(90deg,#1e50c8,#14c8d2,#f0dc28,#e63228)"></button>
        <button data-pal="greenred" title="green → red" style="background:linear-gradient(90deg,#28c85a,#f0e628,#e63228)"></button>
        <button data-pal="heat" title="heat" style="background:linear-gradient(90deg,#8c143c,#e6461e,#fab428,#fafae6)"></button>
      </div>
    </div>

    <div id="lm-banner" class="proof-banner proof-loading" role="status">
      <span class="dot"></span><span class="banner-text">loading heatmap…</span>
    </div>

    <div id="lm-wrap" class="lm-wrap">
      <canvas id="lm-canvas" class="lm-canvas"></canvas>
      <div id="lm-tip" class="lm-tip"></div>
    </div>
    <p class="meta" id="lm-meta"></p>
    <p class="lm-disclaimer" id="lm-disclaimer"></p>

    <div class="lm-upsell">
      <p>
        <strong>Want this data in your agent or bot?</strong> The liquidation map +
        heatmap are on the <a href="/signup">n0brains API</a> — both the CEX estimate
        and the <strong>real on-chain DEX</strong> map, all coins, programmatic via
        REST &amp; the MCP server.
      </p>
      <p class="lm-endpoints">
        <code>/liqmap/{'{coin}'}</code> · <code>/liquidation-map/{'{coin}'}</code> ·
        <code>/liq-heatmap/{'{coin}'}</code> · <code>/liquidation-heatmap/{'{coin}'}</code>
        — <a href="/docs#liquidation-map">docs</a>
      </p>
      <a class="lm-cta" href="/signup">Get API access →</a>
    </div>
  </section>

  <style is:global>
    /* widen this page past the global .about-section 600px cap (heatmap needs room) */
    .about-section.lm-wide { max-width: 1100px; }
    /* charts-hub shell header (matches /charts/win-rate etc.) */
    .lm-back { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-muted); text-decoration: none; }
    .lm-back:hover { color: var(--accent); }
    .lm-kicker { font-family: var(--font-mono); font-size: 0.74rem; text-transform: uppercase;
      letter-spacing: 0.2em; color: var(--accent); margin: 1rem 0; display: flex; align-items: center; gap: 0.6rem; }
    .lm-livedot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent);
      box-shadow: 0 0 8px var(--accent); display: inline-block; animation: lm-blink 2s infinite; }
    @keyframes lm-blink { 50% { opacity: 0.3; } }
    .lm-h1 { font-family: var(--font-display); font-size: clamp(2.6rem, 7vw, 4.6rem);
      line-height: 0.92; color: var(--text-heading); margin-bottom: 1rem; }
    .lm-accent { color: var(--accent); }
  </style>
  <style>
    .lm-controls { display:flex; gap:1.25rem; flex-wrap:wrap; align-items:center; margin:1.75rem 0 1rem; }
    .lm-tabs { display:flex; gap:.4rem; flex-wrap:wrap; }
    /* :global so the rules also match the coin buttons injected via innerHTML
       into #lm-coins — Astro's scoped [data-astro-cid] never lands on JS nodes,
       which left the selected coin un-highlighted. */
    .lm-tabs :global(button) {
      background:var(--bg-card,#0d0d0d); border:1px solid var(--border,#1a1a1a);
      color:var(--text-muted,#707070); padding:.4rem .85rem; border-radius:7px;
      cursor:pointer; font-size:.82rem; font-family:var(--font-mono,inherit); line-height:1;
      transition:background .12s,border-color .12s,color .12s;
    }
    .lm-tabs :global(button:hover) { border-color:var(--accent,#00ff41); color:var(--text-heading,#efefef); }
    .lm-tabs :global(button.active) { background:var(--accent,#00ff41); color:#000; font-weight:700; border-color:var(--accent,#00ff41); }
    .lm-thresh { display:flex; align-items:center; gap:.5rem; font-size:.78rem; color:#9aa0ad; }
    .lm-thresh input[type=range] { width:150px; accent-color:var(--accent,#5b8cff); cursor:pointer;
      height:24px; touch-action:pan-y; }
    @media (pointer:coarse) {            /* bigger tap targets on touch devices */
      .lm-thresh input[type=range] { width:170px; }
      .lm-swatches button { width:38px; height:26px; }
      .lm-tabs :global(button) { padding:.6rem 1.05rem; min-height:40px; }  /* ~44px touch target */
    }
    /* Narrow screens: tighten controls, give threshold its own full row, shrink fonts */
    @media (max-width: 640px) {
      .lm-controls { gap:.7rem; }
      .lm-tabs :global(button) { font-size:.78rem; padding:.5rem .7rem; }
      .lm-thresh { width:100%; }
      .lm-thresh input[type=range] { flex:1; width:auto; }
      .lm-swatches { width:100%; }
    }
    #lm-thresh-val { color:#cfd2dc; font-variant-numeric:tabular-nums; min-width:2.5em; }
    .lm-swatches { display:flex; gap:.3rem; }
    .lm-swatches button {
      width:30px; height:18px; border-radius:4px; border:1px solid #2a2a3a;
      padding:0; cursor:pointer; outline:none;
    }
    .lm-swatches button.active { border-color:#fff; box-shadow:0 0 0 1px #fff; }
    .lm-wrap { width:100%; margin-top:.25rem; min-height:140px; position:relative; }
    .lm-canvas { display:block; width:100%; height:auto; border-radius:6px; background:#0d0b1a;
      cursor:crosshair; -webkit-user-select:none; user-select:none; touch-action:none;
      -webkit-touch-callout:none; }
    .lm-tip { display:none; position:absolute; pointer-events:none; z-index:5; background:rgba(15,13,28,0.96);
      border:1px solid #3a3a4a; border-radius:7px; padding:.5rem .7rem; font-size:.74rem;
      color:#e3e6ee; line-height:1.5; white-space:nowrap; box-shadow:0 4px 14px rgba(0,0,0,0.5); }
    .lm-tip .lm-tip-k { color:#9aa0ad; } .lm-tip b { color:#fff; font-variant-numeric:tabular-nums; }
    .lm-disclaimer { font-size:.72rem; color:#6b7280; margin-top:.4rem; max-width:74ch; }
    .lm-upsell { margin-top:2rem; padding:1.25rem 1.5rem; border:1px solid var(--border,#2a2a3a);
      border-radius:10px; background:rgba(91,140,255,0.05); max-width:74ch; }
    .lm-upsell p { margin:0 0 .6rem; font-size:.9rem; color:#cfd2dc; }
    .lm-upsell .lm-endpoints { font-size:.74rem; color:#9aa0ad; }
    .lm-upsell code { font-size:.72rem; color:#8fb3ff; }
    .lm-cta { display:inline-block; margin-top:.4rem; background:var(--accent,#5b8cff);
      color:#fff; padding:.5rem 1rem; border-radius:7px; font-size:.85rem; font-weight:600;
      text-decoration:none; }
    .lm-cta:hover { filter:brightness(1.1); }
    .proof-banner.proof-ok .dot { background:#2ecc71; }
  </style>

  <script is:inline>
  (function () {
    "use strict";
    const API = "https://api.n0brains.com";
    // Tokenized stocks / indices / metals / commodities on Hyperliquid HIP-3.
    // All are DEX-only (no CEX/Coinglass estimate exists for these), served by
    // /liqmap/{symbol} off the HIP-3 liquidation map.
    const COINS = ["SP500","NASDAQ","XYZ100","NVDA","TSLA","AAPL","AMD","MSFT","GOOGL","AMZN","META",
                   "MSTR","COIN","HOOD","PLTR","NBIS","SKHX","SMSN","BB","GOLD","SILVER","COPPER","OIL","BRENTOIL"];
    const DEX_COINS = new Set(COINS);   // every symbol is on-chain only
    // HL market string per chart symbol — price candles come from HL's own
    // candleSnapshot (Binance/CoinGecko have no tokenized-stock data).
    const HL_MARKET = {
      SP500:"xyz:SP500", NASDAQ:"mkts:USTECH", NVDA:"xyz:NVDA", TSLA:"xyz:TSLA",
      AAPL:"xyz:AAPL", AMD:"xyz:AMD", MSFT:"xyz:MSFT", GOOGL:"xyz:GOOGL",
      AMZN:"xyz:AMZN", META:"xyz:META", MSTR:"xyz:MSTR", COIN:"xyz:COIN",
      HOOD:"xyz:HOOD", PLTR:"xyz:PLTR", GOLD:"xyz:GOLD", SILVER:"xyz:SILVER",
      COPPER:"xyz:COPPER", OIL:"xyz:CL",
      XYZ100:"xyz:XYZ100", NBIS:"xyz:NBIS", SKHX:"xyz:SKHX", SMSN:"xyz:SMSN",
      BB:"xyz:BB", BRENTOIL:"xyz:BRENTOIL",
    };
    let candleCache = {};   // coin:interval:hour -> [{t,o,h,l,c}]
    let realCache = {};     // coin:days:hour -> stock-candles payload
    let wallsCache = {};    // coin:halfhour -> options-walls payload
    // symbols whose tokenized contract trades at its own unit scale (not the
    // real index level) — flagged in the legend so ~$718 doesn't read as a bug
    const UNIT_NOTE = {
      NASDAQ: "quoted in mkts:USTECH contract units — not the ^IXIC index level",
      SKHX: "quoted in xyz:SKHX contract units — not the KRX 000660 share price",
      SMSN: "quoted in xyz:SMSN contract units — not the SMSN.IL GDR price",
    };
    const OV = { real: true, walls: true };   // overlay toggles
    const REFRESH_MS = 120000;
    const VENUE_DEFAULT_DAYS = { dex: 1, est: 7 };
    const VENUE_DEFAULT_THR  = { dex: 0.7, est: 0.55 };
    let coin = "SP500", venue = "est", days = VENUE_DEFAULT_DAYS.est, timer = null, reqId = 0, lastData = null, resizeT = null, threshold = VENUE_DEFAULT_THR.est;
    let FOCUS_PCT = "auto";   // y-axis zoom: "auto" fits the band holding most liquidity
    let lastGeom = null;

    const $ = (id) => document.getElementById(id);
    const fmtPx = (p) => {
      p = +p;
      if (p >= 1000) return "$" + p.toLocaleString(undefined, { maximumFractionDigits: 0 });
      if (p >= 1)    return "$" + p.toFixed(2);
      return "$" + p.toPrecision(3);
    };
    const fmtUsd = (n) => {
      n = Math.abs(+n || 0);
      if (n >= 1e9) return "$" + (n/1e9).toFixed(2) + "B";
      if (n >= 1e6) return "$" + (n/1e6).toFixed(1) + "M";
      if (n >= 1e3) return "$" + (n/1e3).toFixed(0) + "K";
      return "$" + n.toFixed(0);
    };

    // Selectable colormaps (like Coinglass's palette swatches). Each = stop list
    // [t, [r,g,b]] from low→high; the dark first stop blends into the bg.
    const PALETTES = {
      viridis: [   // purple → teal → green → yellow (default)
        [0.00, [13, 11, 26]], [0.18, [40, 22, 90]], [0.40, [38, 70, 150]],
        [0.60, [20, 150, 150]], [0.80, [40, 200, 90]], [1.00, [240, 240, 40]] ],
      bluered: [   // blue → cyan → yellow → red
        [0.00, [10, 12, 30]], [0.25, [30, 80, 200]], [0.50, [20, 200, 210]],
        [0.75, [240, 220, 40]], [1.00, [230, 50, 40]] ],
      greenred: [  // green → yellow → red
        [0.00, [8, 16, 10]], [0.35, [40, 200, 90]], [0.70, [240, 230, 40]],
        [1.00, [230, 50, 40]] ],
      heat: [      // black → red → orange → yellow → white (inferno-ish)
        [0.00, [8, 6, 12]], [0.30, [140, 20, 60]], [0.55, [230, 70, 30]],
        [0.80, [250, 180, 40]], [1.00, [250, 250, 230]] ],
    };
    let palette = "viridis";

    function heatColor(t) {
      // gamma lift: a single whale cluster can sit orders of magnitude above the
      // median band — without this the median bands render near-black
      t = Math.pow(Math.max(0, Math.min(1, t)), 0.55);
      const stops = PALETTES[palette] || PALETTES.viridis;
      for (let i = 1; i < stops.length; i++) {
        if (t <= stops[i][0]) {
          const [t0, c0] = stops[i-1], [t1, c1] = stops[i];
          const f = (t - t0) / (t1 - t0 || 1);
          return `rgb(${Math.round(c0[0]+(c1[0]-c0[0])*f)},${Math.round(c0[1]+(c1[1]-c0[1])*f)},${Math.round(c0[2]+(c1[2]-c0[2])*f)})`;
        }
      }
      const last = stops[stops.length-1][1];
      return `rgb(${last[0]},${last[1]},${last[2]})`;
    }

    function buildCoinTabs() {
      const el = $("lm-coins");
      el.innerHTML = COINS.map((c) =>
        `<button data-coin="${c}" role="tab" class="${c===coin?'active':''}">${c}</button>`).join("");
      el.querySelectorAll("button").forEach((b) =>
        b.addEventListener("click", () => { coin = b.dataset.coin; syncTabs(); load(); }));
    }
    function bindVenue() {
      document.querySelectorAll("#lm-venue button").forEach((b) =>
        b.addEventListener("click", () => {
          venue = b.dataset.venue;
          days = VENUE_DEFAULT_DAYS[venue] ?? days;          // snap range to venue default
          threshold = VENUE_DEFAULT_THR[venue] ?? threshold; // snap threshold too
          const inp = $("lm-thresh-input"), val = $("lm-thresh-val");
          if (inp) inp.value = threshold;
          if (val) val.textContent = threshold.toFixed(2);
          syncTabs(); load();
        }));
    }
    function bindRange() {
      document.querySelectorAll("#lm-range button").forEach((b) =>
        b.addEventListener("click", () => { days = +b.dataset.days; syncTabs(); load(); }));
    }
    function bindZoom() {
      // price-axis zoom: view-only, no refetch — just re-render lastData.
      document.querySelectorAll("#lm-zoom button").forEach((b) =>
        b.addEventListener("click", () => {
          FOCUS_PCT = b.dataset.zoom === "auto" ? "auto" : +b.dataset.zoom;
          syncTabs();
          if (lastData) render(lastData);
        }));
    }
    function bindOverlays() {
      document.querySelectorAll("#lm-overlays button").forEach((b) =>
        b.addEventListener("click", () => {
          OV[b.dataset.ov] = !OV[b.dataset.ov];
          b.classList.toggle("active", OV[b.dataset.ov]);
          if (lastData) render(lastData);
        }));
    }
    function syncTabs() {
      document.querySelectorAll("#lm-coins button").forEach((b) =>
        b.classList.toggle("active", b.dataset.coin === coin));
      document.querySelectorAll("#lm-venue button").forEach((b) =>
        b.classList.toggle("active", b.dataset.venue === venue));
      document.querySelectorAll("#lm-range button").forEach((b) =>
        b.classList.toggle("active", +b.dataset.days === days));
      document.querySelectorAll("#lm-zoom button").forEach((b) =>
        b.classList.toggle("active",
          FOCUS_PCT === "auto" ? b.dataset.zoom === "auto" : +b.dataset.zoom === FOCUS_PCT));
      // zoom is DEX-only (CEX uses full range); hide it for CEX
      const zoomEl = $("lm-zoom");
      if (zoomEl) zoomEl.style.display = "";   // both venues are price-focused
      // range applies to BOTH now — CEX server-side (?days=), DEX client-side slice.
    }
    function banner(state, text) {
      const b = $("lm-banner");
      b.className = "proof-banner " + state;
      b.querySelector(".banner-text").textContent = text;
    }

    function render(d) {
      lastData = d;
      const grid = d.grid || [], cols = d.cols || 0, rows = d.rows || 0;
      const canvas = $("lm-canvas"), wrap = $("lm-wrap");

      if (!cols || !rows || !grid.length) {
        banner("proof-loading", d.note || "heatmap building — more data accruing");
        const ctx = canvas.getContext("2d");
        const W0 = Math.max(360, Math.floor(wrap.clientWidth || 900));
        canvas.width = W0; canvas.height = 200; canvas.style.width = "100%"; canvas.style.height = "auto";
        ctx.fillStyle = "#0d0b1a"; ctx.fillRect(0,0,W0,200);
        ctx.fillStyle = "#6b7280"; ctx.font = "14px system-ui";
        ctx.fillText(venue === "dex" ? "Real on-chain heatmap is building — fills over days."
                                     : "Modeled estimate builds as price history accrues.", 24, 100);
        $("lm-meta").textContent = ""; $("lm-disclaimer").textContent = d.disclaimer || "";
        return;
      }

      // PERCENTILE threshold + log color ramp. The old scheme mapped the slider
      // onto the log-intensity RANGE — one whale cluster several times bigger
      // than everything else pushed every other band under the floor and the
      // chart looked empty. Rank-based cutoff is robust to that outlier: the
      // slider hides the weakest X% of nonzero cells, color spreads over the
      // log range that remains.
      const nzVals = [];
      const rowMass = new Array(rows).fill(0);
      for (let ri = 0; ri < rows; ri++) for (const v of grid[ri]) {
        if (v > 0) { nzVals.push(v); rowMass[ri] += v; }
      }
      nzVals.sort((a, b) => a - b);
      const maxV = nzVals.length ? nzVals[nzVals.length - 1] : 1;
      const cut = nzVals.length ? nzVals[Math.min(nzVals.length - 1, Math.floor(threshold * nzVals.length))] : 0;
      const lCut = Math.log(cut || 1e-9), lMax = Math.log(maxV), den = (lMax - lCut) || 1;
      const norm = (v) => {
        if (v <= 0 || v < cut) return -1;           // -1 = don't draw
        return Math.max(0, Math.min(1, (Math.log(v) - lCut) / den));
      };

      // geometry: fit container width, no scroll
      const padL = 70, padB = 26, padT = 10, padR = 10;
      const W = Math.max(360, Math.floor(wrap.clientWidth || 1000));
      const plotW = W - padL - padR;
      const plotH = Math.max(320, Math.min(620, rows * 7));
      const H = padT + plotH + padB;
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      canvas.width = W * dpr; canvas.height = H * dpr;
      canvas.style.width = "100%"; canvas.style.height = "auto";
      const ctx = canvas.getContext("2d");
      ctx.setTransform(dpr,0,0,dpr,0,0);
      ctx.fillStyle = "#0d0b1a"; ctx.fillRect(0,0,W,H);

      const cellW = plotW / cols, cellH = plotH / rows;
      // stash geometry (CSS px) so the hover handler can map cursor → cell
      lastGeom = { padL, padT, plotW, plotH, cellW, cellH, rows, cols, W, H, dpr };
      // (vMin/vMax/vSpan added to lastGeom just below, once the focus window is computed)
      // FOCUS the y-axis on a band around current price. The full liq range
      // (price_min..price_max) can be ±40% wide, which buries price + the dense
      // near-price liquidity in a thin sliver (most of the chart is empty). Like
      // Coinglass, we default the view to current price ± FOCUS_PCT so the
      // relevant zone fills the chart; the "zoom" buttons widen it.
      const rowPrices = d.prices || [];
      const cands = d.candles || [];
      const curPrice = (cands.length ? cands[cands.length - 1].c
        : (rowPrices.length ? rowPrices[Math.floor(rowPrices.length / 2)] : (d.price_min + d.price_max) / 2));
      const gridSpan = (d.price_max - d.price_min) || 1;   // grid bin geometry
      // View range = liq range WIDENED to include spot + nearby option walls,
      // so overlays never fall off a chart whose buckets sit far from price.
      let rangeMin = d.price_min, rangeMax = d.price_max;
      const widen = (p) => { if (p > 0) { rangeMin = Math.min(rangeMin, p); rangeMax = Math.max(rangeMax, p); } };
      widen(curPrice);
      if (OV.walls && d.walls && curPrice) {
        for (const w of [...(d.walls.call_walls || []).slice(0, 3), ...(d.walls.put_walls || []).slice(0, 3)])
          if (Math.abs(w.strike - curPrice) <= curPrice * 0.2) widen(w.strike);
        if (d.walls.max_pain && Math.abs(d.walls.max_pain - curPrice) <= curPrice * 0.2)
          widen(d.walls.max_pain);
      }
      const fullSpan = (rangeMax - rangeMin) || 1;
      // auto zoom: smallest preset band around current price that still holds
      // most (55%) of the total liquidity mass — so sparse far-out whale
      // clusters don't force the whole chart into a huge empty range, and a
      // genuinely wide book still shows wide.
      let effPct = FOCUS_PCT;
      if (effPct === "auto") {
        const total = nzVals.reduce((a, b) => a + b, 0) || 1;
        effPct = 1;
        for (const pct of [0.03, 0.06, 0.12, 0.25]) {
          let inMass = 0;
          for (let ri = 0; ri < rows; ri++) {
            const rp = rowPrices[ri];
            if (rp != null && Math.abs(rp - curPrice) <= curPrice * pct) inMass += rowMass[ri];
          }
          if (inMass >= 0.55 * total) { effPct = pct; break; }
        }
      }
      // Focus the y-axis ONLY for DEX (its liq range is very wide → price buried
      // in a sliver). CEX is already server-windowed sensibly, so it uses the
      // FULL range untouched. zoom=full also means full range.
      const focusOn = (effPct < 1);   // both venues are current-price-centered
      const halfBand = focusOn ? Math.min(curPrice * effPct, fullSpan / 2 + 1) : fullSpan / 2;
      const center = focusOn ? curPrice : (rangeMin + rangeMax) / 2;
      let vMin = center - halfBand, vMax = center + halfBand;
      // clamp the window into the available (widened) range
      if (vMin < rangeMin) { vMax += (rangeMin - vMin); vMin = rangeMin; }
      if (vMax > rangeMax) { vMin -= (vMax - rangeMax); vMax = rangeMax; }
      vMin = Math.max(rangeMin, vMin); vMax = Math.min(rangeMax, vMax);
      const vSpan = (vMax - vMin) || 1;
      lastGeom.vMin = vMin; lastGeom.vMax = vMax; lastGeom.vSpan = vSpan;
      const xOfTime = (ts) => {
        const times = d.times || [];
        if (times.length < 2) return padL + plotW/2;
        const f = (ts - times[0]) / (times[times.length-1] - times[0]);
        return padL + Math.max(0, Math.min(1, f)) * plotW;
      };
      // map a price into the FOCUS window; returns null if outside (so we can skip)
      const yOfPrice = (p) => padT + (vMax - p) / vSpan * plotH;
      const inBand = (p) => p >= vMin && p <= vMax;

      // heatmap cells — draw each row at its true price position in the focus
      // window (rows are evenly binned across the FULL range, so we place them by
      // price, not by row index, and skip rows outside the band).
      const rowH = plotH * ( (gridSpan / rows) / vSpan );  // a grid bin's height in the zoomed view
      ctx.save();
      ctx.beginPath(); ctx.rect(padL, padT, plotW, plotH); ctx.clip();
      for (let ri = 0; ri < rows; ri++) {
        const rp = rowPrices[ri];
        if (rp == null || !inBand(rp)) continue;
        const y = yOfPrice(rp) - rowH / 2;
        for (let ci = 0; ci < cols; ci++) {
          const t = norm(grid[ri][ci]);
          if (t >= 0) {
            ctx.fillStyle = heatColor(t);
            ctx.fillRect(padL + ci*cellW, y, Math.ceil(cellW)+0.5, Math.ceil(rowH)+0.5);
          }
        }
      }
      ctx.restore();

      // price candles overlay (OHLC). CoinGecko's /ohlc buckets are NOT continuous
      // (close[i] != open[i+1], ~66$ gaps) — that leaves visible breaks between
      // candles. STITCH them: force each candle's open to the previous candle's
      // close so the price path is continuous (the body still shows its own range,
      // wick shows high/low). Bodies ~0.85 of spacing so they nearly touch.
      let candles = (d.candles || []).filter((k) =>
        k.t >= (d.times[0]||0) && k.t <= (d.times[d.times.length-1]||0));
      if (candles.length) {
        // stitch open→prev close for a continuous chart
        const stitched = candles.map((k, i) => i === 0 ? k
          : { ...k, o: candles[i-1].c });
        const cw = Math.max(1.5, plotW / stitched.length * 0.85);
        // clip to the plot rect so candles outside the focus band don't bleed out
        ctx.save();
        ctx.beginPath(); ctx.rect(padL, padT, plotW, plotH); ctx.clip();
        for (const k of stitched) {
          const x = xOfTime(k.t);
          const up = k.c >= k.o;
          ctx.strokeStyle = up ? "rgba(120,230,160,0.95)" : "rgba(255,120,110,0.95)";
          ctx.fillStyle = ctx.strokeStyle;
          ctx.lineWidth = 1;
          ctx.beginPath(); ctx.moveTo(x, yOfPrice(k.h)); ctx.lineTo(x, yOfPrice(k.l)); ctx.stroke();
          const yo = yOfPrice(k.o), yc = yOfPrice(k.c);
          ctx.fillRect(x - cw/2, Math.min(yo,yc), cw, Math.max(1, Math.abs(yc-yo)));
        }
        ctx.restore();
      }

      // REAL-exchange price line (cyan) — segments break across closed-market
      // gaps so the 24/7 tokenized candles vs session-hours reality read clearly
      if (OV.real && d.real && Array.isArray(d.real.candles) && d.real.candles.length) {
        const ivS = { "5m": 300, "30m": 1800, "1h": 3600, "1d": 86400 }[d.real.interval] || 3600;
        const gapS = ivS * 3;
        const t0 = (d.times[0] || 0), t1 = (d.times[d.times.length - 1] || 0);
        const pts = d.real.candles.filter((k) => k.t >= t0 && k.t <= t1);
        if (pts.length > 1) {
          ctx.save();
          ctx.beginPath(); ctx.rect(padL, padT, plotW, plotH); ctx.clip();
          ctx.strokeStyle = "rgba(90,210,255,0.95)"; ctx.lineWidth = 1.6;
          ctx.beginPath();
          let prevT = null;
          for (const k of pts) {
            const x = xOfTime(k.t), y = yOfPrice(k.c);
            if (prevT === null || k.t - prevT > gapS) { ctx.stroke(); ctx.beginPath(); ctx.moveTo(x, y); }
            else ctx.lineTo(x, y);
            prevT = k.t;
          }
          ctx.stroke();
          ctx.restore();
        }
      }

      // options OI walls (CBOE delayed): top call walls green, put walls red,
      // aggregate max pain yellow — the equity analogue of liq magnets
      if (OV.walls && d.walls && (d.walls.call_walls || []).length + (d.walls.put_walls || []).length) {
        ctx.save();
        ctx.font = "10px system-ui"; ctx.textAlign = "left";
        const wall = (price, color, tag) => {
          if (price < vMin || price > vMax) return;
          const y = yOfPrice(price);
          ctx.setLineDash([3, 4]);
          ctx.strokeStyle = color; ctx.lineWidth = 1;
          ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(padL + plotW, y); ctx.stroke();
          ctx.setLineDash([]);
          ctx.fillStyle = color;
          ctx.fillText(tag, padL + 6, y - 3);
        };
        const fmtOi = (n) => n >= 1e6 ? (n/1e6).toFixed(1)+"M" : n >= 1e3 ? (n/1e3).toFixed(0)+"K" : String(n);
        // big call + put OI often stack on the SAME strike — merge to one line
        // so the labels don't overprint into garbage
        const byStrike = new Map();
        for (const w of (d.walls.call_walls || []).slice(0, 3))
          byStrike.set(w.strike, { c: w.call_oi, p: 0 });
        for (const w of (d.walls.put_walls || []).slice(0, 3)) {
          const e = byStrike.get(w.strike);
          if (e) e.p = w.put_oi; else byStrike.set(w.strike, { c: 0, p: w.put_oi });
        }
        for (const [strike, e] of byStrike) {
          const both = e.c > 0 && e.p > 0;
          const color = both ? "rgba(240,200,140,0.8)"
            : e.c > 0 ? "rgba(120,235,140,0.75)" : "rgba(255,120,110,0.75)";
          const tag = both
            ? `WALL ${fmtPx(strike)} · C ${fmtOi(e.c)} / P ${fmtOi(e.p)} OI`
            : e.c > 0 ? `CALL WALL ${fmtPx(strike)} · ${fmtOi(e.c)} OI`
                      : `PUT WALL ${fmtPx(strike)} · ${fmtOi(e.p)} OI`;
          wall(strike, color, tag);
        }
        if (d.walls.max_pain)
          wall(d.walls.max_pain, "rgba(250,220,80,0.85)", `MAX PAIN ${fmtPx(d.walls.max_pain)}`);
        ctx.restore();
      }

      // last-price marker: dashed line + right-edge price chip
      if (curPrice >= vMin && curPrice <= vMax) {
        const py = yOfPrice(curPrice);
        ctx.save();
        ctx.setLineDash([5, 4]);
        ctx.strokeStyle = "rgba(255,255,255,0.55)"; ctx.lineWidth = 1;
        ctx.beginPath(); ctx.moveTo(padL, py); ctx.lineTo(padL + plotW, py); ctx.stroke();
        ctx.setLineDash([]);
        const label = fmtPx(curPrice);
        ctx.font = "bold 11px system-ui";
        const tw = ctx.measureText(label).width;
        ctx.fillStyle = "rgba(255,255,255,0.92)";
        ctx.fillRect(padL + plotW - tw - 12, py - 9, tw + 10, 18);
        ctx.fillStyle = "#0d0b1a"; ctx.textAlign = "left";
        ctx.fillText(label, padL + plotW - tw - 7, py + 4);
        ctx.restore();
      }

      // price axis (Y) — ticks stepped evenly across the FOCUS window (vMin..vMax)
      ctx.fillStyle = "#8b909c"; ctx.font = "11px system-ui"; ctx.textAlign = "right";
      const yticks = 7;
      for (let k = 0; k <= yticks; k++) {
        const price = vMax - vSpan * k / yticks;
        const py = padT + (k / yticks) * plotH;
        ctx.fillStyle = "rgba(35,38,47,0.6)"; ctx.fillRect(padL, py, plotW, 0.5);
        ctx.fillStyle = "#8b909c"; ctx.fillText(fmtPx(price), padL-6, py+3);
      }

      // time axis (X) — format by SPAN: short (hours) → HH:MM, longer → M/D.
      // (DEX live spans minutes/hours so date-only made every tick read the same day.)
      ctx.fillStyle = "#8b909c"; ctx.font = "11px system-ui"; ctx.textAlign = "center";
      const times = d.times || [];
      const totalSpanS = times.length > 1 ? (times[times.length-1] - times[0]) : 0;
      const pad2 = (n) => String(n).padStart(2, "0");
      const fmtT = (ts) => {
        const dt = new Date(ts*1000);
        if (totalSpanS < 36*3600)          // < ~1.5 days → time of day
          return pad2(dt.getHours()) + ":" + pad2(dt.getMinutes());
        if (totalSpanS < 5*86400)          // < 5 days → M/D HH:MM
          return (dt.getMonth()+1) + "/" + dt.getDate() + " " + pad2(dt.getHours()) + ":" + pad2(dt.getMinutes());
        return (dt.getMonth()+1) + "/" + dt.getDate();
      };
      const xticks = Math.min(8, cols);
      for (let k = 0; k <= xticks; k++) {
        const ci = Math.round((cols-1) * k / xticks);
        if (times[ci] != null) ctx.fillText(fmtT(times[ci]), padL + ci*cellW + cellW/2, H-8);
      }

      const spanS = times.length>1 ? (times[times.length-1]-times[0]) : 0;
      const spanTxt = spanS >= 2*86400 ? `${Math.round(spanS/86400)}d` : `${Math.max(1, Math.round(spanS/3600))}h`;
      const src = venue === "est"
        ? `${spanTxt} · modeled from $${(d.oi_usd/1e6).toFixed(0)}M open interest · leverage-tier estimate`
        : `${spanTxt} window · ${cols} snapshots · real on-chain positions (Hyperliquid HIP-3)`;
      const ovBits = [];
      if (OV.real && d.real && (d.real.candles || []).length)
        ovBits.push(`<span style="color:rgba(90,210,255,0.95)">— real exchange price</span> (delayed)`);
      if (OV.walls && d.walls && ((d.walls.call_walls || []).length + (d.walls.put_walls || []).length))
        ovBits.push(`<span style="color:rgba(120,235,140,0.9)">-- call</span>/<span style="color:rgba(255,120,110,0.9)">put walls</span> + <span style="color:rgba(250,220,80,0.95)">max pain</span> (CBOE OI, delayed)`);
      // venue-unit symbols: the tokenized contract trades at its own scale, so
      // real-index overlays (^IXIC price, NDX strikes) sit far outside the
      // chart and are auto-skipped — say so instead of looking broken
      if (UNIT_NOTE[coin]) ovBits.push(`<span style="color:#9aa0ad">${UNIT_NOTE[coin]}</span>`);
      $("lm-meta").innerHTML =
        `<strong>${coin}</strong> · ${src} · price ${fmtPx(d.price_min)}–${fmtPx(d.price_max)}` +
        (ovBits.length ? `<br/>${ovBits.join(" · ")}` : "");
      $("lm-disclaimer").textContent = d.disclaimer || "";
      banner("proof-ok", venue === "est" ? "live · modeled estimate" : "live · real");
    }

    // Candle overlay from Hyperliquid's own candleSnapshot — the ONLY source
    // with tokenized-stock prices (Binance/CoinGecko have none). HL's public
    // info API allows browser CORS; interval picked so the span stays under
    // ~700 candles.
    const KLINE_STEPS = [
      ["5m", 300], ["15m", 900], ["1h", 3600], ["4h", 14400], ["1d", 86400],
    ];
    async function fetchCandles(coin, data) {
      const times = data.times || [];
      const market = HL_MARKET[coin];
      if (times.length < 2 || !market) return [];
      const t0 = times[0], t1 = times[times.length - 1], span = t1 - t0;
      let interval = "1d";
      for (const [iv, secs] of KLINE_STEPS) {
        if (span / secs <= 700) { interval = iv; break; }
      }
      const key = coin + ":hl:" + interval + ":" + Math.round(t0 / 3600);
      if (candleCache[key]) return candleCache[key];
      try {
        const r = await fetch("https://api.hyperliquid.xyz/info", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          signal: AbortSignal.timeout(15000),
          body: JSON.stringify({ type: "candleSnapshot", req: {
            coin: market, interval, startTime: t0 * 1000, endTime: t1 * 1000 } }),
        });
        if (!r.ok) return [];
        const raw = await r.json();
        if (!Array.isArray(raw) || !raw.length) return [];
        const out = raw.map((k) => ({ t: Math.floor(k.t / 1000), o: +k.o, h: +k.h, l: +k.l, c: +k.c }));
        candleCache[key] = out;
        return out;
      } catch (e) { return []; }
    }

    // REAL-exchange session candles (Yahoo delayed, proxied — Yahoo blocks
    // browser CORS). Overlaid against the 24/7 tokenized price: the gaps are
    // closed-market hours, the divergence in those gaps is the story.
    async function fetchReal(coin, days) {
      const key = coin + ":" + days + ":" + Math.floor(Date.now() / 3.6e6);
      if (realCache[key]) return realCache[key];
      try {
        const r = await fetch(`${API}/charts/stock-candles/${encodeURIComponent(coin)}?days=${days}`,
          { cache: "no-store", signal: AbortSignal.timeout(20000) });
        if (!r.ok) return null;
        const d = await r.json();
        realCache[key] = d;
        return d;
      } catch (e) { return null; }
    }

    // Listed-options OI walls (CBOE delayed, proxied). Not every symbol has
    // listed options (metals/commodities 404) — null just skips the overlay.
    async function fetchWalls(coin) {
      const key = coin + ":" + Math.floor(Date.now() / 1.8e6);
      if (wallsCache[key]) return wallsCache[key];
      try {
        const r = await fetch(`${API}/charts/options-walls/${encodeURIComponent(coin)}`,
          { cache: "no-store", signal: AbortSignal.timeout(25000) });
        if (!r.ok) return null;
        const d = await r.json();
        wallsCache[key] = d;
        return d;
      } catch (e) { return null; }
    }

    async function load() {
      const my = ++reqId;
      let v = venue;
      banner("proof-loading", "loading " + coin + " " + v.toUpperCase() + " heatmap…");
      // range window is applied SERVER-SIDE (?days=); the server downsamples long
      // windows to <= cols columns so "max" stays one payload. est = modeled
      // density from OI; dex = real on-chain positions only.
      const path = v === "est" ? "/charts/hip3-estimate-heatmap/" : "/charts/liqmap-heatmap/dex/";
      const qs = v === "est" ? ("?days=" + days) : ("?days=" + days + "&cols=400");
      try {
        const r = await fetch(API + path + encodeURIComponent(coin) + qs,
          { cache: "no-store", signal: AbortSignal.timeout(45000) });
        if (my !== reqId) return;
        if (!r.ok) { banner("proof-error", "error " + r.status + (lastData ? " — showing previous data" : "")); return; }
        let data = await r.json();
        if (my !== reqId) return;
        // overlays fetched in parallel; each degrades to null independently
        const [hl, real, walls] = await Promise.all([
          fetchCandles(coin, data), fetchReal(coin, days), fetchWalls(coin),
        ]);
        if (my !== reqId) return;
        data.candles = hl;
        data.real = real;
        data.walls = walls;
        render(data);
      } catch (e) {
        if (my !== reqId) return;
        // keep the previous chart on screen — a timed-out refresh must not
        // strand the user on a blank canvas or an eternal "loading…"
        banner("proof-error", "fetch failed" + (lastData ? " — showing previous data, retrying…" : " — retrying…"));
      }
    }

    function bindThreshold() {
      const inp = $("lm-thresh-input"), val = $("lm-thresh-val");
      if (!inp) return;
      inp.value = threshold;                        // sync slider to the 0.85 default
      val.textContent = threshold.toFixed(2);
      inp.addEventListener("input", () => {
        threshold = +inp.value;
        val.textContent = threshold.toFixed(2);
        if (lastData) render(lastData);            // instant re-render, no refetch
      });
    }

    function bindPalette() {
      document.querySelectorAll("#lm-palette button").forEach((b) =>
        b.addEventListener("click", () => {
          palette = b.dataset.pal;
          document.querySelectorAll("#lm-palette button").forEach((x) =>
            x.classList.toggle("active", x.dataset.pal === palette));
          if (lastData) render(lastData);          // instant recolor, no refetch
        }));
    }

    function bindHover() {
      const canvas = $("lm-canvas"), tip = $("lm-tip"), wrap = $("lm-wrap");
      if (!canvas) return;

      const hide = () => { tip.style.display = "none"; };
      const showAt = (clientX, clientY) => {
        if (!lastGeom || !lastData) { hide(); return; }
        const g = lastGeom, d = lastData;
        const rect = canvas.getBoundingClientRect();
        if (!rect.width) { hide(); return; }
        // buffer is W×H (CSS-px units, since we draw under setTransform(dpr)); the
        // element is scaled to rect → map cursor back into draw-space coords.
        const sx = g.W / rect.width, sy = g.H / rect.height;
        const x = (clientX - rect.left) * sx, y = (clientY - rect.top) * sy;
        // only react inside the plot area
        if (x < g.padL || x > g.padL + g.plotW || y < g.padT || y > g.padT + g.plotH) { hide(); return; }
        let ci = Math.floor((x - g.padL) / g.cellW);
        ci = Math.max(0, Math.min(g.cols - 1, ci));
        // cursor-y → price via the focus window, then nearest grid row BY PRICE
        // (rows are drawn at their price position now, not by uniform cellH).
        const cursorPrice = (g.vMax != null)
          ? g.vMax - ((y - g.padT) / g.plotH) * g.vSpan
          : null;
        let ri = 0;
        if (cursorPrice != null && (d.prices || []).length) {
          let bestD = 1e9;
          for (let r = 0; r < g.rows; r++) {
            const rp = d.prices[r];
            if (rp == null) continue;
            const dd = Math.abs(rp - cursorPrice);
            if (dd < bestD) { bestD = dd; ri = r; }
          }
        } else {
          ri = Math.max(0, Math.min(g.rows - 1, Math.floor((y - g.padT) / g.cellH)));
        }
        let usd = (d.grid[ri] || [])[ci] || 0;
        // empty cell → snap to the nearest band in this column so the popup always
        // gives feedback (find the closest row with liquidity)
        let showRi = ri;
        if (usd <= 0) {
          let bestD = 1e9;
          for (let r = 0; r < g.rows; r++) {
            const v = (d.grid[r] || [])[ci] || 0;
            if (v > 0 && Math.abs(r - ri) < bestD) { bestD = Math.abs(r - ri); showRi = r; usd = v; }
          }
        }
        const price = (d.prices || [])[showRi];
        const ts = (d.times || [])[ci];
        const when = ts ? new Date(ts*1000) : null;
        const whenStr = when ? (when.getMonth()+1)+"/"+when.getDate()+" "+
          String(when.getHours()).padStart(2,"0")+":"+String(when.getMinutes()).padStart(2,"0") : "";
        tip.innerHTML =
          (whenStr ? `<div><span class="lm-tip-k">${whenStr}</span></div>` : "") +
          `<div><span class="lm-tip-k">price</span> <b>${fmtPx(price)}</b></div>` +
          (usd > 0 ? `<div><span class="lm-tip-k">liquidation</span> <b>${fmtUsd(usd)}</b></div>`
                   : `<div><span class="lm-tip-k">liquidation</span> <b>—</b></div>`);
        tip.style.display = "block";
        const wrect = wrap.getBoundingClientRect();
        let tx = clientX - wrect.left + 14, ty = clientY - wrect.top + 14;
        const tw = tip.offsetWidth, th = tip.offsetHeight;
        if (tx + tw > wrap.clientWidth) tx = clientX - wrect.left - tw - 14;
        if (ty + th > wrap.clientHeight) ty = clientY - wrect.top - th - 14;
        tip.style.left = Math.max(0, tx) + "px";
        tip.style.top = Math.max(0, ty) + "px";
      };

      canvas.addEventListener("mousemove", (e) => showAt(e.clientX, e.clientY));
      canvas.addEventListener("mouseleave", hide);
      // touch: finger acts like hover; preventDefault stops the chart being
      // selected/scrolled (the "copy" selection behaviour on phones).
      const onTouch = (e) => {
        if (!e.touches || !e.touches.length) return;
        e.preventDefault();
        showAt(e.touches[0].clientX, e.touches[0].clientY);
      };
      canvas.addEventListener("touchstart", onTouch, { passive: false });
      canvas.addEventListener("touchmove", onTouch, { passive: false });
      canvas.addEventListener("touchend", hide);
    }

    function start() {
      buildCoinTabs(); bindVenue(); bindRange(); bindZoom(); bindOverlays(); bindThreshold(); bindPalette(); bindHover(); syncTabs(); load();
      timer = setInterval(load, REFRESH_MS);
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) { clearInterval(timer); timer = null; }
        else if (!timer) { load(); timer = setInterval(load, REFRESH_MS); }
      });
      window.addEventListener("resize", () => {
        clearTimeout(resizeT);
        resizeT = setTimeout(() => { if (lastData) render(lastData); }, 150);
      });
    }
    if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", start);
    else start();
  })();
  </script>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="pricing"
  description="n0brains pricing — start free, upgrade to Pro ($39.99/mo) for real-time signals, full source detail, WebSocket, Webhooks, and the MCP server. No credit card to start."
>
  <section class="pricing-page">
    <!-- Hero -->
    <div class="pp-hero">
      <div class="pp-hero-grid" aria-hidden="true"></div>
      <p class="pp-kicker"><span class="pp-dot"></span><span data-scramble>pricing · no credit card to start</span></p>
      <h1 class="pp-h1">TWO TIERS.<br /><span class="accent">NO UPSELLS.</span></h1>
      <p class="pp-lede">
        Start free — no credit card. Pro unlocks real-time delivery, full signal
        detail, and the complete intelligence stack. The record behind every
        tier is <a href="/proof">public</a>.
      </p>
      <div class="pp-toggle" role="group" aria-label="Tier selector">
        <button id="tab-free" aria-pressed="false">free · $0</button>
        <button id="tab-pro" class="on" aria-pressed="true">pro · $39.99</button>
      </div>
    </div>

    <!-- Panels -->
    <div class="pp-panels">
      <!-- Live delayed feed (free-tier view — never changes with the toggle) -->
      <div class="pp-feed">
        <div class="pp-feed-head">
          <span class="pp-feed-title"><span class="pp-dot pp-dot-sm"></span>signal feed — free tier</span>
          <span class="pp-feed-delay">delayed · T+15:00</span>
        </div>
        <div class="pp-feed-rows" id="pp-feed-rows">
          <div class="pp-feed-loading">connecting to delayed feed…</div>
        </div>
        <div class="pp-feed-foot">free-tier feed · pro receives signals the moment they clear the gate</div>
      </div>

      <!-- Tier spec (reacts to toggle) -->
      <div class="pp-spec" id="pp-spec">
        <div class="pp-spec-label">tier spec — <span id="sp-label">pro tier</span></div>
        <div class="pp-bar-block">
          <div class="pp-bar-head"><span>rate limit</span><span id="sp-rate" class="white">600 req/min</span></div>
          <div class="pp-bar"><div class="pp-bar-fill" id="sp-rate-bar" style="width:100%"></div></div>
        </div>
        <div class="pp-bar-block">
          <div class="pp-bar-head"><span>latency</span><span id="sp-lat">T+0 · real-time</span></div>
          <div class="pp-bar"><div class="pp-bar-fill" id="sp-lat-bar" style="width:100%"></div></div>
        </div>
        <div class="pp-deliv-label">delivery</div>
        <div class="pp-deliv">
          <span class="chip chip-on">REST</span>
          <span class="chip chip-on">CLI</span>
          <span class="chip pro-chip" data-pro>WS</span>
          <span class="chip pro-chip" data-pro>WEBHOOK</span>
          <span class="chip pro-chip" data-pro>MCP</span>
          <span class="chip pro-chip" data-pro>x402</span>
        </div>
        <div class="pp-spec-row"><span>signal detail</span><span id="sp-detail" class="white">full source + channel</span></div>
        <div class="pp-spec-row"><span>intelligence layers</span><span id="sp-layers" class="white">all 10 layers</span></div>
        <div class="pp-spec-row"><span>support</span><span id="sp-support" class="white">email</span></div>
        <div class="pp-price-block">
          <div class="pp-price"><span id="sp-price">$39.99</span><span class="pp-per">/mo</span></div>
          <a href="/signup?redirect=checkout&tier=pro" class="pp-cta pp-cta-solid" id="sp-cta">start pro →</a>
        </div>
      </div>
    </div>

    <!-- x402 strip -->
    <div class="pp-strip">
      <span class="pp-pill">x402</span>
      <span>Pay-per-call beyond your tier — one-time packs from $5. No subscription change needed.</span>
    </div>

    <!-- CLI strip -->
    <div class="pp-strip">
      <span class="pp-pill">CLI</span>
      <span>Every endpoint as a command — JSON on stdout, zero dependencies. No protocol envelope, so it's leaner than MCP for bots and shell pipelines.</span>
      <code class="pp-strip-code">$ pip install n0brains-cli</code>
    </div>

    <!-- Methodology / legal -->
    <p class="pp-legal">
      Every signal is analytical data — not financial advice. We measure our own
      track record on real prices and publish it at
      <a href="/proof">/proof</a>, flagging a call
      <span class="pp-ts">trade_signal</span> only when that (type, direction)
      pair's live forward-return record beats BTC, is profitable, and the
      expected move clears round-trip trading cost. Questions:
      <a href="mailto:support@n0brains.com">support@n0brains.com</a>.
    </p>
  </section>

  <!-- Mobile sticky CTA bar -->
  <div class="pp-sticky" id="pp-sticky">
    <a href="/signup" class="pp-cta pp-cta-ghost">free</a>
    <a href="/signup?redirect=checkout&tier=pro" class="pp-cta pp-cta-solid">start pro →</a>
  </div>

  <style>
    .pricing-page { max-width: 1100px; margin: 0 auto; }

    /* ── Hero ── */
    .pp-hero { position: relative; text-align: center; padding: 1.5rem 0 0; }
    .pp-hero-grid {
      position: absolute; inset: -40px -10% 0; pointer-events: none;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 54px 54px;
      -webkit-mask-image: radial-gradient(ellipse 55% 65% at 50% 20%, #000 0%, transparent 75%);
      mask-image: radial-gradient(ellipse 55% 65% at 50% 20%, #000 0%, transparent 75%);
      opacity: 0.5;
    }
    .pp-kicker {
      position: relative;
      font-family: var(--font-mono); font-size: 0.69rem;
      letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent);
      margin-bottom: 18px;
    }
    .pp-dot {
      display: inline-block; width: 7px; height: 7px; border-radius: 50%;
      background: var(--accent); margin-right: 9px;
      animation: ppPulse 2s infinite;
    }
    .pp-dot-sm { width: 6px; height: 6px; margin-right: 8px; }
    @keyframes ppPulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
    .pp-h1 {
      position: relative; margin: 0;
      font-family: var(--font-display);
      font-size: clamp(3.2rem, 8vw, 6rem);
      font-weight: 400; line-height: 0.9; letter-spacing: 0.02em;
      color: var(--text-heading);
    }
    .pp-h1 .accent { color: var(--accent); text-shadow: 0 0 40px var(--accent-glow-strong); }
    .pp-lede {
      position: relative;
      font-size: 1rem; line-height: 1.6; color: var(--text);
      max-width: 560px; margin: 24px auto 0;
    }
    .pp-lede a { color: var(--accent); }

    .pp-toggle {
      position: relative;
      display: inline-flex; margin-top: 30px;
      border: 1px solid #2a2a2a; border-radius: 5px; overflow: hidden;
    }
    .pp-toggle button {
      font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700;
      letter-spacing: 0.1em; text-transform: uppercase;
      padding: 12px 26px; border: none; cursor: pointer;
      background: transparent; color: var(--text-muted);
      transition: all 0.25s ease;
    }
    .pp-toggle button.on { background: var(--accent); color: #000; }

    /* ── Panels ── */
    .pp-panels {
      display: grid; grid-template-columns: 1.35fr 1fr; gap: 18px;
      align-items: stretch; margin-top: 40px;
    }
    @media (max-width: 860px) {
      .pp-panels { grid-template-columns: 1fr; }
      /* spec panel first on mobile (design order) */
      .pp-spec { order: -1; }
    }

    /* Feed panel */
    .pp-feed {
      background: var(--bg-code); border: 1px solid var(--border);
      border-radius: var(--radius); overflow: hidden;
      display: flex; flex-direction: column;
    }
    .pp-feed-head {
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 18px; border-bottom: 1px solid var(--border);
    }
    .pp-feed-title {
      font-family: var(--font-mono); font-size: 0.63rem;
      letter-spacing: 0.22em; text-transform: uppercase; color: var(--text-muted);
    }
    .pp-feed-delay { font-family: var(--font-mono); font-size: 0.63rem; letter-spacing: 0.12em; color: var(--text-muted); }
    .pp-feed-rows { padding: 10px 18px 16px; display: flex; flex-direction: column; gap: 0; flex: 1; min-height: 296px; }
    .pp-feed-loading { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text-faint); padding: 12px 0; }
    :global(.pp-row) {
      display: flex; align-items: center; gap: 12px;
      font-family: var(--font-mono); font-size: 0.72rem;
      padding: 7px 0; border-bottom: 1px solid #111;
    }
    :global(.pp-row.new) { animation: ppRowIn 0.4s var(--ease-out) both; }
    @keyframes ppRowIn { from { opacity: 0; transform: translateY(10px); } }
    :global(.pp-row .t) { color: #4a4a4a; flex-shrink: 0; }
    :global(.pp-row .ty) {
      color: var(--accent-dim); border: 1px solid var(--border-accent);
      border-radius: 3px; padding: 1px 7px; font-size: 0.59rem;
      letter-spacing: 0.08em; flex-shrink: 0;
    }
    :global(.pp-row .as) { color: var(--text-heading); font-weight: 700; flex-shrink: 0; }
    :global(.pp-row .dir-b) { color: #4ade80; flex-shrink: 0; }
    :global(.pp-row .dir-s) { color: #ef4444; flex-shrink: 0; }
    :global(.pp-row .dir-n) { color: var(--text-muted); flex-shrink: 0; }
    :global(.pp-row .sm) {
      color: var(--text-muted); white-space: nowrap; overflow: hidden;
      text-overflow: ellipsis; font-family: var(--font-body); font-size: 0.78rem;
    }
    :global(.pp-row .em) {
      margin-left: auto; color: var(--text-muted); border: 1px solid #2a2a2a;
      border-radius: 3px; padding: 1px 7px; font-size: 0.56rem;
      letter-spacing: 0.1em; flex-shrink: 0;
    }
    .pp-feed-foot {
      padding: 10px 18px; border-top: 1px solid var(--border);
      font-family: var(--font-mono); font-size: 0.59rem;
      letter-spacing: 0.12em; color: #3f3f3f;
    }
    @media (max-width: 860px) {
      .pp-feed-rows { min-height: 0; }
      :global(.pp-row .sm), :global(.pp-row .em) { display: none; }
    }

    /* Spec panel */
    .pp-spec {
      background: var(--bg-card); border: 1px solid rgba(0,255,65,0.35);
      border-radius: var(--radius); padding: 26px 26px 24px;
      display: flex; flex-direction: column;
      transition: border-color 0.4s ease, box-shadow 0.4s ease;
      box-shadow: 0 0 52px -18px rgba(0,255,65,0.3);
    }
    .pp-spec.free { border-color: #2a2a2a; box-shadow: none; }
    .pp-spec-label {
      font-family: var(--font-mono); font-size: 0.63rem;
      letter-spacing: 0.25em; text-transform: uppercase; color: var(--text-muted);
      margin-bottom: 18px;
    }
    .pp-bar-block { margin-bottom: 18px; }
    .pp-bar-head {
      display: flex; justify-content: space-between;
      font-family: var(--font-mono); font-size: 0.66rem; color: var(--text-muted);
      margin-bottom: 7px;
    }
    .pp-bar-head .white, .pp-spec-row .white { color: var(--text-heading); }
    .pp-bar { height: 6px; background: #111; border-radius: 3px; overflow: hidden; }
    .pp-bar-fill {
      height: 100%; border-radius: 3px;
      background: linear-gradient(90deg, var(--accent-dim), var(--accent));
      transition: width 0.7s var(--ease-out), background 0.4s ease;
    }
    .pp-bar-fill.delay { background: linear-gradient(90deg, #80002b, #ff0055); }
    #sp-lat { color: var(--accent); transition: color 0.3s ease; }
    #sp-lat.delay { color: var(--accent-secondary); }
    .pp-deliv-label { font-family: var(--font-mono); font-size: 0.66rem; color: var(--text-muted); margin-bottom: 6px; }
    .pp-deliv { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 18px; }
    .chip {
      font-family: var(--font-mono); font-size: 0.63rem; letter-spacing: 0.08em;
      border-radius: 3px; padding: 4px 9px;
      transition: all 0.35s ease;
    }
    .chip-on { color: var(--accent-dim); border: 1px solid var(--border-accent); }
    .pro-chip { color: var(--accent-dim); border: 1px solid var(--border-accent); }
    .pp-spec.free .pro-chip { color: #3a3a3a; border-color: #1e1e1e; text-decoration: line-through; }
    .pp-spec-row {
      display: flex; justify-content: space-between;
      font-family: var(--font-mono); font-size: 0.66rem; color: var(--text-muted);
      padding: 10px 0; border-top: 1px solid var(--border);
    }
    .pp-price-block { margin-top: auto; padding-top: 18px; }
    .pp-price { display: flex; align-items: baseline; gap: 6px; }
    .pp-price > span:first-child {
      font-family: var(--font-display); font-size: 3.25rem; line-height: 1;
      color: var(--text-heading);
    }
    .pp-per { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-faint); }
    .pp-cta {
      display: block; text-align: center; margin-top: 14px;
      font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700;
      letter-spacing: 0.08em; text-transform: uppercase;
      padding: 13px 0; border-radius: var(--radius-sm);
      transition: all 0.2s ease;
    }
    .pp-cta-solid { color: #000; background: var(--accent); }
    .pp-cta-solid:hover { background: #fff; color: #000; }
    .pp-cta-ghost { color: var(--text); border: 1px solid #2a2a2a; background: transparent; }
    .pp-cta-ghost:hover { border-color: var(--accent); color: var(--accent); }

    /* ── Strips ── */
    .pp-strip {
      display: flex; align-items: center; gap: 14px;
      margin-top: 18px; padding: 14px 20px;
      border: 1px dashed #2a2a2a; border-radius: var(--radius);
      font-size: 0.82rem; color: var(--text);
    }
    .pp-strip + .pp-strip { margin-top: 12px; }
    .pp-pill {
      font-family: var(--font-mono); font-size: 0.63rem; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--accent);
      border: 1px solid var(--border-accent); border-radius: 100px;
      padding: 4px 10px; white-space: nowrap;
    }
    .pp-strip-code {
      margin-left: auto; font-family: var(--font-mono); font-size: 0.72rem;
      color: var(--accent); background: var(--bg-code);
      border: 1px solid var(--border); border-radius: var(--radius-sm);
      padding: 6px 12px; white-space: nowrap;
    }
    @media (max-width: 720px) {
      .pp-strip { flex-wrap: wrap; }
      .pp-strip-code { margin-left: 0; }
    }

    .pp-ts { font-family: var(--font-mono); color: var(--accent-dim); font-size: 0.69rem; }
    .pp-legal {
      margin: 36px auto 0; max-width: 720px; text-align: center;
      font-size: 0.75rem; line-height: 1.7; color: var(--text-muted);
    }
    .pp-legal a { color: var(--text-muted); text-decoration: underline; }

    /* ── Mobile sticky CTA ── */
    .pp-sticky {
      display: none;
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 500;
      gap: 10px; padding: 12px 16px;
      background: rgba(5,5,5,0.92);
      -webkit-backdrop-filter: blur(10px);
      backdrop-filter: blur(10px);
      border-top: 1px solid var(--border);
    }
    .pp-sticky .pp-cta { margin-top: 0; padding: 13px 0; }
    .pp-sticky .pp-cta-ghost { flex: 1; }
    .pp-sticky .pp-cta-solid { flex: 1.6; }
    @media (max-width: 860px) {
      .pp-sticky { display: flex; }
      .pricing-page { padding-bottom: 76px; }
    }
  </style>

  <script>
    (() => {
      const REDUCE = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      /* ── Tier toggle ── */
      const spec = document.getElementById("pp-spec")!;
      const tabFree = document.getElementById("tab-free")!;
      const tabPro = document.getElementById("tab-pro")!;
      const $ = (id: string) => document.getElementById(id)!;
      const setTier = (tier: "free" | "pro") => {
        const free = tier === "free";
        tabFree.classList.toggle("on", free);
        tabPro.classList.toggle("on", !free);
        tabFree.setAttribute("aria-pressed", String(free));
        tabPro.setAttribute("aria-pressed", String(!free));
        spec.classList.toggle("free", free);
        $("sp-label").textContent = free ? "free tier" : "pro tier";
        $("sp-rate").textContent = free ? "60 req/min" : "600 req/min";
        ($("sp-rate-bar") as HTMLElement).style.width = free ? "10%" : "100%";
        $("sp-lat").textContent = free ? "T+15:00 delay" : "T+0 · real-time";
        $("sp-lat").classList.toggle("delay", free);
        ($("sp-lat-bar") as HTMLElement).style.width = free ? "18%" : "100%";
        $("sp-lat-bar").classList.toggle("delay", free);
        $("sp-detail").textContent = free ? "core fields" : "full source + channel";
        $("sp-layers").textContent = free ? "scores only" : "all 10 layers";
        $("sp-support").textContent = free ? "community" : "email";
        $("sp-price").textContent = free ? "$0" : "$39.99";
        const cta = $("sp-cta") as HTMLAnchorElement;
        cta.textContent = free ? "start free" : "start pro →";
        cta.href = free ? "/signup" : "/signup?redirect=checkout&tier=pro";
        cta.className = free ? "pp-cta pp-cta-ghost" : "pp-cta pp-cta-solid";
      };
      tabFree.addEventListener("click", () => setTier("free"));
      tabPro.addEventListener("click", () => setTier("pro"));

      /* ── Live delayed feed (public free-tier teaser endpoint) ── */
      const rows = document.getElementById("pp-feed-rows")!;
      const seen = new Set<string>();
      let firstLoad = true;
      const pad = (n: number) => String(n).padStart(2, "0");
      const rowHtml = (it: any, isNew: boolean) => {
        const d = new Date(it.timestamp * 1000);
        const t = `${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}:${pad(d.getUTCSeconds())}`;
        const dir = it.direction === "bullish" ? ["▲", "dir-b"]
          : it.direction === "bearish" ? ["▼", "dir-s"] : ["•", "dir-n"];
        const esc = (s: string) => s.replace(/&/g, "&amp;").replace(/</g, "&lt;");
        return `<div class="pp-row${isNew && !REDUCE ? " new" : ""}">
          <span class="t">${t}</span>
          <span class="ty">${esc(it.signal_type)}</span>
          <span class="as">${esc(it.asset)}</span>
          <span class="${dir[1]}">${dir[0]}</span>
          <span class="sm">${esc(it.summary)}</span>
          <span class="em">T+15:00</span>
        </div>`;
      };
      const load = async () => {
        try {
          const r = await fetch("https://api.n0brains.com/public/feed?limit=6", { cache: "no-store" });
          const data = await r.json();
          if (!data?.items?.length) throw new Error("empty");
          let html = "";
          for (const it of data.items.slice(0, 6)) {
            const key = `${it.timestamp}|${it.signal_type}|${it.asset}`;
            const isNew = !firstLoad && !seen.has(key);
            seen.add(key);
            html += rowHtml(it, isNew);
          }
          rows.innerHTML = html;
          firstLoad = false;
        } catch {
          if (firstLoad) {
            rows.innerHTML = '<div class="pp-feed-loading">feed unavailable — the live delayed stream is served from api.n0brains.com</div>';
          }
        }
      };
      load();
      setInterval(load, 60_000);
    })();
  </script>
</BaseLayout>

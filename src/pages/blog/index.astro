---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="blog" description="n0brains blog — think less, ship more. Articles about building, AI agents, and crypto." homepage={true}>
  <section class="hero" id="hero">
    <p class="hero-eyebrow">n0brains // build mode</p>
    <h1>
      think<br />
      less.<br />
      <span class="highlight">ship more.</span>
    </h1>
    <p class="hero-desc">
      Building things without overthinking them.
      No grand theories. No analysis paralysis.
    </p>
  </section>

  <section>
    <p class="section-label">// latest posts</p>
    <div class="post-list">
      {
        posts.map((post, i) => (
          <a href={`/blog/${post.id}/`} class="post-card">
            <div class="post-meta">
              <span class="post-index">0{i + 1}</span>
              <span class="date">{post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</span>
            </div>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
            <span class="read-more">read</span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
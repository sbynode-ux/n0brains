---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="proof"
  description="n0brains paper-trading proof — per-signal-type simulated PnL against real Hyperliquid prices, refreshed live. Forward-tested, not advice."
>
  <section class="about-section">
    <h1>proof</h1>
    <p class="legal-updated">
      Every signal type is paper-traded against real exchange prices —
      Hyperliquid mids, with CoinMarketCap / DexScreener fallback for tokens not
      on Hyperliquid — 2% stop, 4% target, 4h max hold, fees and slippage
      applied. Stops and targets resolve against 1-minute candle highs/lows, so
      an intrabar wick through a stop counts as a stop-out. Combines a historical
      backfill with an ongoing live forward-test. Refreshed live.
    </p>

    <div id="proof-banner" class="proof-banner proof-loading">
      <span class="dot"></span>
      <span class="banner-text">loading results…</span>
    </div>

    <div id="proof-table"></div>

    <p class="meta" id="proof-meta"></p>

    <h2 class="tier-heading">Risk-tier performance</h2>
    <p class="tier-blurb">
      The same signals can be run with different stop-loss, take-profit, and
      sizing rules depending on how aggressive you want to be. Below are the
      paper-traded results for three reference tiers — conservative (1),
      balanced (2), and aggressive (3) — over the last 30 days. Source:
      <code>/performance?tier=N</code>. Each tier filters the strategy set
      AND scales SL/TP/size from a base config.
    </p>

    <div id="tier-cards" class="tier-cards">
      <div class="tier-card" data-tier="1">
        <h3>1 · Conservative</h3>
        <div class="tier-body">loading…</div>
      </div>
      <div class="tier-card" data-tier="2">
        <h3>2 · Balanced</h3>
        <div class="tier-body">loading…</div>
      </div>
      <div class="tier-card" data-tier="3">
        <h3>3 · Aggressive</h3>
        <div class="tier-body">loading…</div>
      </div>
    </div>

    <p class="meta" id="tier-meta"></p>

    <p class="legal-updated" style="margin-top: 32px;">
      A type is shown as <strong>paper-tested profitable</strong> only when its
      simulated record clears 30+ trades, a positive average net return, and a
      95% confidence interval above zero. These are the types we flag
      <code>conviction: strong</code> in the API. Simulated results for
      informational purposes only — not financial advice, and past performance
      does not guarantee future results. See <a href="/terms">terms</a>.
    </p>
  </section>
</BaseLayout>

<script>
  const ENDPOINT = "https://api.n0brains.com/proof";

  function pct(v) {
    if (v === null || v === undefined) return "—";
    const n = Number(v) * 100;
    return n.toFixed(1) + "%";
  }
  function pctRaw(v) {
    if (v === null || v === undefined) return "—";
    return (Number(v) >= 0 ? "+" : "") + Number(v).toFixed(2) + "%";
  }
  function usd(v) {
    if (v === null || v === undefined) return "—";
    const n = Number(v);
    return (n >= 0 ? "+$" : "-$") + Math.abs(n).toFixed(2);
  }

  function render(data) {
    const banner = document.getElementById("proof-banner");
    const table  = document.getElementById("proof-table");
    const meta   = document.getElementById("proof-meta");

    if (!data || data.error || !data.types) {
      banner.className = "proof-banner proof-unknown";
      banner.querySelector(".banner-text").textContent =
        "proof unavailable (" + (data?.error || "fetch failed") + ")";
      return;
    }

    const tradeable = data.types.filter((t) => t.tradeable);
    banner.className = "proof-banner proof-up";
    banner.querySelector(".banner-text").textContent =
      tradeable.length + " signal type" + (tradeable.length === 1 ? "" : "s") +
      " paper-tested profitable";

    let rows = "";
    for (const t of data.types) {
      const cls = t.tradeable ? "row-tradeable" : "row-untradeable";
      const flag = t.tradeable
        ? '<span class="badge badge-yes">tradeable</span>'
        : '<span class="badge badge-no">intel only</span>';
      const pnlCls = t.total_pnl_usd >= 0 ? "pos" : "neg";
      rows += `
        <tr class="${cls}">
          <td class="type">${t.signal_type}</td>
          <td>${t.n}</td>
          <td>${pct(t.win_rate)}</td>
          <td class="${t.avg_net_pct >= 0 ? "pos" : "neg"}">${pctRaw(t.avg_net_pct)}</td>
          <td class="${pnlCls}">${usd(t.total_pnl_usd)}</td>
          <td>${flag}</td>
        </tr>`;
    }
    table.innerHTML = `
      <table class="proof-table">
        <thead>
          <tr><th>type</th><th>trades</th><th>win rate</th>
              <th>avg net / trade</th><th>total PnL</th><th></th></tr>
        </thead>
        <tbody>${rows}</tbody>
      </table>`;

    if (data.types[0] && data.types[0].updated_at) {
      const latest = Math.max(...data.types.map((t) => t.updated_at || 0));
      meta.textContent = "Last updated " + new Date(latest * 1000).toISOString();
    }
  }

  async function load() {
    try {
      const r = await fetch(ENDPOINT, { cache: "no-store" });
      render(await r.json());
    } catch (e) {
      render({ error: String(e) });
    }
  }

  load();
  setInterval(load, 60_000);

  // Risk-tier performance — fetch /performance?tier=N for N in {1,2,3}.
  const TIER_LABELS = { 1: "Conservative", 2: "Balanced", 3: "Aggressive" };

  function renderTier(tier, data) {
    const card = document.querySelector(`.tier-card[data-tier="${tier}"] .tier-body`);
    if (!card) return;
    const tp = data && data.tier_performance;
    if (!tp) {
      card.innerHTML = "<div class='tier-err'>no data</div>";
      return;
    }
    const totalCls = tp.total_pnl_usd >= 0 ? "pos" : "neg";
    const sharpe = tp.sharpe === null || tp.sharpe === undefined
      ? "—"
      : Number(tp.sharpe).toFixed(2);
    const contributors = (tp.top_contributors || []).join(", ") || "—";
    let strategyRows = "";
    const byStrat = tp.by_strategy || {};
    for (const [name, s] of Object.entries(byStrat)) {
      const pnlCls = s.total_pnl_usd >= 0 ? "pos" : "neg";
      strategyRows += `
        <tr>
          <td>${name}</td>
          <td>${s.n}</td>
          <td>${Number(s.win_pct).toFixed(1)}%</td>
          <td class="${pnlCls}">${usd(s.total_pnl_usd)}</td>
          <td>${s.sharpe === null || s.sharpe === undefined ? "—" : Number(s.sharpe).toFixed(2)}</td>
        </tr>`;
    }
    card.innerHTML = `
      <div class="tier-summary">
        <div><span class="muted">n</span> ${tp.n}</div>
        <div><span class="muted">win</span> ${Number(tp.win_pct).toFixed(1)}%</div>
        <div><span class="muted">total</span> <span class="${totalCls}">${usd(tp.total_pnl_usd)}</span></div>
        <div><span class="muted">sharpe</span> ${sharpe}</div>
      </div>
      <table class="tier-table">
        <thead><tr><th>strategy</th><th>n</th><th>win</th><th>PnL</th><th>sharpe</th></tr></thead>
        <tbody>${strategyRows || "<tr><td colspan='5' class='muted'>none qualifying</td></tr>"}</tbody>
      </table>
      <div class="tier-foot muted">top: ${contributors}</div>
    `;
  }

  async function loadTier(tier) {
    try {
      const r = await fetch(
        `https://api.n0brains.com/performance?days=30&tier=${tier}`,
        { cache: "no-store" }
      );
      renderTier(tier, await r.json());
    } catch (e) {
      const card = document.querySelector(`.tier-card[data-tier="${tier}"] .tier-body`);
      if (card) card.innerHTML = `<div class="tier-err">load failed: ${e}</div>`;
    }
  }

  async function loadAllTiers() {
    await Promise.all([loadTier(1), loadTier(2), loadTier(3)]);
    const meta = document.getElementById("tier-meta");
    if (meta) {
      try {
        const r = await fetch(
          "https://api.n0brains.com/performance?days=30&tier=1",
          { cache: "no-store" }
        );
        const d = await r.json();
        if (d?.tier_performance?.generated_at) {
          meta.textContent =
            "tier rollup generated " + d.tier_performance.generated_at +
            " · " + (d.tier_performance.methodology || "");
        }
      } catch {}
    }
  }
  loadAllTiers();
  setInterval(loadAllTiers, 60_000);
</script>

<style>
  .proof-banner {
    display: flex; align-items: center; gap: 12px;
    padding: 16px 20px; border-radius: 6px;
    font-family: var(--font-mono); font-size: 0.9rem;
    margin: 1.5rem 0 2rem; border: 1px solid var(--border);
  }
  .proof-banner .dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--text-muted);
  }
  .proof-up { border-color: #2a7a2a; }
  .proof-up .dot { background: #4ade80; box-shadow: 0 0 6px #4ade80; }
  .proof-unknown { border-color: var(--border); }
  .proof-loading .dot { background: var(--accent); }

  .proof-table {
    width: 100%; border-collapse: collapse;
    font-family: var(--font-mono); font-size: 0.88rem;
  }
  .proof-table th, .proof-table td {
    padding: 10px 12px; text-align: left;
    border-bottom: 1px solid var(--border);
  }
  .proof-table th { color: var(--text-muted); font-weight: 500; }
  .proof-table td.type { font-weight: 600; }
  .proof-table .pos { color: #4ade80; }
  .proof-table .neg { color: #ef4444; }
  .row-untradeable { opacity: 0.55; }

  .badge {
    font-size: 0.72rem; padding: 2px 8px; border-radius: 10px;
    border: 1px solid var(--border);
  }
  .badge-yes { color: #4ade80; border-color: #2a7a2a; }
  .badge-no  { color: var(--text-muted); }

  .meta { color: var(--text-muted); font-size: 0.8rem; margin-top: 1rem;
          font-family: var(--font-mono); }

  .tier-heading { margin-top: 2.5rem; }
  .tier-blurb { color: var(--text-muted); font-size: 0.9rem; }
  .tier-cards {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1rem; margin-top: 1rem;
  }
  @media (max-width: 900px) {
    .tier-cards { grid-template-columns: 1fr; }
  }
  .tier-card {
    border: 1px solid var(--border); border-radius: 6px;
    padding: 1rem 1.1rem; background: rgba(255,255,255,0.02);
    font-family: var(--font-mono);
  }
  .tier-card h3 { margin: 0 0 0.6rem; font-size: 0.95rem; font-weight: 600; }
  .tier-summary {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 4px 8px; font-size: 0.82rem; margin-bottom: 0.6rem;
  }
  .tier-summary .muted { color: var(--text-muted); margin-right: 4px; }
  .tier-table {
    width: 100%; border-collapse: collapse; font-size: 0.78rem;
    margin-top: 0.3rem;
  }
  .tier-table th, .tier-table td {
    padding: 6px 6px; text-align: left; border-bottom: 1px solid var(--border);
  }
  .tier-table th { color: var(--text-muted); font-weight: 500; }
  .tier-table .pos { color: #4ade80; }
  .tier-table .neg { color: #ef4444; }
  .tier-foot { font-size: 0.75rem; margin-top: 0.5rem; }
  .tier-err { color: #ef4444; font-size: 0.8rem; }
</style>

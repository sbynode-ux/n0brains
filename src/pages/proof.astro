    padding: 0.7rem 1rem; border-bottom: 1px solid var(--border);
  }
  .gate-crit {
    display: flex; align-items: center; gap: 0.6rem;
    font-family: var(--font-mono); font-size: 0.74rem; color: var(--text);
    padding: 0.55rem 1rem;
  }
  .gate-crit + .gate-crit { border-top: 1px dashed rgba(255,255,255,0.05); }
  .gc-check { color: var(--accent); font-weight: 700; }

  .gate-out { margin-bottom: 1rem; }
  .gate-out.fail { margin-bottom: 0; }

  /* Win-rate bar board */
  .wr-bars { margin-bottom: 1.5rem; }
  :global(.wr-row) {
    display: grid; grid-template-columns: 120px 1fr 64px 90px;
    gap: 0.9rem; align-items: center; padding: 0.45rem 0;
  }
  @media (max-width: 640px) {
    :global(.wr-row) { grid-template-columns: 90px 1fr 56px; }
    :global(.wr-badge) { display: none; }
  }
  :global(.wr-name) {
    font-family: var(--font-mono); font-size: 0.74rem; font-weight: 700;
    color: var(--text-heading); text-transform: uppercase; letter-spacing: 0.06em;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  :global(.wr-row.demoted .wr-name) { color: var(--text-muted); font-weight: 400; }
  :global(.wr-track) {
    position: relative; height: 10px; background: var(--bg-alt);
    border: 1px solid var(--border); border-radius: 3px; overflow: visible;
  }
  :global(.wr-fill) {
    display: block; height: 100%; border-radius: 2px;
    background: linear-gradient(90deg, var(--accent-dim), var(--accent));
    transition: width 1.1s var(--ease-out);
  }
  :global(.wr-row.demoted .wr-fill) { background: #333; }
  :global(.wr-50) {
    position: absolute; left: 50%; top: -3px; bottom: -3px; width: 1px;
    background: var(--text-faint); opacity: 0.7;
  }
  :global(.wr-val) {
    font-family: var(--font-mono); font-size: 0.74rem; color: var(--text);
    text-align: right;
  }
  :global(.wr-row.demoted .wr-val) { color: var(--text-muted); }

  .proven-cards.loaded :global(.pv-card) { animation: none; opacity: 1; transform: none; }

  /* Live stat band */
  .stat-band {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px;
    background: var(--border); border: 1px solid var(--border);
    border-radius: var(--radius); overflow: hidden; margin-bottom: 1.25rem;
    opacity: 0; animation: fadeUp 0.6s var(--ease-out) 0.5s forwards;
  }
  .stat { background: var(--bg-alt); padding: 1.1rem 1.2rem 1rem; }
  .stat-num {
    display: block; font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.6rem); line-height: 1;
    color: var(--accent); letter-spacing: 0.02em;
  }
  .stat-label {
    display: block; margin-top: 0.35rem;
    font-family: var(--font-mono); font-size: 0.62rem;
    text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted);
  }
  @media (max-width: 720px) { .stat-band { grid-template-columns: 1fr 1fr; } }

  .proof-banner {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 16px; border-radius: 6px;
    font-family: var(--font-mono); font-size: 0.85rem;
    margin: 0 0 1.5rem; border: 1px solid var(--border);
  }
  .proof-banner .dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--text-muted);
  }
  .proof-up { border-color: #2a7a2a; }
  .proof-up .dot { background: #4ade80; box-shadow: 0 0 6px #4ade80; }
  .proof-unknown { border-color: var(--border); }
  .proof-loading .dot { background: var(--accent); }

  /* Proven type cards — JS-injected, style with :global */
  .proven-cards {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1rem; margin-bottom: 3rem;
  }
  @media (max-width: 820px) { .proven-cards { grid-template-columns: 1fr; } }
  :global(.pv-card) {
    border: 1px solid var(--border-accent); border-radius: var(--radius);
    background: var(--bg-card); padding: 1.2rem 1.3rem;
    box-shadow: 0 0 36px -18px var(--accent-glow-strong);
    opacity: 0; transform: translateY(14px);
    animation: fadeUp 0.6s var(--ease-out) calc(0.1s + var(--pvi, 0) * 0.12s) forwards;
  }
  :global(.pv-head) {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 0.6rem;
  }
  :global(.pv-type) {
    font-family: var(--font-mono); font-size: 0.85rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-heading);
  }
  :global(.pv-win) {
    font-family: var(--font-display); font-size: 3rem; line-height: 1;
    color: var(--accent); margin-bottom: 0.9rem;
  }
  :global(.pv-win span) {
    display: block; font-family: var(--font-mono); font-size: 0.62rem;
    text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted);

  :global(.pv-rows span) { color: var(--text-muted); text-transform: uppercase; font-size: 0.66rem; letter-spacing: 0.08em; }
  :global(.pv-rows .pos) { color: #4ade80; }
  :global(.pv-rows .neg) { color: #ef4444; }
  :global(.pv-empty) {

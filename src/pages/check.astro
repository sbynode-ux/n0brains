---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="check"
  description="Ask n0brains First — graded pre-trade conditions check. Submit your trade idea (asset, side, leverage, stop) and get a grade A–F with the reasons: crowding, event risk, liquidation distance vs volatility, proven-edge conflicts. Every grade is logged and audited on /proof."
>
  <section class="check-page">
    <div class="ck-hero">
      <p class="ck-kicker"><span class="ck-dash"></span><span data-scramble>pre-trade check · ask n0brains first</span></p>
      <h1 class="ck-h1">ASK <span class="accent">FIRST.</span></h1>
      <p class="ck-lede">
        About to take a trade? Tell us what you're planning. We check the market
        around it — who's crowded on your side, what news is coming, whether your
        leverage survives a normal day — and give it a grade from A to F.
        Every grade we give goes on the public record at <a href="/proof">/proof</a>.
      </p>
      <p class="ck-trust" id="ck-trust" hidden></p>
      <div class="ck-examples">
        <span class="ck-opt">try one:</span>
        <button type="button" class="ck-chip-btn ck-ex" data-ex='{"asset":"BTC","side":"long","lev":10}'>BTC long 10×</button>
        <button type="button" class="ck-chip-btn ck-ex" data-ex='{"asset":"ETH","side":"short","stopPct":2}'>ETH short + stop</button>
        <button type="button" class="ck-chip-btn ck-ex" data-ex='{"asset":"SOL","side":"long","lev":20,"stopPct":1}'>SOL long 20× tight stop</button>
      </div>
    </div>

    <!-- signed-out gate: try 1 anonymous check, or sign in for more -->
    <div class="ck-card ck-gate" id="ck-gate" hidden>
      <p class="ck-gate-line">Try <b>1 free check</b> below — no account.
        Free accounts get <b>3 checks a day</b> + your history; Pro is unlimited.</p>
      <div class="ck-gate-btns">
        <a class="ck-btn" href="/login?next=/check">LOG IN</a>
        <a class="ck-btn ck-btn-cta" href="/signup">CREATE FREE ACCOUNT</a>
      </div>
      <details class="ck-adv">
        <summary>advanced: use an API key instead</summary>
        <div class="ck-adv-row">
          <input id="ck-key" placeholder="intel_sk_…" autocomplete="off" />
          <button type="button" class="ck-btn" id="ck-key-use">USE KEY</button>
        </div>
      </details>
    </div>

    <div class="ck-grid" id="ck-app" hidden>
      <form id="ck-form" class="ck-card">
        <div class="ck-signed" id="ck-signed"></div>
        <div class="ck-drop" id="ck-drop" hidden>
          <input type="file" id="ck-file" accept="image/*" hidden />
          <span id="ck-drop-label">📈 drop a chart screenshot here (or click) — we'll read the ticker</span>
        </div>
        <div class="ck-parse" id="ck-parse" hidden>
          <span id="ck-parse-text"></span>
          <button type="button" class="ck-chip-btn" id="ck-parse-yes">✓ use</button>
          <button type="button" class="ck-chip-btn" id="ck-parse-no">✗ ignore</button>
        </div>
        <div class="ck-row">
          <label>ASSET<input id="ck-asset" placeholder="BTC" maxlength="12" required
            list="ck-assets" autocomplete="off" /></label>
          <datalist id="ck-assets"></datalist>
          <label>SIDE
            <div class="ck-side">
              <button type="button" id="ck-long" class="ck-side-btn on">LONG</button>
              <button type="button" id="ck-short" class="ck-side-btn">SHORT</button>
            </div>
          </label>
        </div>
        <div class="ck-spotline" id="ck-spotline" hidden>spot <b id="ck-spot">—</b></div>
        <div class="ck-row">
          <label>ENTRY <span class="ck-opt">optional — live price if empty</span><input id="ck-entry" type="number" step="any" placeholder="spot" /></label>
          <label>STOP <span class="ck-opt">optional</span><input id="ck-stop" type="number" step="any" placeholder="—" />
            <span class="ck-shortcuts"><button type="button" class="ck-mini" data-stop="1">−1%</button><button type="button" class="ck-mini" data-stop="2">−2%</button><button type="button" class="ck-mini" data-stop="5">−5%</button></span>
          </label>
        </div>
        <div class="ck-row">
          <label>TARGET <span class="ck-opt">optional</span><input id="ck-target" type="number" step="any" placeholder="—" /></label>
          <label>LEVERAGE <span class="ck-opt">optional</span><input id="ck-lev" type="number" step="any" min="1" max="100" placeholder="1" />
            <span class="ck-shortcuts"><button type="button" class="ck-mini" data-lev="3">3×</button><button type="button" class="ck-mini" data-lev="5">5×</button><button type="button" class="ck-mini" data-lev="10">10×</button><button type="button" class="ck-mini" data-lev="20">20×</button></span>
          </label>
        </div>
        <div class="ck-row">
          <label>HORIZON
            <select id="ck-horizon">
              <option value="4">4h</option>
              <option value="24" selected>24h</option>
              <option value="72">3d</option>
              <option value="168">7d</option>
            </select>
          </label>
          <label class="ck-quota-label">TODAY<span class="ck-opt" id="ck-quota">&nbsp;</span></label>
        </div>
        <div id="ck-turnstile" class="ck-turnstile"></div>
        <button type="submit" id="ck-go" class="ck-submit">RUN CHECK</button>
        <p class="ck-err" id="ck-err" hidden></p>
      </form>

      <div class="ck-card ck-result" id="ck-result" hidden>
        <div class="ck-grade-row">
          <div class="ck-grade" id="ck-grade">—</div>
          <div class="ck-grade-meta">
            <div id="ck-headline">conditions</div>
            <div class="ck-score" id="ck-score"></div>
            <div class="ck-scale" id="ck-scale">
              <span data-g="F">F</span><span data-g="D">D</span><span data-g="C">C</span><span data-g="B">B</span><span data-g="B+">B+</span><span data-g="A">A</span>
            </div>
          </div>
        </div>
        <p class="ck-upsell" id="ck-upsell" hidden>
          That's your free check for today — <a href="/signup">a free account gets 3/day + your history</a>.
        </p>
        <div class="ck-section" id="ck-flags-wrap" hidden>
          <div class="ck-sec-title">WORKING AGAINST YOU</div>
          <ul class="ck-list" id="ck-flags"></ul>
        </div>
        <div class="ck-section" id="ck-supports-wrap" hidden>
          <div class="ck-sec-title ck-pos">IN YOUR FAVOR</div>
          <ul class="ck-list" id="ck-supports"></ul>
        </div>
        <div class="ck-section" id="ck-fals-wrap" hidden>
          <div class="ck-sec-title">WHAT WOULD CHANGE THIS GRADE</div>
          <ul class="ck-list ck-fals" id="ck-fals"></ul>
        </div>
        <div class="ck-section" id="ck-unchecked-wrap" hidden>
          <div class="ck-sec-title">NOT CHECKED — YOU DIDN'T TELL US</div>
          <ul class="ck-list ck-unchecked" id="ck-unchecked"></ul>
        </div>
        <button type="button" class="ck-chip-btn" id="ck-copy">copy result</button>
        <p class="ck-fine">
          Conditions assessment measured from live market data — analytical, not
          financial advice. Grades are logged and resolved at horizon;
          calibration publishes on <a href="/proof">/proof</a>.
        </p>
      </div>
    </div>

    <!-- history -->
    <div class="ck-hist" id="ck-hist" hidden>
      <div class="ck-sec-title">YOUR CHECKS · ON THE RECORD</div>
      <p class="ck-record" id="ck-record" hidden></p>
      <div class="ck-hist-scroll">
        <table class="ck-table">
          <thead><tr>
            <th>when</th><th>trade</th><th>grade</th><th>horizon</th><th>result</th><th></th>
          </tr></thead>
          <tbody id="ck-hist-body"></tbody>
        </table>
      </div>
      <p class="ck-fine">Results are the side-adjusted move from your entry to the
        end of the horizon (or your stop, if it was hit first). Pending checks
        resolve automatically — come back after the horizon.</p>
    </div>

    <div class="ck-how">
      <div class="ck-sec-title">HOW IT WORKS</div>
      <ol class="ck-list">
        <li>Type in the trade you're thinking about. Only the coin and long/short are required.</li>
        <li>We grade the conditions around it, A to F, and show every reason.</li>
        <li>Come back after the horizon — your grade gets scored against what actually happened, publicly, on <a href="/proof">/proof</a>.</li>
      </ol>
    </div>
    <p class="ck-signoff">// every grade goes on the record</p>
  </section>

  <script>
    const $ = (id) => document.getElementById(id);
    const API = "https://api.n0brains.com";
    let side = "long";

    // ── auth state: session JWT > saved API key > anonymous (1/day, Turnstile)
    const TURNSTILE_SITEKEY = "0x4AAAAAADu0UwgPFCz27sIq";
    const token = localStorage.getItem("auth_token");
    const savedKey = localStorage.getItem("api_key");
    const mode = token ? "session" : savedKey ? "key" : "anon";
    function authHeader() {
      if (token) return { Authorization: `Bearer ${token}` };
      if (savedKey) return { "X-API-Key": savedKey };
      return {};
    }
    function signOutToGate(msg) {
      localStorage.removeItem("auth_token");
      if (msg) alert(msg);
      location.reload();
    }

    // anon: gate (login CTAs) AND the form both show; form runs 1 Turnstile-
    // gated check against /check/anon. signed-in: form only, full quota.
    $("ck-app").hidden = false;
    $("ck-gate").hidden = mode !== "anon";
    if (mode === "anon") {
      $("ck-signed").textContent = "anonymous — 1 free check today";
      $("ck-quota").textContent = "1 free (no account)";
      const s = document.createElement("script");
      s.src = "https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit&onload=ckTsInit";
      s.async = true; s.defer = true;
      window.ckTsInit = () => window.turnstile.render("#ck-turnstile", { sitekey: TURNSTILE_SITEKEY });
      document.head.appendChild(s);
    } else {
      $("ck-signed").textContent = mode === "session" ? "signed in — session" : "using API key";
      loadHistory();
    }
    $("ck-key-use").addEventListener("click", () => {
      const k = $("ck-key").value.trim();
      if (!k) return;
      localStorage.setItem("api_key", k);
      location.reload();
    });

    // supported-asset autocomplete (public endpoint, cached server-side)
    fetch(`${API}/check/assets`).then(r => r.json()).then(d => {
      $("ck-assets").innerHTML = (d.assets || [])
        .map(a => `<option value="${a}">`).join("");
    }).catch(() => {});

    // ── chart screenshot → identity parse (signed-in only; vision call) ──
    if (mode !== "anon") $("ck-drop").hidden = false;
    const drop = $("ck-drop");
    drop.addEventListener("click", () => $("ck-file").click());
    drop.addEventListener("dragover", (e) => { e.preventDefault(); drop.classList.add("on"); });
    drop.addEventListener("dragleave", () => drop.classList.remove("on"));
    drop.addEventListener("drop", (e) => {
      e.preventDefault(); drop.classList.remove("on");
      const f = e.dataTransfer.files && e.dataTransfer.files[0];
      if (f) parseChart(f);
    });
    $("ck-file").addEventListener("change", (e) => {
      if (e.target.files[0]) parseChart(e.target.files[0]);
    });

    async function parseChart(file) {
      $("ck-drop-label").textContent = "reading chart…";
      try {
        const b64 = await resizeToJpegB64(file, 900);
        const r = await fetch(`${API}/check/chart-parse`, {
          method: "POST",
          headers: { "Content-Type": "application/json", ...authHeader() },
          body: JSON.stringify({ image_b64: b64, media_type: "image/jpeg" }),
          signal: AbortSignal.timeout(40000),
        });
        const d = await r.json();
        if (!r.ok) throw new Error(d.detail || `HTTP ${r.status}`);
        if (!d.asset || d.confidence < 0.3) {
          $("ck-drop-label").textContent = "couldn't read a ticker from that image — type it instead";
          return;
        }
        window._parse = d;
        $("ck-parse").hidden = false;
        $("ck-parse-text").textContent =
          `Reading this as ${d.asset}${d.timeframe ? " · " + d.timeframe : ""}` +
          `${d.covered ? "" : " (NOT covered — check the spelling)"} — confirm?`;
        $("ck-drop-label").textContent = "📈 drop a different screenshot to re-read";
      } catch (err) {
        $("ck-drop-label").textContent = `chart read failed: ${err.message} — type the ticker instead`;
      }
    }
    $("ck-parse-yes").addEventListener("click", () => {
      const d = window._parse || {};
      if (d.asset) $("ck-asset").value = d.asset;
      if (d.suggested_horizon_hours) {
        const sel = $("ck-horizon");
        const want = String(d.suggested_horizon_hours);
        for (const o of sel.options) if (o.value === want) sel.value = want;
      }
      // explicit confirmation: buttons go away, chip states what happened,
      // the filled field flashes so the eye lands on it (user QA 2026-07-03:
      // chip previously appeared to ignore the click)
      $("ck-parse-yes").hidden = true; $("ck-parse-no").hidden = true;
      $("ck-parse-text").textContent = `✓ applied — ${d.asset}${d.timeframe ? " · " + d.timeframe : ""} filled in below`;
      $("ck-asset").classList.add("ck-flash");
      if (typeof fetchSpot === "function") fetchSpot();
      setTimeout(() => { $("ck-parse").hidden = true; $("ck-asset").classList.remove("ck-flash");
                         $("ck-parse-yes").hidden = false; $("ck-parse-no").hidden = false; }, 2500);
    });
    $("ck-parse-no").addEventListener("click", () => { $("ck-parse").hidden = true; });

    function resizeToJpegB64(file, maxDim) {
      return new Promise((resolve, reject) => {
        const img = new Image();
        img.onload = () => {
          const scale = Math.min(1, maxDim / Math.max(img.width, img.height));
          const c = document.createElement("canvas");
          c.width = Math.round(img.width * scale);
          c.height = Math.round(img.height * scale);
          c.getContext("2d").drawImage(img, 0, 0, c.width, c.height);
          resolve(c.toDataURL("image/jpeg", 0.82).split(",")[1]);
        };
        img.onerror = () => reject(new Error("could not load image"));
        img.src = URL.createObjectURL(file);
      });
    }

    function setSide(sd) {
      side = sd;
      $("ck-long").classList.toggle("on", sd === "long");
      $("ck-short").classList.toggle("on", sd === "short");
    }
    $("ck-long").addEventListener("click", () => setSide("long"));
    $("ck-short").addEventListener("click", () => setSide("short"));

    // live spot chip: fetch when the asset field settles
    let spotPx = null, spotTimer = null;
    $("ck-asset").addEventListener("input", () => {
      clearTimeout(spotTimer);
      spotTimer = setTimeout(fetchSpot, 500);
    });
    async function fetchSpot() {
      const a = $("ck-asset").value.trim().toUpperCase();
      spotPx = null; $("ck-spotline").hidden = true;
      if (!a) return;
      try {
        const r = await fetch(`${API}/price/${a}`, { signal: AbortSignal.timeout(8000) });
        if (!r.ok) return;
        const d = await r.json();
        const px = Number(d.price || d.mid || d.current_price);
        if (px > 0) {
          spotPx = px;
          $("ck-spot").textContent = px >= 100 ? px.toLocaleString() : String(px);
          $("ck-spotline").hidden = false;
        }
      } catch {}
    }

    // one-tap shortcuts: stop at −N% (side-aware) and leverage chips
    document.querySelectorAll(".ck-mini[data-stop]").forEach(b =>
      b.addEventListener("click", () => {
        const base = Number($("ck-entry").value) || spotPx;
        if (!base) { $("ck-err").textContent = "pick an asset first (need a price for % stops)"; $("ck-err").hidden = false; return; }
        const pct = Number(b.dataset.stop) / 100;
        const px = side === "long" ? base * (1 - pct) : base * (1 + pct);
        $("ck-stop").value = px >= 100 ? px.toFixed(1) : px.toPrecision(5);
      }));
    document.querySelectorAll(".ck-mini[data-lev]").forEach(b =>
      b.addEventListener("click", () => { $("ck-lev").value = b.dataset.lev; }));

    // example chips: prefill + run
    document.querySelectorAll(".ck-ex").forEach(b =>
      b.addEventListener("click", async () => {
        const ex = JSON.parse(b.dataset.ex);
        $("ck-asset").value = ex.asset; setSide(ex.side);
        $("ck-lev").value = ex.lev || ""; $("ck-stop").value = ""; $("ck-target").value = "";
        await fetchSpot();
        if (ex.stopPct && spotPx) {
          const px = ex.side === "long" ? spotPx * (1 - ex.stopPct / 100) : spotPx * (1 + ex.stopPct / 100);
          $("ck-stop").value = px >= 100 ? px.toFixed(1) : px.toPrecision(5);
        }
        $("ck-app").scrollIntoView({ behavior: "smooth", block: "start" });
        if (mode !== "anon") $("ck-form").requestSubmit();  // anon: Turnstile first
      }));

    // staged progress text while the engine works
    const STAGES = ["reading positioning…", "scanning scheduled events…",
                    "measuring volatility…", "checking proven edges…", "grading…"];
    let stageTimer = null;
    function startStages() {
      let i = 0;
      $("ck-go").textContent = STAGES[0];
      stageTimer = setInterval(() => {
        i = Math.min(i + 1, STAGES.length - 1);
        $("ck-go").textContent = STAGES[i];
      }, 1600);
    }
    function stopStages() {
      clearInterval(stageTimer);
      $("ck-go").textContent = "RUN CHECK";
    }

    const num = (id) => { const v = $(id).value.trim(); return v === "" ? null : Number(v); };

    $("ck-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      $("ck-err").hidden = true;
      const body = {
        asset: $("ck-asset").value.trim().toUpperCase(), side,
        entry: num("ck-entry"), stop: num("ck-stop"), target: num("ck-target"),
        leverage: num("ck-lev"), horizon_hours: Number($("ck-horizon").value),
      };
      $("ck-go").disabled = true; startStages();
      try {
        let url = `${API}/check`;
        if (mode === "anon") {
          const ts = window.turnstile && window.turnstile.getResponse();
          if (!ts) throw new Error("Please complete the verification widget first.");
          body.turnstile_token = ts;
          url = `${API}/check/anon`;
        }
        const r = await fetch(url, {
          method: "POST",
          headers: { "Content-Type": "application/json", ...authHeader() },
          body: JSON.stringify(body),
          signal: AbortSignal.timeout(30000),  // never strand the button
        });
        if (r.status === 401 && mode !== "anon") return signOutToGate("Session expired — please log in again.");
        const d = await r.json().catch(() => ({}));
        if (!r.ok) throw new Error(d.detail || `HTTP ${r.status}`);
        render(d);
        if (mode === "anon") {
          $("ck-quota").textContent = "0 free left — accounts get 3/day";
          if (window.turnstile) window.turnstile.reset();
        } else {
          loadHistory();
        }
      } catch (err) {
        $("ck-err").textContent = String(err.message || err);
        $("ck-err").hidden = false;
        $("ck-result").hidden = true;
      } finally {
        $("ck-go").disabled = false; stopStages();
      }
    });

    const GRADE_COLOR = { "A": "#2ecc71", "B+": "#7ac943", "B": "#c9b843", "C": "#e0983a", "D": "#e0663a", "F": "#e03a3a" };
    function render(d) {
      lastResult = d;
      $("ck-result").hidden = false;
      $("ck-grade").textContent = d.grade;
      $("ck-grade").style.color = GRADE_COLOR[d.grade] || "inherit";
      $("ck-headline").textContent = `${d.asset} ${d.side === "bullish" ? "LONG" : "SHORT"} · ${d.horizon_hours}h horizon · regime: ${d.regime || "—"}`;
      $("ck-score").textContent = `score ${d.score} · realized daily vol ${d.realized_daily_vol_pct ?? "—"}%`;
      document.querySelectorAll("#ck-scale span").forEach(el => {
        el.classList.toggle("on", el.dataset.g === d.grade);
        if (el.dataset.g === d.grade) el.style.color = GRADE_COLOR[d.grade] || "inherit";
        else el.style.color = "";
      });
      $("ck-upsell").hidden = !(mode === "anon");
      setQuota(d.free_checks_remaining_today);
      fill("ck-flags", "ck-flags-wrap", (d.flags || []).map(f =>
        `<b class="ck-sev ck-sev-${f.severity}">${f.severity}</b> ${esc(f.note)}`));
      fill("ck-supports", "ck-supports-wrap", (d.supports || []).map(s => esc(s.note)));
      fill("ck-fals", "ck-fals-wrap", (d.falsifiers || []).map(esc));
      fill("ck-unchecked", "ck-unchecked-wrap", (d.unchecked || []).map(esc));
      $("ck-result").scrollIntoView({ behavior: "smooth", block: "nearest" });
    }
    function setQuota(left) {
      if (mode === "anon") return; // anon quota text managed by submit handler
      $("ck-quota").textContent = left == null ? "unlimited (pro)" : `${left} free checks left`;
    }
    function fill(listId, wrapId, items) {
      $(wrapId).hidden = items.length === 0;
      $(listId).innerHTML = items.map(i => `<li>${i}</li>`).join("");
    }
    function esc(s) { const t = document.createElement("span"); t.textContent = s ?? ""; return t.innerHTML; }

    // trust chip: live count of publicly resolved grades
    fetch(`${API}/proof`).then(r => r.json()).then(d => {
      const cg = d.check_grades;
      if (cg && cg.n_resolved > 0) {
        $("ck-trust").innerHTML = `${cg.n_resolved} grades already resolved on the ` +
          `<a href="/proof">public record</a> — we grade our own grades.`;
        $("ck-trust").hidden = false;
      }
    }).catch(() => {});

    // copy result as shareable text
    let lastResult = null;
    $("ck-copy").addEventListener("click", () => {
      if (!lastResult) return;
      const d = lastResult;
      const flags = (d.flags || []).map(f => `⚠ ${f.note}`).join("\n");
      const sup = (d.supports || []).map(x => `✓ ${x.note}`).join("\n");
      const txt = `n0brains graded my ${d.asset} ${d.side === "bullish" ? "LONG" : "SHORT"}: ${d.grade}\n` +
        [flags, sup].filter(Boolean).join("\n") +
        `\n— every grade goes on the record: https://n0brains.com/check`;
      navigator.clipboard.writeText(txt).then(() => {
        $("ck-copy").textContent = "✓ copied";
        setTimeout(() => { $("ck-copy").textContent = "copy result"; }, 1500);
      });
    });

    // ── history ──
    async function loadHistory() {
      try {
        const r = await fetch(`${API}/checks/history`, { headers: { ...authHeader() }, signal: AbortSignal.timeout(20000) });
        if (r.status === 401) return signOutToGate("Session expired — please log in again.");
        if (!r.ok) return;
        const d = await r.json();
        setQuota(d.free_checks_remaining_today ?? null);
        if (!d.checks || d.checks.length === 0) return;
        $("ck-hist").hidden = false;
        const res = d.checks.filter(c => c.ret_pct != null);
        if (res.length >= 2) {
          const wins = res.filter(c => c.ret_pct > 0).length;
          const avg = res.reduce((a, c) => a + c.ret_pct, 0) / res.length;
          $("ck-record").textContent =
            `your record: ${wins}/${res.length} profitable · avg ${avg >= 0 ? "+" : ""}${avg.toFixed(2)}% per check`;
          $("ck-record").hidden = false;
        }
        $("ck-hist-body").innerHTML = d.checks.map(rowHtml).join("");
        document.querySelectorAll(".ck-recheck").forEach(b =>
          b.addEventListener("click", () => {
            const c = JSON.parse(b.dataset.c);
            $("ck-asset").value = c.asset; setSide(c.side === "bullish" ? "long" : "short");
            $("ck-entry").value = ""; // fresh entry at current spot
            $("ck-stop").value = c.stop_price ?? ""; $("ck-target").value = c.target_price ?? "";
            $("ck-lev").value = c.leverage ?? "";
            const want = String(Math.round((c.horizon_secs || 86400) / 3600));
            for (const o of $("ck-horizon").options) if (o.value === want) $("ck-horizon").value = want;
            fetchSpot();
            $("ck-app").scrollIntoView({ behavior: "smooth", block: "start" });
            $("ck-form").requestSubmit();
          }));
      } catch {}
    }
    function rowHtml(c) {
      const dt = new Date(c.created_at * 1000);
      const when = dt.toLocaleString(undefined, { month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" });
      const sideTxt = c.side === "bullish" ? "LONG" : "SHORT";
      const lev = c.leverage ? ` ${c.leverage}x` : "";
      const hz = c.horizon_secs >= 86400 ? `${Math.round(c.horizon_secs / 86400)}d` : `${Math.round(c.horizon_secs / 3600)}h`;
      let result;
      if (c.resolved_at == null) {
        result = `<span class="ck-pending">pending</span>`;
      } else if (c.ret_pct == null) {
        result = `<span class="ck-pending">n/a</span>`;
      } else {
        const cls = c.ret_pct > 0 ? "ck-win" : c.ret_pct < 0 ? "ck-loss" : "";
        const stop = c.stop_hit ? " · stopped" : "";
        result = `<span class="${cls}">${c.ret_pct > 0 ? "+" : ""}${c.ret_pct}%${stop}</span>`;
      }
      const gc = GRADE_COLOR[c.grade] || "inherit";
      const cJson = esc(JSON.stringify({asset: c.asset, side: c.side, stop_price: c.stop_price,
        target_price: c.target_price, leverage: c.leverage, horizon_secs: c.horizon_secs}));
      return `<tr>
        <td>${when}</td>
        <td>${esc(c.asset)} ${sideTxt}${lev}</td>
        <td><b style="color:${gc}">${esc(c.grade)}</b></td>
        <td>${hz}</td>
        <td>${result}</td>
        <td><button type="button" class="ck-mini ck-recheck" data-c="${cJson}">re-check now</button></td>
      </tr>`;
    }
  </script>


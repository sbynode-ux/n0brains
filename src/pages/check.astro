      border: 1px solid color-mix(in srgb, var(--gc, #2ecc71) 45%, var(--border));
      background:
        radial-gradient(ellipse 90% 130% at 12% 50%, color-mix(in srgb, var(--gc, #2ecc71) 9%, transparent), transparent 60%);
      padding: 1.1rem 1.2rem; }

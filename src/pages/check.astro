    .ck-side-btn.on { opacity: 1; outline: 1px solid currentColor; }
    #ck-long.on { color: #2ecc71; outline-color: #2ecc71; }
    #ck-short.on { color: #e05a3a; outline-color: #e05a3a; }

    .ck-submit { position: relative; overflow: hidden; width: 100%; padding: .85rem; margin-top: .3rem;
      background: transparent; border: 1px solid var(--accent, #00ff41);
      color: var(--accent, #00ff41); font: inherit; letter-spacing: .18em; cursor: pointer; }
    .ck-submit:hover { background: color-mix(in srgb, var(--accent, #00ff41) 12%, transparent);
      box-shadow: 0 0 18px color-mix(in srgb, var(--accent, #00ff41) 25%, transparent); }

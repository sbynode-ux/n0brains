---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MonoChip from "../../components/MonoChip.astro";

/* -----------------------------------------------------------------------
   /clawhub — download the n0brains-signals agent skill (a plain .md file)
   and wire it to your n0brains API key. No registry, no install command;
   it's one Markdown file you drop into your agent runtime.
   ---------------------------------------------------------------------- */

const runtimes = [
  { chip: "OC",  title: "OpenClaw",
    desc: "Drop <code>n0brains-signals.md</code> into your agent's skills directory. Set <code>NB_API_KEY</code> in the environment (or your secret store, key <code>n0brains_api_key</code>)." },
  { chip: "CC",  title: "Claude Code",
    desc: "Copy it to <code>~/.claude/skills/n0brains-signals/SKILL.md</code>. Set <code>NB_API_KEY</code> in your environment." },
  { chip: "OR",  title: "Custom orchestrator",
    desc: "Load the file as system context. Read the key from <code>NB_API_KEY</code> or your secret store." },
];
---

<BaseLayout
  title="n0brains-signals — agent skill"
  description="Download the n0brains-signals skill — a plain Markdown file that gives any agent (OpenClaw, Claude Code, custom orchestrators) live crypto market intelligence. Bring your own n0brains API key."
>
  <section class="skill-page">

    <header class="hero">
      <p class="eyebrow">// agent skill</p>
      <h1>n0brains-signals</h1>
      <p class="lede">
        A plain Markdown file. Drop it into your agent runtime, set your n0brains API key, and the agent can read the live signal feed — corroborated trading signals, support/resistance levels, session opens. No SDK, no install command, no registry. It does not trade for you; it's an intelligence layer.
      </p>

      <div class="dl-card">
        <div class="dl-row">
          <div class="dl-meta">
            <code class="dl-name">n0brains-signals.md</code>
            <span class="dl-sub">markdown · ~10 KB · v1</span>
          </div>
          <a class="btn btn-primary" href="/clawhub/n0brains-signals.md" download>Download .md ↓</a>
        </div>
        <div class="dl-row alt">
          <code><span class="prompt">$</span>curl -O https://n0brains.com/clawhub/n0brains-signals.md</code>
          <button class="copy-btn" data-copy="curl -O https://n0brains.com/clawhub/n0brains-signals.md" aria-label="copy">copy</button>
        </div>
        <div class="cta-row">
          <a href="/signup" class="btn btn-secondary">Get a free API key →</a>
          <a href="/docs/" class="btn btn-secondary">API docs ↗</a>
        </div>
      </div>
    </header>

    <section class="block">
      <p class="section-label">// how to install it</p>
      <div class="rt-grid">
        {runtimes.map((r) => (
          <div class="rt-card">
            <div class="chip-row"><MonoChip text={r.chip} /></div>
            <h3>{r.title}</h3>
            <p set:html={r.desc}></p>
          </div>
        ))}
      </div>
      <p class="note">
        Whichever runtime you use, the skill reads your key from <code>NB_API_KEY</code> first. Get one — free tier, no card — at <a href="/signup">/signup</a>.
      </p>
    </section>

    <section class="block">
      <p class="section-label">// what it gives the agent</p>
      <table class="tools">
        <thead><tr><th>endpoint</th><th>what</th><th>tier</th></tr></thead>
        <tbody>
          <tr><td><code>GET /signals</code></td><td>active signals — filter by asset / type / urgency / direction</td><td>free + pro</td></tr>
          <tr><td><code>GET /signals/&#123;id&#125;</code></td><td>a single signal by ID — for following a webhook alert</td><td>free + pro</td></tr>
          <tr><td><code>GET /levels/&#123;coin&#125;</code></td><td>nearest support / resistance from the Hyperliquid order book</td><td>free + pro</td></tr>
          <tr><td><code>GET /market-opens</code></td><td>BTC / ETH / SOL at Tokyo, Shanghai, HK, London, NY opens</td><td>free + pro</td></tr>
          <tr><td><code>WS /stream</code></td><td>real-time WebSocket — every new signal in milliseconds</td><td class="pro">pro only</td></tr>
        </tbody>
      </table>
      <p class="note">
        Prefer to skip the skill and call the API directly? See <a href="/docs/">the API docs</a> — or the <a href="https://github.com/sbynode-ux/n0brains-ts">TypeScript client</a> (optional, not yet on npm).
      </p>
    </section>

  </section>
</BaseLayout>

<style>
  .skill-page { max-width: 980px; margin: 0 auto; padding: 0 1.5rem; }

  .hero { padding: 4rem 0 3rem; }
  .eyebrow {
    font-family: var(--font-mono); font-size: 0.7rem;
    color: var(--accent); text-transform: uppercase; letter-spacing: 0.25em;
    margin-bottom: 16px;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 400; line-height: 0.95; letter-spacing: 0.03em;
    color: var(--text-heading); margin-bottom: 1.2rem;
  }
  .lede {
    font-size: 1.05rem; color: var(--text);
    max-width: 640px; margin-bottom: 2.5rem; line-height: 1.65;
  }
  .lede code, .block p code, .block table code, .note code {
    font-family: var(--font-mono); font-size: 0.92em;
    color: var(--accent); background: var(--bg-hover);
    padding: 1px 6px; border-radius: 3px; border: 1px solid var(--border);
  }

  /* download card */
  .dl-card {
    background: var(--bg-alt); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 22px; position: relative; max-width: 660px;
  }
  .dl-card::before {
    content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, var(--accent) 0%, transparent 60%); opacity: 0.6;
  }
  .dl-row {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    background: var(--bg-code); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 14px 16px; margin-bottom: 12px;
    font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-heading);
    overflow-x: auto;
  }
  .dl-row.alt code { color: var(--text); white-space: nowrap; }
  .dl-row .prompt { color: var(--accent); margin-right: 8px; user-select: none; }
  .dl-meta { display: flex; flex-direction: column; gap: 2px; }
  .dl-name { color: var(--text-heading); }
  .dl-sub { font-size: 0.62rem; color: var(--text-muted); letter-spacing: 0.1em; text-transform: uppercase; }
  .copy-btn {
    font-family: var(--font-mono); font-size: 0.62rem; color: var(--text);
    letter-spacing: 0.15em; text-transform: uppercase;
    background: transparent; border: 1px solid var(--border);
    border-radius: 3px; padding: 4px 9px; cursor: pointer; flex-shrink: 0;
    transition: all 0.15s ease;
  }
  .copy-btn:hover { color: var(--accent); border-color: var(--accent); }
  .cta-row { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 6px; }
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 0.85rem 1.5rem; border-radius: var(--radius-sm);
    font-family: var(--font-mono); font-size: 0.85rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.05em;
    transition: all 0.2s ease; border: 0; cursor: pointer; flex-shrink: 0;
  }
  .btn-primary { background: var(--accent); color: #000; }
  .btn-primary:hover { background: #fff; }
  .btn-secondary { background: transparent; color: var(--text); border: 1px solid var(--border); }
  .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

  .block { padding: 3rem 0; border-top: 1px solid var(--border); }
  .section-label {
    font-family: var(--font-mono); font-size: 0.65rem;
    color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.3em;
    display: flex; align-items: center; gap: 16px; margin-bottom: 24px;
  }
  .section-label::after { content: ""; flex: 1; height: 1px; background: var(--border); }
  .block p { color: var(--text); }
  .note { font-size: 0.9rem; color: var(--text); margin-top: 20px; max-width: 680px; }
  .note a, .block table a { color: var(--accent); }

  .rt-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1px; background: var(--border); border: 1px solid var(--border);
  }
  .rt-card { background: var(--bg-alt); padding: 22px 24px; transition: background 0.2s ease; }
  .rt-card:hover { background: var(--bg-hover); }
  .rt-card .chip-row { margin-bottom: 14px; }
  .rt-card h3 {
    font-family: var(--font-body); font-size: 1rem; font-weight: 700;
    color: var(--text-heading); margin-bottom: 6px;
  }
  .rt-card p { font-size: 0.9rem; line-height: 1.55; }
  .rt-card p code {
    font-size: 0.82em; color: var(--accent);
    background: var(--bg-code); padding: 1px 5px; border-radius: 3px; border: 1px solid var(--border);
  }

  .tools { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  .tools th {
    text-align: left; font-family: var(--font-mono); font-size: 0.7rem;
    color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.12em;
    padding: 10px 14px; border-bottom: 1px solid var(--border);
  }
  .tools td { padding: 12px 14px; border-bottom: 1px solid var(--border); color: var(--text); vertical-align: top; }
  .tools tr:last-child td { border-bottom: 0; }
  .tools td.pro { color: var(--accent); }
</style>

<script>
  document.querySelectorAll("[data-copy]").forEach((b) => {
    b.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(b.dataset.copy || "");
        const orig = b.textContent;
        b.textContent = "copied";
        setTimeout(() => { b.textContent = orig; }, 1500);
      } catch { /* ignore */ }
    });
  });
</script>

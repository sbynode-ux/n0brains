---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const order = ["blitzy-thousand-agents", "agents-cant-find-the-file", "openai-symphony", "hello-world"];
posts.sort((a, b) => order.indexOf(a.id) - order.indexOf(b.id));
---

<BaseLayout title="n0brains" description="think less, ship more — a blog about building without overthinking." homepage={true}>
  <section class="hero" id="hero">
    <p class="tagline">n0brains // build mode</p>
    <h1>
      think less<br />
      <span class="highlight">ship more.</span>
    </h1>
    <p class="hero-desc">
      A blog about building things without overthinking them.
      No grand theories. No analysis paralysis. Just shipping.
    </p>
  </section>

  <section>
    <div class="post-list">
      {
        posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="post-card">
            <div class="date">{post.data.pubDate.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}</div>
            <h2>{post.data.title}</h2>
            <p>{post.data.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
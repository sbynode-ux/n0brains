---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Crypto Signals" description="AI-powered crypto intelligence signals. 12 sources, real-time delivery. REST API, WebSocket, Webhooks." homepage={true}>
  <style>
    .signals-page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .hero-section {
      padding: 6rem 0 4rem;
      text-align: center;
    }

    .hero-section h1 {
      font-size: 2.5rem;
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 1rem;
      color: var(--text-heading);
    }

    .hero-section h1 .accent {
      color: var(--accent);
    }

    .hero-section p {
      font-size: 1.1rem;
      color: var(--text-muted);
      max-width: 600px;
      margin: 0 auto 2rem;
      line-height: 1.6;
    }

    .hero-section p strong {
      color: var(--text);
    }

    .live-dot {
      display: inline-block;
      width: 8px;
      height: 8px;
      background: var(--accent);
      border-radius: 50%;
      margin-right: 8px;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }

    .cta-row {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      border-radius: var(--radius-sm);
      font-family: var(--font-mono);
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      transition: all 0.2s ease;
      cursor: pointer;
      border: none;
    }

    .btn-primary {
      background: var(--accent);
      color: #000;
    }

    .btn-primary:hover {
      background: #fff;
      color: #000;
    }

    .btn-secondary {
      background: transparent;
      color: var(--text);
      border: 1px solid var(--border);
    }

    .btn-secondary:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    /* Sources grid */
    .sources-section {
      padding: 4rem 0;
      border-top: 1px solid var(--border);
    }

    .sources-section h2 {
      font-size: 1.8rem;
      font-weight: 800;
      margin-bottom: 0.5rem;
    }

    .sources-section .subtitle {
      color: var(--text-muted);
      margin-bottom: 2rem;
    }

    .sources-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1px;
      background: var(--border);
    }

    .source-card {
      background: var(--bg-alt);
      padding: 1.5rem;
      transition: background 0.2s ease;
    }

    .source-card:hover {
      background: var(--bg-hover);
    }

    .source-card .icon {
      width: 32px;
      height: 32px;
      border: 1px solid var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 0.75rem;
      font-size: 0.8rem;
      color: var(--accent);
    }

    .source-card h3 {
      font-size: 0.95rem;
      font-weight: 700;
      margin-bottom: 0.25rem;
    }

    .source-card p {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.5;
    }

    /* Pricing */
    .pricing-section {
      padding: 4rem 0;
      border-top: 1px solid var(--border);
    }

    .pricing-section h2 {
      font-size: 1.8rem;
      font-weight: 800;
      text-align: center;
      margin-bottom: 0.5rem;
    }

    .pricing-section .subtitle {
      text-align: center;
      color: var(--text-muted);
      margin-bottom: 2.5rem;
    }

    .pricing-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      max-width: 750px;
      margin: 0 auto;
    }

    @media (max-width: 640px) {
      .pricing-grid { grid-template-columns: 1fr; }
    }

    .pricing-card {
      background: var(--bg-alt);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2rem;
      position: relative;
    }

    .pricing-card.featured {
      border-color: var(--accent);
    }

    .pricing-card .badge {
      position: absolute;
      top: -1px;
      right: -1px;
      background: var(--accent);
      color: #000;
      font-family: var(--font-mono);
      font-size: 0.65rem;
      font-weight: 700;
      padding: 0.25rem 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border-radius: 0 var(--radius-sm) 0 var(--radius);
    }

    .pricing-card .tier-name {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
    }

    .pricing-card.featured .tier-name {
      color: var(--accent);
    }

    .pricing-card .price {
      font-size: 2.5rem;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 0.25rem;
    }

    .pricing-card .price .period {
      font-size: 0.9rem;
      font-weight: 400;
      color: var(--text-muted);
    }

    .pricing-card .desc {
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
    }

    .pricing-card ul {
      list-style: none;
      padding: 0;
      margin-bottom: 1.5rem;
    }

    .pricing-card li {
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
      font-size: 0.85rem;
      margin-bottom: 0.6rem;
      color: var(--text);
    }

    .pricing-card li .check {
      color: var(--accent);
      flex-shrink: 0;
      margin-top: 2px;
    }

    /* Stats */
    .stats-section {
      padding: 4rem 0;
      border-top: 1px solid var(--border);
    }

    .stats-section h2 {
      font-size: 1.8rem;
      font-weight: 800;
      margin-bottom: 0.5rem;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: var(--border);
    }

    @media (max-width: 640px) {
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }

    .stat-card {
      background: var(--bg-alt);
      padding: 1.5rem;
    }

    .stat-card .label {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
    }

    .stat-card .value {
      font-size: 1.8rem;
      font-weight: 800;
    }

    .stat-card .value.green { color: var(--accent); }
    .stat-card .value.blue { color: #5c7cfa; }
  </style>

  <section class="signals-page">
    <!-- Hero -->
    <section class="hero-section" id="hero">
      <p style="font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--accent); margin-bottom: 1.5rem;">
        <span class="live-dot"></span>Live Signal Feed Active
      </p>
      <h1>AI-POWERED<br><span class="accent">CRYPTO</span><br>INTELLIGENCE</h1>
      <p>12 verified sources. Machine-classified, backtested, and delivered via <strong>REST API</strong>, <strong>WebSocket</strong>, or <strong>Webhook</strong>. Built for traders who execute.</p>
      <div class="cta-row">
        <a href="/signup" class="btn btn-primary">Start Free →</a>
        <a href="/docs/" class="btn btn-secondary">API Docs ↗</a>
      </div>
    </section>

    <!-- Sources -->
    <section class="sources-section">
      <h2>12 Signal Sources</h2>
      <p class="subtitle">Aggregated, classified, and corroborated in real-time.</p>
      <div class="sources-grid">
        <div class="source-card">
          <div class="icon">TG</div>
          <h3>Telegram Channels</h3>
          <p>WatcherGuru, ZachXBT Investigations, and more. Fastest signal source for hacks and breaking news.</p>
        </div>
        <div class="source-card">
          <div class="icon">🐋</div>
          <h3>Whale Tracking</h3>
          <p>Hyperliquid leaderboard consensus. When top traders pile into the same side, we detect it.</p>
        </div>
        <div class="source-card">
          <div class="icon">📊</div>
          <h3>L/S Ratios</h3>
          <p>Bybit, Binance, and Gate.io positioning data. Detect extreme crowding before reversals.</p>
        </div>
        <div class="source-card">
          <div class="icon">💰</div>
          <h3>Funding & Liquidations</h3>
          <p>Binance funding extremes and real-time liquidation cascades via WebSocket.</p>
        </div>
        <div class="source-card">
          <div class="icon">⛓</div>
          <h3>On-Chain Flows</h3>
          <p>Large ETH/BTC transfers to/from exchanges. Whale deposits = selling pressure.</p>
        </div>
        <div class="source-card">
          <div class="icon">📰</div>
          <h3>News & RSS</h3>
          <p>CoinDesk, Decrypt, CoinTelegraph, Reddit, and Trump's Truth Social. Keyword-filtered for crypto.</p>
        </div>
        <div class="source-card">
          <div class="icon">📈</div>
          <h3>CMC & Macro</h3>
          <p>CoinMarketCap price alerts, trending coins, Fear & Greed Index, DeFi TVL shifts.</p>
        </div>
        <div class="source-card">
          <div class="icon">🎯</div>
          <h3>S/R Levels</h3>
          <p>Real-time support/resistance from Hyperliquid order book. Rejects trades near adverse levels.</p>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="pricing-section" id="pricing">
      <h2>Choose your tier.</h2>
      <p class="subtitle">Start free. Upgrade to Pro for real-time signals.</p>
      <div class="pricing-grid">
        <!-- Free -->
        <div class="pricing-card">
          <div class="tier-name">Free</div>
          <div class="price">$0<span class="period">/mo</span></div>
          <p class="desc">For evaluation and light usage.</p>
          <ul>
            <li><span class="check">✓</span> 60 requests / minute</li>
            <li><span class="check">✓</span> 15-minute signal delay</li>
            <li><span class="check">✓</span> REST API only</li>
            <li><span class="check">✓</span> Limited signal detail</li>
            <li><span class="check">✓</span> Community support</li>
          </ul>
          <a href="/signup" class="btn btn-secondary" style="width: 100%; justify-content: center;">Start Free</a>
        </div>

        <!-- Pro -->
        <div class="pricing-card featured">
          <div class="badge">Popular</div>
          <div class="tier-name">Pro</div>
          <div class="price">$49.99<span class="period">/mo</span></div>
          <p class="desc">For active traders. Everything you need.</p>
          <ul>
            <li><span class="check">✓</span> 600 requests / minute</li>
            <li><span class="check">✓</span> <strong>Real-time</strong> signals — no delay</li>
            <li><span class="check">✓</span> REST + WebSocket + Webhooks</li>
            <li><span class="check">✓</span> Full source &amp; channel detail</li>
            <li><span class="check">✓</span> Entry, SL &amp; TP levels</li>
            <li><span class="check">✓</span> Whale tracking &amp; on-chain flows</li>
            <li><span class="check">✓</span> Corroboration scoring</li>
            <li><span class="check">✓</span> Email support</li>
          </ul>
          <button data-checkout="pro" class="btn btn-primary" style="width: 100%; justify-content: center;">Get Pro</button>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="stats-section">
      <h2>30-Day Track Record</h2>
      <div id="home-stats-widget">
        <div class="stats-grid">
          <div class="stat-card">
            <div class="label">Win Rate</div>
            <div class="value green" id="stat-winrate">—</div>
          </div>
          <div class="stat-card">
            <div class="label">Total Signals</div>
            <div class="value" id="stat-total">—</div>
          </div>
          <div class="stat-card">
            <div class="label">Avg PnL</div>
            <div class="value" id="stat-pnl">—</div>
          </div>
          <div class="stat-card">
            <div class="label">Sources</div>
            <div class="value blue" id="stat-sources">13</div>
          </div>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>

<script>
  const API_BASE = window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost'
    ? 'http://127.0.0.1:8000'
    : 'https://api.n0brains.com';

  async function loadStats() {
    try {
      const resp = await fetch(`${API_BASE}/performance/public`);
      if (!resp.ok) return;
      const data = await resp.json();
      if (data.win_rate != null) document.getElementById('stat-winrate').textContent = (data.win_rate * 100).toFixed(1) + '%';
      if (data.total_signals) document.getElementById('stat-total').textContent = data.total_signals.toLocaleString();
      if (data.avg_pnl != null) document.getElementById('stat-pnl').textContent = (data.avg_pnl >= 0 ? '+' : '') + data.avg_pnl.toFixed(2) + '%';
      if (data.sources) document.getElementById('stat-sources').textContent = data.sources;
    } catch (e) {
      // Stats will show dashes
    }
  }

  // Checkout flow
  function initCheckoutButtons() {
    document.querySelectorAll('[data-checkout]').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var tier = btn.dataset.checkout;
        var apiKey = localStorage.getItem('api_key');
        var token = localStorage.getItem('auth_token');
        if (!apiKey && !token) {
          window.location.href = '/signup?redirect=checkout&tier=' + encodeURIComponent(tier);
          return;
        }
        var headers = { 'Content-Type': 'application/json' };
        if (token) headers['Authorization'] = 'Bearer ' + token;
        else if (apiKey) headers['X-API-Key'] = apiKey;
        fetch(API_BASE + '/billing/checkout', {
          method: 'POST',
          headers: headers,
          body: JSON.stringify({ price_id: tier })
        }).then(function(r) {
          if (r.status === 401) { window.location.href = '/login?redirect=checkout&tier=' + encodeURIComponent(tier); return; }
          return r.json();
        }).then(function(data) {
          if (data && data.url) window.location.href = data.url;
        }).catch(function(err) {
          console.error('Checkout error:', err);
        });
      });
    });

    var params = new URLSearchParams(window.location.search);
    if (params.get('redirect') === 'checkout') {
      var tier = params.get('tier') || 'pro';
      setTimeout(function() { initCheckoutButtons(); /* will trigger on next click */ }, 500);
    }
  }

  loadStats();
  initCheckoutButtons();
</script>
---
import BaseLayout from "../layouts/BaseLayout.astro";
import MonoChip from "../components/MonoChip.astro";

/* ---------- Source taxonomy (lives here so it's editable in one place) ---------- */
/* Ordered by market-signaling significance — strongest directional / timing edge first. */
const sources = [
  { chip: "MP",  title: "Macro Pulse",            desc: "Daily BTC + ETH directional bias. CPI, FOMC, NFP, PPI calendar synthesised with 7d intel signals — regime call, conviction, key levels, invalidation. Sunday weekly 30d deep-dive." },
  { chip: "WH",  title: "Whale Tracking",         desc: "Hyperliquid leaderboard consensus. When top traders pile into the same side, we detect it — and like every signal here, its live track record is published on /proof." },
  { chip: "$",   title: "Funding & Liquidations", desc: "Binance funding extremes and real-time liquidation cascades via WebSocket, plus multi-venue open-interest momentum from Coinglass snapshots. Timing signal for reversals and continuations." },
  { chip: "LIQ", title: "DEX Liquidation Map",    desc: "Our own liquidation map built from real on-chain DEX perp positions (Hyperliquid + GMX) — exact liquidation prices, not estimates. Clusters near price mark magnet / cascade levels; we use them to place stops and targets, not to pick a direction (liquidity predicts volatility, not which way)." },
  { chip: "ETH", title: "On-Chain Flows",         desc: "Large ETH/BTC transfers to/from exchanges via Alchemy + mempool.space WebSockets. Positioning context and capital-concentration tracking — directional whale reads come from Hyperliquid leaderboard positions." },
  { chip: "L/S", title: "L/S Ratios",             desc: "Bybit, Binance, and Gate.io positioning data. Detect extreme crowding before the reversal." },
  { chip: "OPT", title: "Options Flow",           desc: "Deribit options positioning — put/call open-interest ratio, max-pain magnets, and large smart-money block trades on BTC + ETH. Surfaces institutional positioning the crowd-sentiment feeds miss." },
  { chip: "ETF", title: "ETF Flows",              desc: "US spot BTC + ETH ETF daily net flows. Sustained inflows = institutional accumulation, outflows = distribution — the cleanest read on institutional capital, timed right after the US close settles." },
  { chip: "USD", title: "Stablecoin Flows",       desc: "Large USDC mints and USDT Treasury deployments, plus net stablecoin inflow to exchange wallets — fresh dollar liquidity entering crypto and dry powder staged on exchanges (bullish) versus redemptions leaving (bearish). The macro dry-powder signal." },
  { chip: "SR",  title: "S/R Levels",             desc: "Real-time support/resistance from the Hyperliquid order book. Shapes entries and stops; rejects trades near adverse levels." },
  { chip: "TG",  title: "Telegram Channels",      desc: "WatcherGuru, ZachXBT Investigations, and more. Fastest source for hacks and breaking events — high speed, needs corroboration." },
  { chip: "SEC", title: "Security & Exploits",    desc: "Dedicated exploit feed — DefiLlama hacks database (amount, technique, chain) plus rekt.news post-mortems. Structured, first-mover coverage of protocol drains and bridge hacks." },
  { chip: "RSS", title: "News & RSS",             desc: "CoinDesk, Decrypt, CoinTelegraph, Reddit, Tree of Alpha fast-news, and Trump's Truth Social. Keyword-filtered — broader context, slower than the live feeds." },
  { chip: "FC",  title: "Farcaster",              desc: "Crypto-native social monitoring on Farcaster channels — our highest trades-per-signal social source in the live source audit." },
  { chip: "CMC", title: "CMC & Macro",            desc: "CoinMarketCap price alerts, trending coins, Fear & Greed Index, DeFi TVL shifts. Regime context rather than a direct trade trigger." },
  { chip: "LP",  title: "Launchpads & Listings",  desc: "New-token launch detection across Pump.fun (Solana) and major IDO/IEO/launchpad platforms. Catches listings and launches as they go live." },
  { chip: "GOV", title: "Policy & Regulatory",    desc: "Official government and regulatory RSS — SEC, Treasury, congressional, and agency sources monitored for crypto-relevant policy moves — plus congressional stock-trade disclosures. No paid APIs." },
  { chip: "DEX", title: "DEX Screener",           desc: "DexScreener trending and boosted-token feed — early on-chain discovery and token activity. Discovery context, non-directional." },
  { chip: "X",   title: "X / Curated Accounts",   desc: "A budget-capped X (Twitter) feed of research-vetted directional analysts and on-chain trackers — Arthur Hayes, Ki Young Ju, Pentoshi, EmberCN, Lookonchain, WuBlockchain, and more — plus official exchange listing and hack feeds." },
];

const proFeatures = [
  "600 requests / minute",
  "<strong>Real-time</strong> signals — no delay",
  "REST + WebSocket + Webhooks + <strong><a href=\"/docs/mcp\">MCP server</a></strong>",
  "<strong>MCP endpoint</strong> — drop into Claude Desktop, Cursor, Cline (19 tools, Bearer auth)",
  "Full source &amp; channel detail",
  "Whale tracking &amp; on-chain flows",
  "Corroboration scoring",
  "<strong>Macro Pulse</strong> — daily + weekly BTC/ETH bias",
  "<strong>Narrative heatmap</strong> — 1h/4h/24h signal momentum per asset",
  "<strong>Semantic search</strong> — find similar signals by meaning",
  "<strong>Trust scoring</strong> — contract risk + rug probability per token",
  "<strong>Manipulation detection</strong> — coordinated pump + social burst flags",
  "<strong>Wallet DNA</strong> — smart money classification + stealth-accumulation flag",
  "<strong>Market-state</strong> — BTC/ETH consensus snapshot from proven voters",
  "<strong>Liquidation map</strong> — real-position DEX liq levels (HL + GMX)",
  "Email support",
];
const freeFeatures = [
  "60 requests / minute",
  "15-minute signal delay",
  "REST API only",
  "Limited signal detail",
  "Community support",
];

/* ---------- Pipeline visualization data ---------- */
/* Sources collapsed into 5 intake groups; chips reference the taxonomy above. */
const sourceGroups = [
  { name: "Market Structure", chips: ["WH", "$", "LIQ", "L/S", "OPT", "SR"], count: 6, blurb: "whales · funding · liq map · options · order book" },
  { name: "Capital Flows",    chips: ["ETH", "ETF", "USD"],                  count: 3, blurb: "on-chain · ETF · stablecoin mints" },
  { name: "News & Events",    chips: ["TG", "SEC", "RSS", "FC", "X"],        count: 5, blurb: "telegram · exploits · news · farcaster · X" },
  { name: "Macro & Regime",   chips: ["MP", "CMC", "GOV"],                   count: 3, blurb: "macro pulse · fear & greed · policy" },
  { name: "Discovery",        chips: ["LP", "DEX"],                          count: 2, blurb: "launchpads · DEX screener" },
];

const engineLayers = [
  { icon: "∿",  name: "Confidence Decay" },
  { icon: "⚖",  name: "Source Accuracy Feedback" },
  { icon: "🌡", name: "Narrative Heatmap" },
  { icon: "⚠",  name: "Manipulation Detection" },
  { icon: "🧬", name: "Wallet DNA" },
  { icon: "🛡", name: "Trust & Scam Scoring" },
  { icon: "∿∿", name: "Semantic Signal Search" },
  { icon: "ML", name: "ML Outcome Models" },
  { icon: "∮",  name: "Historical Edge" },
  { icon: "≈",  name: "Binned Calibration" },
];

/* Full layer descriptions for the deep-dive accordion (same copy as before). */
const computeLayers = [
  { chip: "∿",  title: "Confidence Decay",         desc: "Signal confidence degrades exponentially with age. A liquidation cascade from 4 hours ago is not the same signal as one from 4 minutes ago. Every score you receive reflects time." },
  { chip: "⚖",  title: "Source Accuracy Feedback", desc: "Source weights self-tune daily via EMA-smoothed win rates from tracked outcomes. Sources that predict correctly get boosted; sources that don't get dampened. Automatically." },
  { chip: "🌡", title: "Narrative Heatmap",         desc: "Rolling 1h / 4h / 24h signal momentum per asset. Narrative strength, velocity, and decay rate. Coordination detection: three independent source types firing the same direction in 5 minutes raises a manipulation flag." },
  { chip: "⚠",  title: "Manipulation Detection",   desc: "Social burst scoring, coordinated pump detection, and liquidation cascade identification. If engagement spikes 5× baseline or four unrelated sources fire the same coin in 10 minutes — you know." },
  { chip: "🧬", title: "Wallet DNA",                desc: "Whale signals tagged with wallet archetype — CEX hot/cold, market maker, MEV bot, institutional, smart trader. 700+ verified labeled addresses across Ethereum, refreshed weekly from Etherscan label cloud and a live top-volume sweep. Stealth-accumulation flag fires when a tracked wallet receives a token in ≥3 fragmented buys totaling ≥$500K within 24h — catches quiet accumulation before it shows up in whale-alert feeds." },
  { chip: "🛡", title: "Trust & Scam Scoring",      desc: "Every new token signal gets a contract risk pass — GoPlus honeypot check, mint function, sell tax, insider concentration, and DexScreener liquidity. Composite rug probability score. Cached 6 hours per token." },
  { chip: "∿∿", title: "Semantic Signal Search",   desc: "BGE-M3 embeddings on every signal, stored in a vector database. Find signals by meaning, not just keywords. Semantic deduplication suppresses near-duplicate events before they reach the feed." },
  { chip: "ML", title: "ML Outcome Models",         desc: "Four models score every directional signal: a logistic win-probability, q10/q50/q90 PnL quantiles, a Cox survival model for median hold time, and an HMM market-regime detector — all trained on tracked forward returns. Sub-10ms inference; degrade gracefully when a model is cold." },
  { chip: "∮",  title: "Historical Edge",           desc: "Each signal's (type × direction × regime) cell carries its empirical track record. When a cell is anti-predictive (n≥30, win rate ≤30%, avg PnL ≤−2%) we attach a labeled paired_inverse advisory — short-term reversal literature, never silently flipping your signal." },
  { chip: "≈",  title: "Binned Calibration",        desc: "Confidence is mapped to empirical win rate per signal type, per raw-confidence bin. Win-rate is non-monotonic and type-dependent (higher confidence means higher win for sentiment, lower for whale) — a single curve can't capture that, so we bin it." },
];
---

<BaseLayout
  title="AI-Powered Crypto Signals API"
  description="Corroborated, scored crypto signals — entry, stop, take — not a feed firehose. Anchored by Macro Pulse, our daily BTC + ETH directional bias. REST API, WebSocket, and Webhooks built for autonomous trading agents. Free tier — no credit card."
  homepage={true}
  ogType="website"
  keywords={["crypto signals API", "bitcoin trading signals", "AI trading agents", "whale tracking", "macro pulse", "crypto intelligence", "autonomous trading", "WebSocket crypto API", "funding rate alerts", "on-chain flows"]}
>
  <style>
    .signals-page { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }

    /* ── Hero ── */
    .hero-section { padding: 6.5rem 0 4.5rem; text-align: center; position: relative; }

    /* Layered backdrop: masked grid + two drifting accent glows.
       Pure gradients (no blur filters), transform-only animation. */
    .hero-bg {
      position: absolute; inset: -30% -10% 0;
      pointer-events: none; z-index: -1; overflow: hidden;
    }
    .hero-bg::before {
      content: ""; position: absolute; inset: 0;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 54px 54px;
      -webkit-mask-image: radial-gradient(ellipse 58% 52% at 50% 42%, #000 0%, transparent 72%);
      mask-image: radial-gradient(ellipse 58% 52% at 50% 42%, #000 0%, transparent 72%);
      opacity: 0.55;
    }
    .hero-glow {
      position: absolute; width: 620px; height: 620px; border-radius: 50%;
      will-change: transform;
    }
    .hero-glow-a {
      left: 50%; top: 8%; margin-left: -480px;
      background: radial-gradient(circle, rgba(0,255,65,0.075), transparent 62%);
      animation: glowDriftA 22s ease-in-out infinite alternate;
    }
    .hero-glow-b {
      left: 50%; top: 22%; margin-left: -80px;
      background: radial-gradient(circle, rgba(255,0,85,0.045), transparent 60%);
      animation: glowDriftB 28s ease-in-out infinite alternate;
    }
    @keyframes glowDriftA { from { transform: translate3d(0,0,0) scale(1); } to { transform: translate3d(70px,40px,0) scale(1.12); } }
    @keyframes glowDriftB { from { transform: translate3d(0,0,0) scale(1.08); } to { transform: translate3d(-60px,-30px,0) scale(0.95); } }

    /* Scroll-linked parallax fade — CSS scroll-driven where supported, static
       otherwise. Duration overrides don't silence scroll timelines, so gate
       explicitly on motion preference. */
    @media (prefers-reduced-motion: no-preference) {
      @supports (animation-timeline: view()) {
        .hero-bg {
          animation: heroBgRecede linear both;
          animation-timeline: view();
          animation-range: exit 0% exit 100%;
        }
        @keyframes heroBgRecede {
          to { transform: translateY(90px); opacity: 0.15; }
        }
      }
    }

    .hero-eyebrow-line {
      font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase;
      letter-spacing: 0.2em; color: var(--accent); margin-bottom: 1.5rem;
      opacity: 0; animation: fadeUp 0.5s var(--ease-out) 0.05s forwards;
      transform: translateY(10px);
    }

    .hero-section h1 {
      font-family: var(--font-display);
      font-size: clamp(3rem, 8vw, 6.5rem);
      font-weight: 400; line-height: 1; letter-spacing: 0.03em;
      margin-bottom: 1rem; color: var(--text-heading);
    }
    /* Per-line mask reveal */
    .hero-section h1 .hl { display: block; overflow: hidden; padding-bottom: 0.04em; }
    .hero-section h1 .hli {
      display: block; transform: translateY(110%);
      animation: lineUp 0.8s var(--ease-out) forwards;
    }
    .hero-section h1 .hl:nth-child(1) .hli { animation-delay: 0.10s; }
    .hero-section h1 .hl:nth-child(2) .hli { animation-delay: 0.22s; }
    .hero-section h1 .hl:nth-child(3) .hli { animation-delay: 0.34s; }
    @keyframes lineUp { to { transform: translateY(0); } }
    .hero-section h1 .accent { color: var(--accent); text-shadow: 0 0 36px var(--accent-glow-strong); }

    .hero-section .lede {
      font-size: 1.1rem; color: var(--text); /* upgraded from --text-muted for AA */
      max-width: 600px; margin: 0 auto 2rem; line-height: 1.6;
      opacity: 0; transform: translateY(12px);
      animation: fadeUp 0.6s var(--ease-out) 0.5s forwards;
    }
    .hero-section .lede strong { color: var(--text-heading); font-weight: 500; }
    .hero-section .cta-row {
      opacity: 0; transform: translateY(12px);
      animation: fadeUp 0.6s var(--ease-out) 0.62s forwards;
    }
    .hero-section .proof-strip {
      opacity: 0; transform: translateY(10px);
      animation: fadeUp 0.6s var(--ease-out) 0.74s forwards;
    }

    .live-dot {
      display: inline-block; width: 8px; height: 8px;
      background: var(--accent); border-radius: 50%;
      margin-right: 8px; animation: pulse 2s infinite;
    }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

    /* Scroll hint — fades once scrolling starts (class toggled by layout JS). */
    .scroll-hint {
      margin-top: 3rem;
      display: flex; flex-direction: column; align-items: center; gap: 2px;
      font-family: var(--font-mono); font-size: 0.6rem;
      letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--text-faint);
      opacity: 0;
      animation: fadeUp 0.6s var(--ease-out) 1.1s forwards;
      transition: opacity 0.4s ease;
    }
    .scroll-hint.hidden { opacity: 0 !important; }
    .sh-chevron {
      color: var(--accent); font-size: 0.9rem;
      animation: chevronBob 1.8s ease-in-out infinite;
    }
    @keyframes chevronBob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(5px); } }

    /* Signal-type ticker — continuous marquee, pauses on hover. */
    .ticker {
      overflow: hidden;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 0.7rem 0;
      margin: 0 -1.5rem;
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
      mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    }
    .ticker-track {
      display: inline-flex;
      white-space: nowrap;
      animation: tickerScroll 48s linear infinite;
      will-change: transform;
    }
    .ticker:hover .ticker-track { animation-play-state: paused; }
    .ticker-seq { display: inline-flex; }
    .ticker-item {
      display: inline-flex; align-items: center; gap: 0.55rem;
      font-family: var(--font-mono); font-size: 0.72rem;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--text-muted);
      padding: 0 1.4rem;
    }
    .ticker-dot {
      width: 5px; height: 5px; border-radius: 50%;
      background: var(--accent); opacity: 0.55; flex-shrink: 0;
    }
    @keyframes tickerScroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
    @media (prefers-reduced-motion: reduce) {
      .ticker-track { animation: none; }
    }

    .cta-row { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.85rem 1.6rem; border-radius: var(--radius-sm);
      font-family: var(--font-mono); font-size: 0.85rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.05em;
      transition: all 0.2s ease; cursor: pointer; border: none;
      position: relative; overflow: hidden;
    }
    .btn:active { transform: translateY(1px); }
    .btn-primary   { background: var(--accent); color: #000; }
    .btn-primary:hover   { background: #fff; }
    /* Sheen sweep on the primary CTA — single pass, transform-only. */
    .btn-primary::after {
      content: ""; position: absolute; inset: 0;
      background: linear-gradient(115deg, transparent 35%, rgba(255,255,255,0.5) 50%, transparent 65%);
      transform: translateX(-130%);
      transition: transform 0.55s ease;
      pointer-events: none;
    }
    .btn-primary:hover::after { transform: translateX(130%); }
    .btn-secondary { background: transparent; color: var(--text); border: 1px solid var(--border); }
    .btn-secondary:hover {
      border-color: var(--accent); color: var(--accent);
      box-shadow: 0 0 18px -6px var(--accent-glow-strong);
    }

    /* Live proof strip — above the fold, always current from /proof */
    .proof-strip {
      display: inline-flex; align-items: center; gap: 0.65rem; flex-wrap: wrap;
      justify-content: center; margin: 2.25rem auto 0; padding: 0.6rem 1.1rem;
      border: 1px solid var(--border); border-radius: var(--radius-sm);
      background: var(--bg-alt); text-decoration: none;
      font-family: var(--font-mono); font-size: 0.8rem; color: var(--text);
      transition: border-color 0.2s ease;
    }
    .proof-strip:hover { border-color: var(--accent); }
    .proof-strip-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--accent); animation: pulse 2s infinite; flex-shrink: 0;
    }
    .proof-strip-text { color: var(--text-heading); }
    .proof-strip-text .ps-pos { color: #4ade80; }
    .proof-strip-cta { color: var(--accent); font-weight: 700; }

    /* Sources */
    .sources-section, .pricing-section, .stats-section, .contrast-section {
      padding: 5rem 0; border-top: none; position: relative;
    }
    /* Gradient hairline dividers — accent shimmer fading at the edges. */
    .sources-section::before, .pricing-section::before,
    .stats-section::before, .contrast-section::before, .honesty-section::before {
      content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, var(--border-accent) 25%, var(--border) 50%, var(--border) 75%, transparent);
    }
    /* Ticker carries its own borders — drop the adjacent section hairline. */
    .ticker + .sources-section::before { display: none; }
    .sources-section h2, .pricing-section h2, .stats-section h2, .contrast-section h2 {
      font-family: var(--font-display);
      font-size: 2.4rem; font-weight: 400;
      color: var(--text-heading); letter-spacing: 0.04em;
      margin-bottom: 0.5rem;
    }
    .pricing-section h2 { text-align: center; }
    .sources-section .subtitle, .pricing-section .subtitle {
      color: var(--text); margin-bottom: 2rem;
    }
    .pricing-section .subtitle { text-align: center; margin-bottom: 2.5rem; }

    .source-card {
      background: var(--bg-alt); padding: 1.5rem;
      transition: background 0.2s ease;
      position: relative;
    }
    /* Cursor spotlight — radial accent follows pointer (set via --mx/--my). */
    .source-card::after {
      content: ""; position: absolute; inset: 0; opacity: 0;
      background: radial-gradient(240px circle at var(--mx, 50%) var(--my, 50%), var(--accent-glow), transparent 70%);
      transition: opacity 0.25s ease;
      pointer-events: none;
    }
    .source-card:hover::after { opacity: 1; }
    .source-card:hover { background: var(--bg-hover); }
    .source-card .chip-row { margin-bottom: 0.75rem; }
    .source-card h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.25rem; color: var(--text-heading); }
    .source-card p  { font-size: 0.85rem; color: var(--text); line-height: 1.55; }

    /* ── The Pipeline ── */
    .pipeline {
      display: grid;
      grid-template-columns: 1fr 52px 1.15fr 52px 1fr;
      align-items: stretch;
      margin-top: 2.5rem;
    }
    .pl-stage { display: flex; flex-direction: column; gap: 0.8rem; min-width: 0; }
    .pl-stage-label {
      font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.25em; color: var(--accent);
      padding-bottom: 0.6rem; border-bottom: 1px solid var(--border);
      display: flex; justify-content: space-between; align-items: baseline;
    }
    .pl-stage-sub { color: var(--text-faint); letter-spacing: 0.1em; font-weight: 400; }

    .pl-node {
      border: 1px solid var(--border); border-radius: var(--radius-sm);
      background: var(--bg-alt); padding: 0.8rem 0.95rem;
      transition: border-color 0.2s ease, background 0.2s ease;
    }
    .pl-node:hover { border-color: var(--border-accent); background: var(--bg-hover); }
    .pl-node-head { display: flex; justify-content: space-between; align-items: baseline; }
    .pl-node-name { font-size: 0.85rem; font-weight: 600; color: var(--text-heading); }
    .pl-node-count { font-family: var(--font-mono); font-size: 0.62rem; color: var(--accent); }
    .pl-node-chips { display: flex; flex-wrap: wrap; gap: 4px; margin: 0.5rem 0 0.4rem; }
    .pl-node-blurb {
      font-family: var(--font-mono); font-size: 0.6rem;
      color: var(--text-muted); letter-spacing: 0.04em;
    }

    /* Flow connectors — dashes streaming toward the next stage. */
    .pl-flow {
      display: flex; flex-direction: column; justify-content: center;
      gap: 22px; padding: 0 6px;
    }
    .pl-flow-line { position: relative; height: 2px; background: var(--border); overflow: hidden; }
    .pl-flow-line::after {
      content: ""; position: absolute; inset: 0;
      background: repeating-linear-gradient(90deg, transparent 0 12px, var(--accent) 12px 20px);
      animation: flowDash 1.1s linear infinite;
      opacity: 0.85;
    }
    @keyframes flowDash { from { transform: translateX(-20px); } to { transform: translateX(0); } }

    /* The engine */
    .pl-core {
      position: relative; flex: 1; overflow: hidden;
      border: 1px solid var(--border-accent); border-radius: var(--radius);
      background: var(--bg-card);
      box-shadow: 0 0 44px -18px var(--accent-glow-strong);
      padding-bottom: 0.4rem;
    }
    .pl-core-head {
      display: flex; align-items: center; gap: 8px;
      font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.2em; color: var(--accent);
      padding: 0.85rem 1rem; border-bottom: 1px solid var(--border);
    }
    .pl-core-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--accent); animation: pulse 2s infinite;
    }
    .pl-layers { list-style: none; padding: 0.5rem 0; margin: 0; }
    .pl-layer {
      display: flex; align-items: center; gap: 0.65rem;
      padding: 0.4rem 1rem; border-left: 2px solid transparent;
      animation: layerPulse 6s ease-in-out infinite;
      animation-delay: calc(var(--li) * 0.6s);
    }
    @keyframes layerPulse {
      0%, 9%, 100% { background: transparent; border-left-color: transparent; }

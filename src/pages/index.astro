  <script>
    // Live proof strip: same /proof endpoint as the scoreboard. Keeps the
    // above-the-fold claim honest and current — never asserts more than /proof shows.
    (() => {
      const strip = document.getElementById("proof-strip");
      if (!strip) return;
      const textEl = strip.querySelector(".proof-strip-text");
      fetch("https://api.n0brains.com/proof", { cache: "no-store" })
        .then((r) => r.json())
        .then((data) => {
          if (!data || !Array.isArray(data.types)) throw new Error("no types");
          const proven = data.types.filter((t) => t.tradeable);
          if (!proven.length) {
            textEl.textContent = "live win-rate scoreboard";
            return;
          }
          const parts = proven
            .slice(0, 3)
            .map((t) => `${t.signal_type} <span class="ps-pos">${(Number(t.win_rate) * 100).toFixed(1)}%</span>`);
          const n = proven.length;
          textEl.innerHTML =
            `${n} signal type${n === 1 ? "" : "s"} forward-return proven · ` + parts.join(" · ");
        })
        .catch(() => {
          // On failure, fall back to a static honest label (no invented numbers).
          textEl.textContent = "live win-rate scoreboard";
        });
    })();

    // Pipeline output card: cycle through example payloads so the flow reads
    // as alive. Clearly labeled "example payload" — not live data.
    (() => {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      const card = document.getElementById("pl-signal");
      if (!card) return;
      const sigs = [
        { type: "hack",    asset: "ETH", dir: "bearish", conf: "0.87", conv: "strong",  srcs: "3 independent sources" },
        { type: "listing", asset: "SOL", dir: "bullish", conf: "0.74", conv: "notable", srcs: "2 independent sources" },
        { type: "funding", asset: "BTC", dir: "bullish", conf: "0.69", conv: "watch",   srcs: "funding extreme + L/S" },
        { type: "sentiment", asset: "ETH", dir: "bearish", conf: "0.78", conv: "notable", srcs: "burst-scored, 4 sources" },
      ];
      const $ = (id: string) => document.getElementById(id)!;
      let i = 0;
      setInterval(() => {
        i = (i + 1) % sigs.length;
        card.classList.add("swap");
        setTimeout(() => {
          const s = sigs[i];
          $("ps-type").textContent = s.type;
          $("ps-asset").textContent = s.asset;
          const d = $("ps-dir");
          d.textContent = (s.dir === "bullish" ? "▲ " : "▼ ") + s.dir;
          d.className = "dir-" + s.dir;
          $("ps-conf").innerHTML = `${s.conf} <span class="ps-note">calibrated</span>`;
          $("ps-conv").textContent = s.conv;
          $("ps-srcs").textContent = s.srcs;
          card.classList.remove("swap");
        }, 360);
      }, 4200);
    })();
  </script>

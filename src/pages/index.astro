---
import BaseLayout from "../layouts/BaseLayout.astro";
import MonoChip from "../components/MonoChip.astro";

/* ---------- Source taxonomy (lives here so it's editable in one place) ---------- */
/* Ordered by market-signaling significance — strongest directional / timing edge first. */
const sources = [
  { chip: "MP",  title: "Macro Pulse",            desc: "Daily BTC + ETH directional bias. CPI, FOMC, NFP, PPI calendar synthesised with 7d intel signals — regime call, conviction, key levels, invalidation. Sunday weekly 30d deep-dive." },
  { chip: "WH",  title: "Whale Tracking",         desc: "Hyperliquid leaderboard consensus. When top traders pile into the same side, we detect it — the highest-conviction directional read." },
  { chip: "$",   title: "Funding & Liquidations", desc: "Binance funding extremes and real-time liquidation cascades via WebSocket. The cleanest timing signal for reversals and continuations." },
  { chip: "ETH", title: "On-Chain Flows",         desc: "Large ETH/BTC transfers to/from exchanges via Alchemy + mempool.space WebSockets. Inflows lead selling pressure; outflows lead accumulation." },
  { chip: "L/S", title: "L/S Ratios",             desc: "Bybit, Binance, and Gate.io positioning data. Detect extreme crowding before the reversal." },
  { chip: "OPT", title: "Options Flow",           desc: "Deribit options positioning — put/call open-interest ratio, max-pain magnets, and large smart-money block trades on BTC + ETH. Surfaces institutional positioning the crowd-sentiment feeds miss." },
  { chip: "ETF", title: "ETF Flows",              desc: "US spot BTC + ETH ETF daily net flows. Sustained inflows = institutional accumulation, outflows = distribution — the cleanest read on institutional capital, timed right after the US close settles." },
  { chip: "USD", title: "Stablecoin Flows",       desc: "Large USDC mints and USDT Treasury deployments — fresh dollar liquidity entering crypto (bullish) versus redemptions leaving (bearish). The macro dry-powder signal." },
  { chip: "SR",  title: "S/R Levels",             desc: "Real-time support/resistance from the Hyperliquid order book. Shapes entries and stops; rejects trades near adverse levels." },
  { chip: "TG",  title: "Telegram Channels",      desc: "WatcherGuru, ZachXBT Investigations, and more. Fastest source for hacks and breaking events — high speed, needs corroboration." },
  { chip: "SEC", title: "Security & Exploits",    desc: "Dedicated exploit feed — DefiLlama hacks database (amount, technique, chain) plus rekt.news post-mortems. Structured, first-mover coverage of protocol drains and bridge hacks." },
  { chip: "RSS", title: "News & RSS",             desc: "CoinDesk, Decrypt, CoinTelegraph, Reddit, and Trump's Truth Social. Keyword-filtered — broader context, slower than the live feeds." },
  { chip: "CMC", title: "CMC & Macro",            desc: "CoinMarketCap price alerts, trending coins, Fear & Greed Index, DeFi TVL shifts. Regime context rather than a direct trade trigger." },
  { chip: "LP",  title: "Launchpads & Listings",  desc: "New-token launch detection across Pump.fun (Solana) and major IDO/IEO/launchpad platforms. Catches listings and launches as they go live." },
  { chip: "GOV", title: "Policy & Regulatory",    desc: "Official government and regulatory RSS — SEC, Treasury, congressional, and agency sources monitored for crypto-relevant policy moves. No paid APIs." },
  { chip: "DEX", title: "DEX Screener",           desc: "DexScreener trending and boosted-token feed — early on-chain activity and momentum on decentralized exchanges. Enrichment context, lightly weighted." },
  { chip: "X",   title: "X / Curated Accounts",   desc: "A budget-capped X (Twitter) feed of vetted on-chain trackers, exchanges, and analysts — Lookonchain, Arkham, WuBlockchain, official exchange handles, and more." },
];

const proFeatures = [
  "600 requests / minute",
  "<strong>Real-time</strong> signals — no delay",
  "REST + WebSocket + Webhooks + <strong><a href=\"/docs/mcp\">MCP server</a></strong>",
  "<strong>MCP endpoint</strong> — drop into Claude Desktop, Cursor, Cline (19 tools, Bearer auth)",
  "Full source &amp; channel detail",
  "Whale tracking &amp; on-chain flows",
  "Corroboration scoring",
  "<strong>Macro Pulse</strong> — daily + weekly BTC/ETH bias",
  "<strong>Narrative heatmap</strong> — 1h/4h/24h signal momentum per asset",
  "<strong>Semantic search</strong> — find similar signals by meaning",
  "<strong>Trust scoring</strong> — contract risk + rug probability per token",
  "<strong>Manipulation detection</strong> — coordinated pump + social burst flags",
  "<strong>Wallet DNA</strong> — smart money classification + stealth-accumulation flag",
  "Email support",
];
const freeFeatures = [
  "60 requests / minute",
  "15-minute signal delay",
  "REST API only",
  "Limited signal detail",
  "Community support",
];

// "What we compute" cards are inline below; keep this in sync if you add/remove
// a layer. Drives the odd-count filler tile (same logic as the sources grid).
const computeLayerCount = 10;
---

<BaseLayout
  title="AI-Powered Crypto Signals API"
  description="Corroborated, scored crypto signals — entry, stop, take — not a feed firehose. Anchored by Macro Pulse, our daily BTC + ETH directional bias. REST API, WebSocket, and Webhooks built for autonomous trading agents. Free tier — no credit card."
  homepage={true}
  ogType="website"
  keywords={["crypto signals API", "bitcoin trading signals", "AI trading agents", "whale tracking", "macro pulse", "crypto intelligence", "autonomous trading", "WebSocket crypto API", "funding rate alerts", "on-chain flows"]}
>
  <style>
    .signals-page { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }

    .hero-section { padding: 6rem 0 4rem; text-align: center; }
    .hero-section h1 {
      font-family: var(--font-display);
      font-size: clamp(3rem, 8vw, 5.5rem);
      font-weight: 400; line-height: 1; letter-spacing: 0.03em;
      margin-bottom: 1rem; color: var(--text-heading);
    }
    .hero-section h1 .accent { color: var(--accent); }
    .hero-section .lede {
      font-size: 1.1rem; color: var(--text); /* upgraded from --text-muted for AA */
      max-width: 600px; margin: 0 auto 2rem; line-height: 1.6;
    }
    .hero-section .lede strong { color: var(--text-heading); font-weight: 500; }

    .live-dot {
      display: inline-block; width: 8px; height: 8px;
      background: var(--accent); border-radius: 50%;
      margin-right: 8px; animation: pulse 2s infinite;
    }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

    .cta-row { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.85rem 1.6rem; border-radius: var(--radius-sm);
      font-family: var(--font-mono); font-size: 0.85rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.05em;
      transition: all 0.2s ease; cursor: pointer; border: none;
    }
    .btn-primary   { background: var(--accent); color: #000; }
    .btn-primary:hover   { background: #fff; }
    .btn-secondary { background: transparent; color: var(--text); border: 1px solid var(--border); }
    .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

    /* Live proof strip — above the fold, always current from /proof */
    .proof-strip {
      display: inline-flex; align-items: center; gap: 0.65rem; flex-wrap: wrap;
      justify-content: center; margin: 2.25rem auto 0; padding: 0.6rem 1.1rem;
      border: 1px solid var(--border); border-radius: var(--radius-sm);
      background: var(--bg-alt); text-decoration: none;
      font-family: var(--font-mono); font-size: 0.8rem; color: var(--text);
      transition: border-color 0.2s ease;
    }
    .proof-strip:hover { border-color: var(--accent); }
    .proof-strip-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--accent); animation: pulse 2s infinite; flex-shrink: 0;
    }
    .proof-strip-text { color: var(--text-heading); }
    .proof-strip-text .ps-pos { color: #4ade80; }
    .proof-strip-cta { color: var(--accent); font-weight: 700; }

    /* Sources */
    .sources-section, .pricing-section, .stats-section, .contrast-section {
      padding: 4rem 0; border-top: 1px solid var(--border);
    }
    .sources-section h2, .pricing-section h2, .stats-section h2, .contrast-section h2 {
      font-family: var(--font-display);
      font-size: 2.4rem; font-weight: 400;
      color: var(--text-heading); letter-spacing: 0.04em;
      margin-bottom: 0.5rem;
    }
    .pricing-section h2 { text-align: center; }
    .sources-section .subtitle, .pricing-section .subtitle {
      color: var(--text); margin-bottom: 2rem;
    }
    .pricing-section .subtitle { text-align: center; margin-bottom: 2.5rem; }

    .sources-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1px; background: var(--border);
    }
    .source-card {
      background: var(--bg-alt); padding: 1.5rem;
      transition: background 0.2s ease;
    }
    /* Filler tile shown only when the source count is odd, so the 2-col grid
       never ends on a dead cell. Links to the docs instead of empty space. */
    .source-card.source-filler {
      display: flex; flex-direction: column; justify-content: center;
      align-items: center; text-align: center; text-decoration: none;
      color: var(--text); gap: 0.3rem;
    }
    .source-card.source-filler:hover { background: var(--bg-hover); }
    .source-card.source-filler .filler-arrow {
      font-size: 1.1rem; color: var(--accent); font-weight: 700;
    }
    .source-card.source-filler .filler-sub { font-size: 0.8rem; opacity: 0.7; }
    .source-card:hover { background: var(--bg-hover); }
    .source-card .chip-row { margin-bottom: 0.75rem; }
    .source-card h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.25rem; color: var(--text-heading); }
    .source-card p  { font-size: 0.85rem; color: var(--text); line-height: 1.55; }

    /* Contrast */
    .contrast-section h2 { text-align: center; margin-bottom: 2.5rem; }
    .contrast-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 1px;
      background: var(--border); border: 1px solid var(--border);
      max-width: 820px; margin: 0 auto;
    }
    @media (max-width: 640px) { .contrast-grid { grid-template-columns: 1fr; } }
    .contrast-col { background: var(--bg-alt); padding: 1.75rem; }
    .contrast-col.us { background: var(--bg-hover); }
    .contrast-col .ctag {
      font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.18em;
      margin-bottom: 0.75rem; color: var(--text-muted);
    }
    .contrast-col.us .ctag { color: var(--accent); }
    .contrast-col p { font-size: 0.92rem; line-height: 1.6; color: var(--text); }
    .contrast-col.us p { color: var(--text-heading); }

    /* Pricing */
    .pricing-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 1.5rem; max-width: 750px; margin: 0 auto;
    }
    @media (max-width: 640px) { .pricing-grid { grid-template-columns: 1fr; } }

    .pricing-card {
      background: var(--bg-alt);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2rem; position: relative;
    }
    .pricing-card.featured { border-color: var(--accent); }
    .pricing-card .badge {
      position: absolute; top: -1px; right: -1px;
      background: var(--accent); color: #000;
      font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700;
      padding: 0.25rem 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;
      border-radius: 0 var(--radius-sm) 0 var(--radius);
    }
    .pricing-card .tier-name {
      font-family: var(--font-mono); font-size: 0.7rem;
      text-transform: uppercase; letter-spacing: 0.15em;
      color: var(--text); margin-bottom: 0.5rem;
    }
    .pricing-card.featured .tier-name { color: var(--accent); }
    .pricing-card .price {
      font-size: 2.5rem; font-weight: 800; line-height: 1; margin-bottom: 0.25rem;
      color: var(--text-heading);
    }
    .pricing-card .price .period { font-size: 0.9rem; font-weight: 400; color: var(--text); }
    .pricing-card .desc { font-size: 0.9rem; color: var(--text); margin-bottom: 1.5rem; }
    .pricing-card ul { list-style: none; padding: 0; margin-bottom: 1.5rem; }
    .pricing-card li {
      display: flex; align-items: flex-start; gap: 0.5rem;
      font-size: 0.9rem; margin-bottom: 0.6rem; color: var(--text);
    }
    .pricing-card li .check { color: var(--accent); flex-shrink: 0; margin-top: 2px; }
    .payg-note {
      text-align: center; max-width: 640px; margin: 2rem auto 0;
      font-size: 0.9rem; color: var(--text-muted); line-height: 1.6;
    }
    .payg-note strong { color: var(--text-heading); }
    .payg-note a { color: var(--accent); }

    /* Honesty comparison */
    .honesty-section { padding: 4rem 0; border-top: 1px solid var(--border); }
    .honesty-section h2 {
      font-family: var(--font-display); font-size: 2.4rem; font-weight: 400;
      color: var(--text-heading); letter-spacing: 0.04em; text-align: center;
      margin-bottom: 0.5rem;
    }
    .honesty-sub { text-align: center; max-width: 640px; margin: 0 auto 2.5rem; }
    .honesty-wrap { overflow-x: auto; max-width: 900px; margin: 0 auto; }
    .honesty-table {
      width: 100%; border-collapse: collapse; font-size: 0.9rem;
      border: 1px solid var(--border);
    }
    .honesty-table th, .honesty-table td {
      padding: 0.85rem 1rem; text-align: left; border-bottom: 1px solid var(--border);
      border-right: 1px solid var(--border);
    }
    .honesty-table thead th {
      font-family: var(--font-mono); font-size: 0.72rem; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--text-muted); background: var(--bg-alt);
    }
    .honesty-table td { color: var(--text); }
    .honesty-table td:first-child { color: var(--text-heading); font-weight: 500; }
    .honesty-table .us-col { background: var(--bg-hover); }
    .honesty-table thead .us-col { color: var(--accent); }
    .honesty-table .yes { color: #4ade80; font-weight: 600; }
    .honesty-table .yes a { color: #4ade80; text-decoration: underline; }
    .honesty-table .no { color: var(--text-muted); }
    .honesty-foot {
      max-width: 760px; margin: 1.5rem auto 0; text-align: center;
      font-size: 0.78rem; color: var(--text-muted); line-height: 1.5;
    }
    .honesty-foot strong { color: var(--text); }

  </style>

  <div class="signals-page">
    <!-- Hero -->
    <section class="hero-section" id="hero">
      <p style="font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--accent); margin-bottom: 1.5rem;">
        <span class="live-dot"></span>Live Signal Feed Active
      </p>
      <h1>SIGNALS THAT<br /><span class="accent">PROVE</span><br />THEIR EDGE</h1>
      <p class="lede">
        We measure every signal type against real post-signal price action and flag a call <code>trade_signal</code> only when that type's <a href="/proof">live forward-return record both beats buy-and-hold and is profitable on its own (95% CI lower bound above zero)</a> — and we publicly demote our own weak signals. Every event is machine-classified, cross-corroborated, and scored with a <strong>calibrated</strong> confidence, anchored by <strong>Macro Pulse</strong>, our daily BTC + ETH directional bias. Pipe it into your agent or alert system via <strong>REST API</strong>, <strong>WebSocket</strong>, <strong>Webhook</strong>, <strong>MCP</strong>, or pay-per-call <strong>x402</strong>.
      </p>
      <div class="cta-row">
        <a href="/signup" class="btn btn-primary">Start Free →</a>
        <a href="/proof" class="btn btn-secondary">See the proof ↗</a>
        <a href="/docs/" class="btn btn-secondary">API Docs ↗</a>
      </div>

      <!-- Live proof strip — pulls the same /proof endpoint the scoreboard renders,
           so the above-the-fold claim can never exceed what we actually prove. -->
      <a id="proof-strip" class="proof-strip" href="/proof" aria-label="See the live win-rate scoreboard">
        <span class="proof-strip-dot"></span>
        <span class="proof-strip-text">loading live win-rate…</span>
        <span class="proof-strip-cta">live scoreboard →</span>
      </a>
    </section>

    <!-- What we watch -->
    <section class="sources-section">
      <h2>What we watch</h2>
      <p class="subtitle">Telegram, whales (ETH + BTC + SOL), positioning, funding, on-chain flows, news, macro calendar, order-book levels — every event classified, cross-corroborated, and scored in real-time, then anchored to the weekly Macro Pulse bias. Over 30 data sources. One API.</p>
      <div class="sources-grid">
        {sources.map((s) => (
          <div class="source-card">
            <div class="chip-row"><MonoChip text={s.chip} /></div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
        {sources.length % 2 === 1 && (
          <a class="source-card source-filler" href="/docs">
            <span class="filler-arrow">See the docs →</span>
            <span class="filler-sub">full source list &amp; data model</span>
          </a>
        )}
      </div>
    </section>

    <!-- Intelligence Layers -->
    <section class="sources-section">
      <h2>What we compute</h2>
      <p class="subtitle">Raw signals are just the start. Ten intelligence layers run on every event before it reaches your API key.</p>
      <div class="sources-grid">
        <div class="source-card">
          <div class="chip-row"><MonoChip text="∿" /></div>
          <h3>Confidence Decay</h3>
          <p>Signal confidence degrades exponentially with age. A liquidation cascade from 4 hours ago is not the same signal as one from 4 minutes ago. Every score you receive reflects time.</p>
        </div>
        <div class="source-card">
          <div class="chip-row"><MonoChip text="⚖" /></div>
          <h3>Source Accuracy Feedback</h3>
          <p>Source weights self-tune daily via EMA-smoothed win rates from tracked outcomes. Sources that predict correctly get boosted; sources that don't get dampened. Automatically.</p>
        </div>
        <div class="source-card">
          <div class="chip-row"><MonoChip text="🌡" /></div>
          <h3>Narrative Heatmap</h3>
          <p>Rolling 1h / 4h / 24h signal momentum per asset. Narrative strength, velocity, and decay rate. Coordination detection: three independent source types firing the same direction in 5 minutes raises a manipulation flag.</p>
        </div>
        <div class="source-card">
          <div class="chip-row"><MonoChip text="⚠" /></div>
          <h3>Manipulation Detection</h3>
          <p>Social burst scoring, coordinated pump detection, and liquidation cascade identification. If engagement spikes 5× baseline or four unrelated sources fire the same coin in 10 minutes — you know.</p>
        </div>
        <div class="source-card">
          <div class="chip-row"><MonoChip text="🧬" /></div>
          <h3>Wallet DNA</h3>
          <p>Whale signals tagged with wallet archetype — CEX hot/cold, market maker, MEV bot, institutional, smart trader. 700+ verified labeled addresses across Ethereum, refreshed weekly from Etherscan label cloud and a live top-volume sweep. Stealth-accumulation flag fires when a tracked wallet receives a token in ≥3 fragmented buys totaling ≥$500K within 24h — catches quiet accumulation before it shows up in whale-alert feeds.</p>
        </div>
        <div class="source-card">
          <div class="chip-row"><MonoChip text="🛡" /></div>
          <h3>Trust &amp; Scam Scoring</h3>
          <p>Every new token signal gets a contract risk pass — GoPlus honeypot check, mint function, sell tax, insider concentration, and DexScreener liquidity. Composite rug probability score. Cached 6 hours per token.</p>
        </div>
        <div class="source-card">
          <div class="chip-row"><MonoChip text="∿∿" /></div>
          <h3>Semantic Signal Search</h3>
          <p>BGE-M3 embeddings on every signal, stored in a vector database. Find signals by meaning, not just keywords. Semantic deduplication suppresses near-duplicate events before they reach the feed.</p>
        </div>
        <div class="source-card">
          <div class="chip-row"><MonoChip text="ML" /></div>
          <h3>ML Outcome Models</h3>
          <p>Four models score every directional signal: a logistic win-probability, q10/q50/q90 PnL quantiles, a Cox survival model for median hold time, and an HMM market-regime detector — all trained on tracked forward returns. Sub-10ms inference; degrade gracefully when a model is cold.</p>
        </div>
        <div class="source-card">
          <div class="chip-row"><MonoChip text="∮" /></div>
          <h3>Historical Edge</h3>
          <p>Each signal's (type × direction × regime) cell carries its empirical track record. When a cell is anti-predictive (n≥30, win rate ≤30%, avg PnL ≤−2%) we attach a labeled <code>paired_inverse</code> advisory — short-term reversal literature, never silently flipping your signal.</p>
        </div>
        <div class="source-card">
          <div class="chip-row"><MonoChip text="≈" /></div>
          <h3>Binned Calibration</h3>
          <p>Confidence is mapped to empirical win rate per signal type, per raw-confidence bin. Win-rate is non-monotonic and type-dependent (higher confidence means higher win for sentiment, lower for whale) — a single curve can't capture that, so we bin it.</p>
        </div>
        {computeLayerCount % 2 === 1 && (
          <a class="source-card source-filler" href="/docs">
            <span class="filler-arrow">See the docs →</span>
            <span class="filler-sub">how each layer scores a signal</span>
          </a>
        )}
      </div>
    </section>

    <!-- vs. the dashboards -->
    <section class="contrast-section">
      <h2>One API. Not twelve.</h2>
      <div class="contrast-grid">
        <div class="contrast-col others">
          <div class="ctag">Others</div>
          <p>Whale data from one API. Funding from another. News from three more. L/S ratios, on-chain flows, options positioning, ETF flows, macro calendar — each a separate subscription, separate key, separate rate limit. You duct-tape them together and still do all the synthesis yourself.</p>
        </div>
        <div class="contrast-col us">
          <div class="ctag">n0brains</div>
          <p>All of it — one endpoint. Telegram, whales, funding, liquidations, on-chain, L/S ratios, options flow, ETF + stablecoin flows, news, security feeds, macro calendar — fused, corroborated, and scored. Plus narrative momentum, manipulation detection, wallet DNA, token trust scoring, and semantic signal search baked in. One API key. One bill. Raw classified intel your agent can filter, route, and act on directly.</p>
        </div>
      </div>
    </section>

    <!-- We publish our win-rate. They don't. (honesty comparison) -->
    <section class="honesty-section">
      <h2>We publish our win-rate. They don't.</h2>
      <p class="subtitle honesty-sub">
        Most of the industry asks you to trust a backtest you can't audit. We measure
        every signal type on real prices, publish the result, and demote our own weak
        signals in the open. The edge here is honesty — not a bigger pile of data.
      </p>
      <div class="honesty-wrap">
        <table class="honesty-table">
          <thead>
            <tr>
              <th></th>
              <th class="us-col">n0brains</th>
              <th>Nansen</th>
              <th>Glassnode</th>
              <th>Typical TG "call" group</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Publishes live per-signal win-rate</td>
              <td class="us-col"><span class="yes">Yes — <a href="/proof">/proof</a></span></td>
              <td><span class="no">No</span></td>
              <td><span class="no">No</span></td>
              <td><span class="no">No</span></td>
            </tr>
            <tr>
              <td>Demotes its own weak signals publicly</td>
              <td class="us-col"><span class="yes">Yes</span></td>
              <td><span class="no">No</span></td>
              <td><span class="no">No</span></td>
              <td><span class="no">Never</span></td>
            </tr>
            <tr>
              <td>Forward-return vs buy-and-hold, with 95% CI</td>
              <td class="us-col"><span class="yes">Yes</span></td>
              <td><span class="no">No</span></td>
              <td><span class="no">No</span></td>
              <td><span class="no">No</span></td>
            </tr>
            <tr>
              <td>Price</td>
              <td class="us-col"><span class="yes">$19.99/mo</span></td>
              <td>$49/mo</td>
              <td>$999/mo (Pro)</td>
              <td>"lifetime $$$"</td>
            </tr>
          </tbody>

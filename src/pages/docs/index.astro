<BaseLayout title="n0brains Documentation" description="n0brains documentation — REST API, MCP server, CLI, x402 pay-per-call, endpoints, authentication, rate limits, and response formats.">
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebAPI",
    "name": "n0brains API",
    "description": "REST + WebSocket + Webhook + MCP server API delivering scored market-intelligence signals across crypto AND the tokenized stock market — equities, indices, metals and commodities (NVDA, TSLA, S&P 500, gold, oil) on Hyperliquid HIP-3. Whales (Hyperliquid positions), funding, on-chain liquidation maps, options + ETF + stablecoin flows, macro bias, cross-asset spillover (how the stock market moves crypto and back), security feeds, X (Twitter) curated feed, and more. Each signal includes direction, urgency, confidence, asset class, and quality band. MCP endpoint drops into Claude Desktop, Cursor, Cline. Analytical data only, not financial advice.",
    "url": "https://n0brains.com/docs/",
    "documentation": "https://n0brains.com/docs/",
    "termsOfService": "https://n0brains.com/terms",
    "provider": {
      "@type": "Organization",
      "name": "n0brains",
      "url": "https://n0brains.com"
    },
    "offers": [
      { "@type": "Offer", "price": "0", "priceCurrency": "USD", "description": "Free tier — 60 req/min, REST only, 15-min delay" },
      { "@type": "Offer", "price": "39.99", "priceCurrency": "USD", "description": "Pro tier — 600 req/min, real-time, REST + WebSocket + Webhooks + MCP server" }
    ],
    "potentialAction": {

}, null, 2);

const loginResponse = JSON.stringify({
  token: "eyJhbGciOiJIUzI1NiIs...",
  tier: "free",
  api_keys: [{id: 1, prefix: "intel_sk_a1b2", name: "default", created_at: 1778555605}]
}, null, 2);

const webhookCreateResponse = JSON.stringify({
  id: 1,
  url: "https://your-server.com/hooks/n0brains",
  secret: "a1b2c3d4...",
  events: "signal.created",
  note: "Use X-Intel-Signature header to verify deliveries. Secret is shown only once."
}, null, 2);

const webhookDeliveryResponse = JSON.stringify({
  event: "signal.created",
  timestamp: 1778555605,
  data: {
    id: 195,
    asset: "BTC",
    signal_type: "whale",
    direction: "bullish",
    urgency: "high",
    summary: "Strategy buys 535 BTC for $43M",
    confidence: 0.95,
    score: 1.42,
    entry_price: 81262.50,

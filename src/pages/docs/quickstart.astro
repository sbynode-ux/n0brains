<script>
  // ── copy buttons: read from the sibling <pre> so personalization applies ──
  document.querySelectorAll(".copy-btn").forEach((b) => {
    b.addEventListener("click", async () => {
      const pre = b.parentElement?.querySelector("pre");
      if (!pre) return;
      try {
        await navigator.clipboard.writeText(pre.innerText);
        const orig = b.textContent;
        b.textContent = "copied";
        setTimeout(() => { b.textContent = orig; }, 1500);
      } catch { /* ignore */ }
    });
  });

  // ── key personalizer: swap YOUR_API_KEY in every snippet, client-side only ──
  const PLACEHOLDER = "YOUR_API_KEY";
  const codes = Array.from(document.querySelectorAll(".prompt-block pre code"));
  const originals = new Map(codes.map((c) => [c, c.textContent || ""]));
  const input = document.getElementById("qs-key");
  const note = document.getElementById("qs-keynote");
  const tocKey = document.getElementById("qs-toc-key");

  function applyKey() {
    const k = (input?.value || "").trim();
    let n = 0;
    for (const c of codes) {
      const orig = originals.get(c) || "";
      if (!orig.includes(PLACEHOLDER)) continue;
      c.textContent = k ? orig.replaceAll(PLACEHOLDER, k) : orig;
      n++;
    }
    if (note) {
      if (k) {
        note.textContent = `✓ key applied to ${n} snippets — stays in this tab, never sent or saved.`;
        note.classList.add("applied");
      } else {
        note.textContent = "Stays in this tab — never sent anywhere, never saved.";
        note.classList.remove("applied");
      }
    }
    if (tocKey) tocKey.hidden = !k;
  }
  document.getElementById("qs-apply")?.addEventListener("click", applyKey);
  input?.addEventListener("keydown", (e) => { if (e.key === "Enter") applyKey(); });

  // ── scrollspy for the side TOC ──
  const tocLinks = new Map(
    Array.from(document.querySelectorAll(".qs-toc a[data-toc]")).map((a) => [a.getAttribute("data-toc"), a]),
  );
  const targets = Array.from(tocLinks.keys())
    .map((id) => document.getElementById(id))
    .filter(Boolean);
  let activeId = null;
  function setActive(id) {
    if (id === activeId) return;
    activeId = id;
    tocLinks.forEach((a, key) => a.classList.toggle("active", key === id));
  }
  const spy = new IntersectionObserver(
    (entries) => {
      // pick the topmost visible section; fall back to the last one above the viewport
      const visible = entries.filter((e) => e.isIntersecting).map((e) => e.target);
      if (visible.length) {
        const top = visible.sort((a, b) => a.getBoundingClientRect().top - b.getBoundingClientRect().top)[0];
        setActive(top.id);
      }
    },
    { rootMargin: "-80px 0px -55% 0px", threshold: 0 },
  );
  targets.forEach((t) => spy.observe(t));
</script>

---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Log In" description="Log in to your n0brains Signals account.">
  <section class="auth-page">
    <h1>log in</h1>
    <p class="auth-subtitle">Retrieve your API key or manage your account.</p>

    <form id="login-form" class="auth-form">
      <div class="form-group">
        <label for="email">email</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email" />
      </div>
      <div class="form-group">
        <label for="password">password</label>
        <input type="password" id="password" name="password" required placeholder="your password" autocomplete="current-password" />
      </div>
      <button type="submit" class="btn btn-primary" id="submit-btn">Log In</button>
      <p class="auth-error" id="error-msg"></p>
    </form>

    <div id="success-panel" class="success-panel" style="display:none;">
      <h2>logged in</h2>
      <p id="welcome-msg"></p>
      <div id="keys-section">
        <p class="auth-subtle">Your active API keys:</p>
        <div id="keys-list" class="keys-list"></div>
      </div>
      <p class="auth-subtle" style="margin-top:1rem;">Tier: <strong id="tier-display"></strong></p>
      <a href="/#pricing" class="btn btn-primary" style="margin-top:1rem; display:inline-block;" id="upgrade-btn">Upgrade to Pro</a>
    </div>

    <p class="auth-footer">No account yet? <a href="/signup">Create one</a></p>
  </section>
</BaseLayout>

<style>
  .auth-page {
    max-width: 420px;
    margin: 0 auto;
    padding: 4rem 0;
  }

  .auth-page h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--text-heading);
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .auth-subtitle {
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-group label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
  }

  .form-group input {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .form-group input:focus {
    border-color: var(--accent);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
    margin-top: 0.5rem;
  }

  .btn-primary {
    background: var(--accent);
    color: #000;
  }

  .btn-primary:hover {
    background: #fff;
    color: #000;
  }

  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .auth-error {
    color: var(--accent-secondary, #ff0055);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    min-height: 1.2rem;
  }

  .success-panel {
    margin-top: 1rem;
    padding: 1.5rem;
    background: var(--bg-alt);
    border: 1px solid var(--accent);
    border-radius: var(--radius);
  }

  .success-panel h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .success-panel p {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .keys-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .key-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: #080808;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
  }

  .key-item .key-name {
    color: var(--text-muted);
    flex: 1;
  }

  .auth-subtle {
    font-size: 0.8rem !important;
    color: var(--text-muted);
  }

  .auth-subtle a, .success-panel a {
    color: var(--accent);
  }

  .auth-footer {
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: center;
  }

  .auth-footer a {
    color: var(--accent);
  }

  #upgrade-btn { display: none; }
</style>

<script>
  const API_BASE = window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost'
    ? 'http://127.0.0.1:8000'
    : 'https://api.n0brains.com';

  const form = document.getElementById('login-form');
  const errorEl = document.getElementById('error-msg');
  const submitBtn = document.getElementById('submit-btn');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.textContent = '';
    submitBtn.disabled = true;
    submitBtn.textContent = 'Logging in...';

    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;

    try {
      const resp = await fetch(`${API_BASE}/auth/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });

      const data = await resp.json();

      if (!resp.ok) {
        throw new Error(data.detail || 'Login failed');
      }

      // Store auth info
      if (data.token) localStorage.setItem('auth_token', data.token);
      localStorage.setItem('tier', data.tier || 'free');

      // Show success panel
      form.style.display = 'none';
      document.getElementById('success-panel').style.display = 'block';
      document.getElementById('welcome-msg').textContent = `Welcome back, ${email}`;
      document.getElementById('tier-display').textContent = data.tier || 'free';

      // Show keys
      const keysList = document.getElementById('keys-list');
      if (data.api_keys && data.api_keys.length > 0) {
        data.api_keys.forEach(key => {
          const div = document.createElement('div');
          div.className = 'key-item';
          div.innerHTML = `<span>${key.prefix}...${key.name || 'default'}</span>`;
          keysList.appendChild(div);
        });
      } else {
        keysList.innerHTML = '<span style="color:var(--text-muted);">No active keys</span>';
      }

      // Show upgrade button if free tier
      if (data.tier === 'free') {
        document.getElementById('upgrade-btn').style.display = 'inline-block';
      }
    } catch (err) {
      errorEl.textContent = err.message;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Log In';
    }
  });
</script>
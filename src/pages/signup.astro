---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Sign Up" description="Create your free n0brains Signals account.">
  <section class="auth-page">
    <h1>create account</h1>
    <p class="auth-subtitle">Free tier. No credit card required. Get your API key instantly.</p>

    <form id="signup-form" class="auth-form">
      <div class="form-group">
        <label for="email">email</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email" />
      </div>
      <div class="form-group">
        <label for="password">password</label>
        <input type="password" id="password" name="password" required minlength="8" placeholder="8+ characters" autocomplete="new-password" />
      </div>
      <button type="submit" class="btn btn-primary" id="submit-btn">Create Account</button>
      <p class="auth-error" id="error-msg"></p>
    </form>

    <div id="success-panel" class="success-panel" style="display:none;">
      <h2>account created</h2>
      <p>Your API key is shown below. <strong>Save it now — it will not be shown again.</strong></p>
      <div class="api-key-box">
        <code id="api-key-display"></code>
        <button class="btn btn-secondary" id="copy-btn" onclick="copyKey()">copy</button>
      </div>
      <p class="auth-subtle">Free tier: 60 req/min, 15-min delay. <a href="/#pricing">Upgrade to Pro</a> for real-time signals.</p>
      <a href="/#pricing" class="btn btn-primary" style="margin-top:1rem; display:inline-block;">View Plans</a>
    </div>

    <p class="auth-footer">Already have an account? <a href="/login">Log in</a></p>
  </section>
</BaseLayout>

<style>
  .auth-page {
    max-width: 420px;
    margin: 0 auto;
    padding: 4rem 0;
  }

  .auth-page h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--text-heading);
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .auth-subtitle {
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-group label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
  }

  .form-group input {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .form-group input:focus {
    border-color: var(--accent);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
    margin-top: 0.5rem;
  }

  .btn-primary {
    background: var(--accent);
    color: #000;
  }

  .btn-primary:hover {
    background: #fff;
    color: #000;
  }

  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .auth-error {
    color: var(--accent-secondary, #ff0055);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    min-height: 1.2rem;
  }

  .success-panel {
    margin-top: 1rem;
    padding: 1.5rem;
    background: var(--bg-alt);
    border: 1px solid var(--accent);
    border-radius: var(--radius);
  }

  .success-panel h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .success-panel p {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .api-key-box {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    background: #080808;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
    overflow-x: auto;
  }

  .api-key-box code {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    word-break: break-all;
    flex: 1;
  }

  .auth-subtle {
    font-size: 0.8rem !important;
    color: var(--text-muted);
  }

  .auth-subtle a {
    color: var(--accent);
  }

  .auth-footer {
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: center;
  }

  .auth-footer a {
    color: var(--accent);
  }
</style>

<script>
  const API_BASE = window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost'
    ? 'http://127.0.0.1:8000'
    : 'https://api.n0brains.com';

  const form = document.getElementById('signup-form');
  const errorEl = document.getElementById('error-msg');
  const submitBtn = document.getElementById('submit-btn');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.textContent = '';
    submitBtn.disabled = true;
    submitBtn.textContent = 'Creating...';

    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;

    try {
      const resp = await fetch(`${API_BASE}/auth/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });

      const data = await resp.json();

      if (!resp.ok) {
        throw new Error(data.detail || 'Registration failed');
      }

      // Store API key
      localStorage.setItem('api_key', data.api_key);
      localStorage.setItem('tier', data.tier);

      // Show success panel
      form.style.display = 'none';
      document.getElementById('success-panel').style.display = 'block';
      document.getElementById('api-key-display').textContent = data.api_key;

      // If redirected from checkout, auto-trigger checkout
      const params = new URLSearchParams(window.location.search);
      if (params.get('redirect') === 'checkout') {
        const tier = params.get('tier') || 'pro';
        try {
          const checkoutResp = await fetch(`${API_BASE}/billing/checkout`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-API-Key': data.api_key },
            body: JSON.stringify({ price_id: tier }),
          });
          const checkoutData = await checkoutResp.json();
          if (checkoutData.url) {
            window.location.href = checkoutData.url;
            return;
          }
        } catch (e) {
          // Checkout failed — show the API key panel instead, user can upgrade later
        }
      }
    } catch (err) {
      errorEl.textContent = err.message;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Create Account';
    }
  });

  window.copyKey = function() {
    const key = document.getElementById('api-key-display').textContent;
    navigator.clipboard.writeText(key).then(() => {
      document.getElementById('copy-btn').textContent = 'copied!';
      setTimeout(() => { document.getElementById('copy-btn').textContent = 'copy'; }, 2000);
    });
  };
</script>
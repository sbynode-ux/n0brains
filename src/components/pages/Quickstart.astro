---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, toLocale, navHref } from "../../i18n/ui";

/* -----------------------------------------------------------------------
   /docs/quickstart — the beginner path: get a key, connect YOUR agent
   (claude.ai custom connector, Claude Code, Claude Desktop, OpenClaw,
   Hermes, Cursor, any MCP client, or plain REST), ask the first
   question, then hand the agent a job from the prompt library.

   Every number, config shape, and auth path on this page is verified
   against the LIVE API (2026-07-17): 40 MCP tools total, 14 on a free
   key (authoritative -32001 free_tools list), ?api_key= URL auth
   confirmed working end-to-end, check_trade example is a real response.
   ---------------------------------------------------------------------- */

const locale = toLocale(Astro.currentLocale);
const t = useTranslations(locale);
const canonicalURL = new URL(Astro.url.pathname, "https://n0brains.com").href;

const KEY = "YOUR_API_KEY";
const MCP_URL = "https://api.n0brains.com/mcp/";

// ── Per-client connect snippets ───────────────────────────────────────
const claudeAiUrl = `${MCP_URL}?api_key=${KEY}`;

const claudeCodeCmd =
`claude mcp add --transport http n0brains ${MCP_URL} \\
  --header "Authorization: Bearer ${KEY}" -s user`;

const openclawCmd =
`openclaw mcp set n0brains '{"url":"${MCP_URL}","transport":"streamable-http","headers":{"Authorization":"Bearer ${KEY}"}}'`;

const openclawJson =
`{
  mcp: {
    servers: {
      n0brains: {
        url: "${MCP_URL}",
        transport: "streamable-http",
        headers: {
          Authorization: "Bearer ${KEY}",
        },
      },
    },
  },
}`;

const hermesYaml =
`mcp_servers:
  n0brains:
    url: "${MCP_URL}"
    headers:
      Authorization: "Bearer ${KEY}"`;

const mcpServersJson =
`{
  "mcpServers": {
    "n0brains": {
      "url": "${MCP_URL}",
      "headers": { "Authorization": "Bearer ${KEY}" }
    }
  }
}`;

// ── Step 03: the first question ───────────────────────────────────────
const firstQuestion =
`Use the n0brains tools to check this trade idea: BTC long at the current
price, 5x leverage, 24-hour horizon. Read me back the grade, every flag
working against it, and what it could NOT assess.`;

// Condensed from a real check_trade response (free key, 2026-07-17).
const checkTradeExample =
`{
  "grade": "B+",
  "score": 0.84,
  "engine_version": "v2.7",
  "flags": [{
    "check": "proven_edge",
    "severity": "high",
    "note": "strongest PROVEN driver is hack/bearish — measured
             realized edge points AGAINST this bullish idea",
    "falsifier": "market-state proven driver flips bullish"
  }],
  "supports": [],
  "falsifiers": ["market-state proven driver flips bullish"],
  "unchecked": ["stop placement (no stop given)",
                "risk:reward (needs both stop and target)"],
  "receipts": "https://n0brains.com/proof"
}`;

// ── REST track (no MCP client needed — works with ANY agent) ──────────
const restOneLiner =
`Use the n0brains API at https://api.n0brains.com with header X-API-Key: ${KEY}
It returns scored crypto intelligence signals. Before answering any market
question, GET /signals (filter with ?asset=BTC&signal_type=whale&urgency=high)
and cite what you find. Read the "conviction" field: strong > notable > watch
> none — an evidence-strength label, not a directive or probability. Analysis,
not financial advice — never place trades.`;

// ── Prompt library (jobs for a connected agent) ───────────────────────
const checkFirst =
`Before I place ANY trade, ask n0brains first. The n0brains API:
  base URL: https://api.n0brains.com   header: X-API-Key: ${KEY}

POST /check with the trade I'm considering:
  {"asset":"BTC","side":"long","entry":62000,"stop":60000,
   "target":66000,"leverage":10,"horizon_hours":24}
Only "asset" and "side" are required. Works for crypto AND the tokenized
stock market (NVDA, SP500, XYZ100, GOLD, …).

It returns a graded conditions assessment:
  grade   — A to F (with a "score" and the engine_version that graded it)
  flags   — what's working against the trade (crowding, event risk,
            liquidation-vs-volatility, momentum extension, positioning,
            and a fatal check for structurally-broken stops)
  supports, falsifiers, terrain (nearest S/R + liq clusters), and
  unchecked — what it could NOT assess given the inputs.

Read the grade AND the reasons back to me. A "grade" describes the
CONDITIONS around the trade — it is analysis, never a directive to trade.
Every verdict is logged before its outcome and resolved at its horizon;
grade performance publishes on /proof once it clears the verification
standard. Free 3 checks a day. Never place the trade yourself.`;

const tradeAware =
`You are my crypto research assistant. You have the n0brains API:
  base URL: https://api.n0brains.com
  auth header: X-API-Key: ${KEY}

Before answering any "should I buy/sell/hold X" question, ALWAYS:
  1. GET /signals?asset=<COIN>  — read direction, conviction, score, summary.
     conviction: strong > notable > watch > none — an evidence-strength label,
     not a directive or probability.
  2. GET /levels/<COIN>          — nearest support/resistance (as zones, with
     polarity-flip tracking) for entry/stop framing.
  3. GET /macro                  — current regime + calendar risk; per-asset
     bias only when supported.

Then give a structured read: bias, the signals behind it, key levels, and what
would invalidate it. End with "Analysis only, not financial advice." Never
recommend a position size or leverage, and never execute a trade.`;

const macroBrief =
`Each morning, build me a crypto macro brief from the n0brains API
(https://api.n0brains.com, header X-API-Key: ${KEY}):
  1. GET /macro            — regime, calendar risks, and any supported asset bias.
  2. GET /rotation         — is capital rotating into alts or into BTC?
  3. GET /signals?urgency=high&limit=10  — the day's highest-urgency events.
Summarize in 5 bullets: regime, any supported asset bias, calendar risk,
rotation read, top catalyst. Never invent a bias the API withheld.
Append the calendar_risks from /macro. Analysis only, not financial advice.`;

const tokenSafety =
`Before I touch any token, screen it with the n0brains API
(https://api.n0brains.com, header X-API-Key: ${KEY}):
  GET /trust/<TICKER>   — returns trust_score, rug_probability, is_honeypot,
                          is_mintable, sell_tax, low_liquidity, flags.
If rug_probability > 0.5, is_honeypot is true, or "honeypot"/"high_sell_tax" is
in flags, warn me loudly and tell me NOT to proceed. Otherwise summarize the
risk. Analytical scam-screening, not a guarantee of safety.`;

const liqHunt =
`You map liquidation magnets with the n0brains API
(https://api.n0brains.com, header X-API-Key: ${KEY}). When I name a coin:
  GET /liquidation-map/<COIN>  — returns nearest_long_liq_zone (price below, where
    longs get flushed) and nearest_short_liq_zone (price above, where shorts get
    squeezed), plus zones[] sorted by est_notional_usd.
Tell me: the nearest magnet on each side, which is heavier (bigger est_notional_usd),
and therefore which direction price is more likely to get pulled. Pair with
GET /levels/<COIN> so the magnet lines up against real support/resistance.
These are modeled liquidity zones, not certainties — analysis only, not advice.`;

const rotationRebal =
`You track capital rotation with the n0brains API
(https://api.n0brains.com, header X-API-Key: ${KEY}). On request:
  1. GET /rotation         — regime is "into_alts", "into_btc", or "neutral",
                             with a rotation_score for strength.
  2. GET /correlation?vs=BTC  — which assets move WITH vs INDEPENDENT of BTC.
  3. GET /macro            — confirm the regime read against macro conditions.
If regime=into_alts, surface low-BTC-correlation names as the rotation candidates;
if into_btc, flag alts as the funding source; if neutral, say so and stand down.
This is a heuristic regime read, not a rebalancing instruction — analysis only.`;

const sentDivergence =
`You hunt sentiment/price divergences with the n0brains API
(https://api.n0brains.com, header X-API-Key: ${KEY}). For a coin I name:
  GET /sentiment/<COIN>  — returns lean (bullish/bearish/mixed), net_sentiment,
    volume, velocity (recent vs older chatter), accelerating, top_sources.
Flag a DIVERGENCE when sentiment lean is strongly one way and accelerating, but
the asset's recent signals (GET /signals?asset=<COIN>) point the other way — a
possible crowd-vs-flow mismatch. Report lean, velocity, the contradicting signal,
and which side has the on-chain/flow evidence. Analysis only, not financial advice.`;

const promptCards = [
  { id: "job-checkfirst", title: "Ask n0brains first — pre-trade check", sub: "Before any trade, POST /check and get a graded A–F read of the conditions — crypto and tokenized stocks. The flagship.", code: checkFirst },
  { id: "job-research",   title: "Market-aware research assistant", sub: "Makes an agent check signals, levels, and regime before answering any market question.", code: tradeAware },
  { id: "job-macro",      title: "Daily macro brief", sub: "A morning routine: regime, calendar risk, rotation, and any supported asset bias.", code: macroBrief },
  { id: "job-safety",     title: "Token safety screen", sub: "Screen any token for honeypot / rug risk before touching it.", code: tokenSafety },
  { id: "job-liqhunt",    title: "Liquidation-magnet hunter", sub: "Find where leveraged positions get flushed — which side is heavier and pulls price.", code: liqHunt },
  { id: "job-rotation",   title: "Rotation / rebalance scout", sub: "Is capital flowing into alts or into BTC? Surface the rotation candidates.", code: rotationRebal },
  { id: "job-sentiment",  title: "Sentiment-divergence finder", sub: "Spot crowd-vs-flow mismatches: sentiment one way, on-chain signals the other.", code: sentDivergence },
];

// ── Client cards (step 02 chooser) ────────────────────────────────────
const clients = [
  { id: "claude-ai",      name: "claude.ai",        hint: "web + mobile app — no install at all", tag: "start here" },
  { id: "claude-code",    name: "Claude Code",      hint: "one command in your terminal", tag: "" },
  { id: "claude-desktop", name: "Claude Desktop",   hint: "same connector flow as claude.ai", tag: "" },
  { id: "openclaw",       name: "OpenClaw",         hint: "self-hosted agent gateway", tag: "" },
  { id: "hermes",         name: "Hermes",           hint: "Nous Research personal agent", tag: "" },
  { id: "cursor",         name: "Cursor",           hint: "and any mcpServers-style client", tag: "" },
  { id: "other-clients",  name: "Cline · Continue · other MCP", hint: "generic config block", tag: "" },
  { id: "rest",           name: "No MCP? Plain REST", hint: "works with literally any agent", tag: "" },
];

// ── Side navigation ───────────────────────────────────────────────────
const toc = [
  { group: "setup", items: [
    { href: "#start",   label: "01 · get your key" },
    { href: "#connect", label: "02 · connect your agent" },
    { href: "#test",    label: "03 · first question" },
  ]},
  { group: "connect", items: [
    { href: "#claude-ai",      label: "claude.ai" },
    { href: "#claude-code",    label: "claude code" },
    { href: "#claude-desktop", label: "claude desktop" },
    { href: "#openclaw",       label: "openclaw" },
    { href: "#hermes",         label: "hermes" },
    { href: "#cursor",         label: "cursor" },
    { href: "#other-clients",  label: "other mcp clients" },
    { href: "#rest",           label: "plain rest" },
  ]},
  { group: "use it", items: [
    { href: "#prompts",      label: "prompt library" },
    { href: "#tiers",        label: "free vs pro" },
    { href: "#troubleshoot", label: "troubleshooting" },
    { href: "#more",         label: "going further" },
  ]},
  { group: "more docs", items: [
    { href: "/docs/",    label: "api reference" },
    { href: "/docs/mcp", label: "mcp server" },
    { href: "/docs/cli", label: "cli" },
    { href: "/docs/x402", label: "x402" },
  ]},
];

// Strings the client script swaps in (copy button + key personalizer).
const jsT = {
  copied: t("copied"),
  keyApplied: t("✓ key applied to {n} snippets — stays in this tab, never sent or saved."),
  keyNoteReset: t("Stays in this tab — never sent anywhere, never saved."),
};

const howToJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Connect an AI agent to n0brains market intelligence",
  totalTime: "PT5M",
  step: [
    { "@type": "HowToStep", name: "Get a free API key", text: "Create a free n0brains account — the API key is shown once at signup. Copy it; you can regenerate from the dashboard anytime." },
    { "@type": "HowToStep", name: "Connect your agent", text: "Add the n0brains MCP server (https://api.n0brains.com/mcp/) to claude.ai as a custom connector, or to Claude Code, Claude Desktop, OpenClaw, Hermes, Cursor, or any MCP client. No MCP? Use plain REST." },
    { "@type": "HowToStep", name: "Ask the first question", text: "Ask your agent to check a trade idea with check_trade — it returns a graded A–F conditions assessment with flags and falsifiers." },
  ],
});
---

<BaseLayout
  title={t("Quickstart — connect your agent to n0brains")}
  description={t("Five minutes to a market-aware AI agent. Step-by-step: get a free key, connect claude.ai (custom connector), Claude Code, Claude Desktop, OpenClaw, Hermes, Cursor, or any MCP client — then hand your agent a job from the prompt library. No SDK, no install.")}
  canonicalURL={canonicalURL}
>
  <script type="application/ld+json" set:html={howToJsonLd} />

  <section class="docs-page qs">
    <div class="qs-hero">
      <p class="qs-boot" aria-hidden="true">$ agent --connect n0brains<span class="qs-caret">▮</span></p>
      <h1>{t("Five minutes to a")}<br /><span class="qs-hl">{t("market-aware agent")}</span></h1>
      <p class="docs-subtitle">
        {t("n0brains is an intelligence layer your agent calls like a native tool — live signals, graded pre-trade checks, levels, macro regime. No SDK, nothing to install. Three steps: get a key, connect the agent you already use, ask the first question.")}
      </p>
      <div class="qs-steps" aria-hidden="true">
        <a href="#start"><b>01</b> {t("get key")}</a>
        <span class="qs-step-line"></span>
        <a href="#connect"><b>02</b> {t("connect agent")}</a>
        <span class="qs-step-line"></span>
        <a href="#test"><b>03</b> {t("ask")}</a>
      </div>
    </div>

    <nav class="qs-chipnav" aria-label="Jump to section">
      {toc.flatMap((g) => g.items).map((i) => (
        <a href={i.href}>{t(i.label).replace(/^\d+ · /, "")}</a>
      ))}
    </nav>

    <div class="qs-grid">
      <div class="qs-main">

        <!-- ── STEP 01 ─────────────────────────────────────────────── -->
        <div class="card qs-step" id="start">
          <span class="qs-num" aria-hidden="true">01</span>
          <h2>{t("Get your key")}</h2>
          <ol>
            <li><a href={navHref("/signup", locale)}>{t("Create a free account")}</a> {t("— no card, ~30 seconds.")}</li>
            <li>{t("Your API key is shown")} <strong>{t("once")}</strong>{t(", right after signup — copy it now. Lost it?")} <a href="/dashboard">{t("Regenerate from the dashboard")}</a>{t("; the old key stops working immediately.")}</li>
          </ol>
          <div class="qs-keybar">
            <label for="qs-key">{t("Paste your key here and every snippet on this page personalizes itself:")}</label>
            <div class="qs-keyrow">
              <input id="qs-key" type="password" placeholder="intel_sk_…" autocomplete="off" spellcheck="false" />
              <button id="qs-apply" type="button">{t("apply")}</button>
            </div>
            <p class="qs-keynote" id="qs-keynote">{t("Stays in this tab — never sent anywhere, never saved.")}</p>
          </div>
        </div>

        <!-- ── STEP 02 ─────────────────────────────────────────────── -->
        <div class="card qs-step" id="connect">
          <span class="qs-num" aria-hidden="true">02</span>
          <h2>{t("Connect your agent")}</h2>
          <p>{t("Pick the agent you already use. Every path below points at the same MCP server —")}
          <code>https://api.n0brains.com/mcp/</code> {t("— and a free key already unlocks 14 tools, including the flagship")} <code>check_trade</code>.</p>
          <div class="qs-clients">
            {clients.map((c) => (
              <a class={`qs-client ${c.tag ? "qs-client-star" : ""}`} href={`#${c.id}`}>
                {c.tag && <span class="qs-client-tag">{t(c.tag)}</span>}
                <span class="qs-client-name">{t(c.name)}</span>
                <span class="qs-client-hint">{t(c.hint)}</span>
                <span class="qs-client-arrow" aria-hidden="true">↳</span>
              </a>
            ))}
          </div>
        </div>

        <div class="card qs-client-card" id="claude-ai">
          <h3>claude.ai — {t("custom connector")} <span class="qs-badge">{t("easiest · no install")}</span></h3>
          <p>{t("Works on the claude.ai web app (and the mobile apps once connected). The free Claude plan allows one custom connector — n0brains fits in it.")}</p>
          <ol>
            <li>{t("Open")} <strong>{t("Settings → Connectors")}</strong> {t("(on some accounts it's labeled")} <strong>{t("Customize → Connectors")}</strong>{t(").")}</li>
            <li>{t("Click")} <strong>{t("Add custom connector")}</strong>.</li>
            <li>{t("Name it")} <code>n0brains</code> {t("and paste this as the remote MCP server URL:")}</li>
          </ol>
          <div class="prompt-block">
            <button class="copy-btn" aria-label={t("copy URL")}>{t("copy")}</button>
            <pre><code>{claudeAiUrl}</code></pre>
          </div>
          <ol start="4">
            <li>{t("Click")} <strong>{t("Add")}</strong>{t(". In any chat, open the")} <strong>+</strong> {t("menu →")} <strong>{t("Connectors")}</strong> {t("and toggle n0brains on.")}</li>
            <li>{t("Ask:")} <em>{t('"What does n0brains say about BTC right now?"')}</em> {t("— Claude will call the tools itself.")}</li>
          </ol>
          <p class="docs-tip"><strong>{t("Why the key is in the URL:")}</strong> {t("claude.ai custom connectors can't yet attach auth headers on self-serve accounts (Anthropic's request-header option is still in beta), so the n0brains server also accepts")} <code>?api_key=</code> {t("on the URL. Treat that URL like a password — anyone holding it can spend your quota. If it ever leaks,")} <a href="/dashboard">{t("regenerate the key")}</a> {t("and update the connector. If your Claude account has the beta \"Request headers\" section, prefer it: header")} <code>x-api-key</code>{t(", value = your bare key, and drop the query string from the URL.")}</p>
        </div>

        <div class="card qs-client-card" id="claude-code">
          <h3>Claude Code</h3>
          <p>{t("One command in your terminal —")} <code>-s user</code> {t("makes it available in every project:")}</p>
          <div class="prompt-block">
            <button class="copy-btn" aria-label={t("copy command")}>{t("copy")}</button>
            <pre><code>{claudeCodeCmd}</code></pre>
          </div>
          <p>{t("Restart Claude Code (or open a new session) and the n0brains tools appear automatically. Prefer a skill instead of tools?")} <code>curl -O https://n0brains.com/openclaw/n0brains-signals.md</code> {t("and drop it into")} <code>~/.claude/skills/n0brains-signals/SKILL.md</code>.</p>
        </div>

        <div class="card qs-client-card" id="claude-desktop">
          <h3>Claude Desktop</h3>
          <p>{t("Same custom-connector flow as claude.ai:")} <strong>{t("Settings → Connectors → Add custom connector")}</strong>{t(", paste the same URL-with-key from the")} <a href="#claude-ai">{t("claude.ai section")}</a>{t(". Connectors added on either surface sync to the other.")}</p>
          <p>{t("Managing servers by config file instead? The classic")} <code>claude_desktop_config.json</code> {t("route and per-OS file paths are on the")} <a href="/docs/mcp">{t("MCP page")}</a>.</p>
        </div>

        <div class="card qs-client-card" id="openclaw">
          <h3>OpenClaw</h3>
          <p>{t("MCP is built in (recent releases). One CLI call registers the server:")}</p>
          <div class="prompt-block">
            <button class="copy-btn" aria-label={t("copy command")}>{t("copy")}</button>
            <pre><code>{openclawCmd}</code></pre>
          </div>
          <p>{t("Or add it by hand to")} <code>~/.openclaw/openclaw.json</code> {t("under")} <code>mcp.servers</code>
          {t("(JSON5 — trailing commas fine;")} <code>{"${ENV_VAR}"}</code> {t("substitution works in headers):")}</p>
          <div class="prompt-block">
            <button class="copy-btn" aria-label={t("copy config")}>{t("copy")}</button>
            <pre><code>{openclawJson}</code></pre>
          </div>
          <p>{t("Verify with")} <code>openclaw mcp list</code>{t(", then ask your agent for a BTC read. Getting 401s with a correct key? Update OpenClaw — one older build silently dropped custom headers on streamable-http (see")} <a href="#troubleshoot">{t("troubleshooting")}</a>{t("). Prefer skills over MCP? The same")} <a href="/openclaw/n0brains-signals.md" download>n0brains-signals.md</a> {t("skill file drops straight into your OpenClaw skills directory.")}</p>
        </div>

        <div class="card qs-client-card" id="hermes">
          <h3>Hermes (Nous Research)</h3>
          <p>{t("The self-hosted")} <a href="https://github.com/NousResearch/hermes-agent">{t("Hermes agent")}</a> {t("reads MCP servers from")} <code>~/.hermes/config.yaml</code>:</p>
          <div class="prompt-block">
            <button class="copy-btn" aria-label={t("copy config")}>{t("copy")}</button>
            <pre><code>{hermesYaml}</code></pre>
          </div>
          <p>{t("Tidier: put the key in")} <code>~/.hermes/.env</code> {t("as")} <code>N0BRAINS_API_KEY=…</code> {t("and write the header value as")} <code>Bearer {"${N0BRAINS_API_KEY}"}</code> {t("— Hermes resolves")} <code>{"${VAR}"}</code> {t("from env at connect time. A running session picks the edit up automatically (or run")} <code>/reload-mcp</code>{t("); verify with")} <code>hermes mcp test n0brains</code>{t(". Tools register as")} <code>mcp_n0brains_*</code>.</p>
        </div>

        <div class="card qs-client-card" id="cursor">
          <h3>Cursor</h3>
          <p><strong>{t("Settings → MCP → Add server")}</strong>{t(", or add to")} <code>~/.cursor/mcp.json</code>:</p>
          <div class="prompt-block">
            <button class="copy-btn" aria-label={t("copy config")}>{t("copy")}</button>
            <pre><code>{mcpServersJson}</code></pre>
          </div>
        </div>

        <div class="card qs-client-card" id="other-clients">
          <h3>{t("Cline · Continue · any MCP client")}</h3>
          <p>{t("Anything that speaks the standard")} <code>mcpServers</code> {t("config shape takes the exact block from the")} <a href="#cursor">{t("Cursor section")}</a> {t("— remote streamable-HTTP URL plus an")} <code>Authorization: Bearer</code> {t("(or")} <code>X-API-Key</code>{t(") header. The server also answers")} <code>initialize</code> {t("and")} <code>tools/list</code> {t("without auth, so client \"test connection\" buttons work before you've wired the key.")}</p>
        </div>

        <div class="card qs-client-card" id="rest">
          <h3>{t("No MCP? Plain REST — any agent at all")}</h3>
          <p>{t("Every tool has a REST twin. Paste this into any agent's instructions — that's the whole integration:")}</p>
          <div class="prompt-block">
            <button class="copy-btn" aria-label={t("copy prompt")}>{t("copy")}</button>
            <pre><code>{restOneLiner}</code></pre>
          </div>
          <p>{t("Shell pipelines and bots: the")} <a href="/docs/cli">CLI</a> {t("prints JSON to stdout for")} <code>jq</code>{t(". No account at all?")} <a href="/docs/x402">x402</a> {t("pays per request in USDC — no signup.")}</p>
        </div>

        <!-- ── STEP 03 ─────────────────────────────────────────────── -->
        <div class="card qs-step" id="test">
          <span class="qs-num" aria-hidden="true">03</span>
          <h2>{t("Ask the first question")}</h2>
          <p>{t("Say this to your connected agent:")}</p>
          <div class="prompt-block">
            <button class="copy-btn" aria-label={t("copy prompt")}>{t("copy")}</button>
            <pre><code>{firstQuestion}</code></pre>
          </div>
          <p>{t("Your agent calls")} <code>check_trade</code> {t("and gets back a graded conditions read. Here's a real response (trimmed) from a free key:")}</p>

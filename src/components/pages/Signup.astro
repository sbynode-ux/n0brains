---
/* Shared body for /signup and /{es,tr,ru}/signup. The register flow sets a few
   strings from client JS (button states, error fallback, copy button), so those
   are passed in as a JSON blob the script reads — server-side t() can't reach
   JS-created text. Endpoints, prices, localStorage keys and field attributes
   stay literal. */
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, toLocale } from "../../i18n/ui";

const locale = toLocale(Astro.currentLocale);
const t = useTranslations(locale);
const canonicalURL = new URL(Astro.url.pathname, "https://n0brains.com").href;

/* Strings the client script swaps in (button states + copy feedback). */
const jsT = {
  creating: t("Creating..."),
  ctaCreate: t("Create Account"),
  errRegister: t("Registration failed"),
  copyLabel: t("copy"),
  copyDone: t("copied!"),
};
---

<BaseLayout
  title={t("Sign Up")}
  description={t("Create your free n0brains Signals account.")}
  canonicalURL={canonicalURL}
>
  <section class="auth-page">
    <h1>{t("create account")}</h1>
    <p class="auth-subtitle">{t("Free tier. No credit card required. Get your API key instantly.")}</p>

    <form id="signup-form" class="auth-form">
      <div class="form-group">
        <label for="email">{t("email")}</label>
        <input type="email" id="email" name="email" required placeholder={t("you@example.com")} autocomplete="email" />
      </div>
      <div class="form-group">
        <label for="password">{t("password")}</label>
        <input type="password" id="password" name="password" required minlength="8" placeholder={t("8+ characters")} autocomplete="new-password" />
      </div>
      <label class="terms-check">
        <input type="checkbox" id="terms" required />
        <span>{t("I agree to the")} <a href="/terms" target="_blank">{t("Terms of Service")}</a> {t("and")} <a href="/privacy" target="_blank">{t("Privacy Policy")}</a>.</span>
      </label>
      <button type="submit" class="btn btn-primary" id="submit-btn">{t("Create Account")}</button>
      <p class="auth-error" id="error-msg"></p>
    </form>

    <div id="success-panel" class="success-panel" style="display:none;">
      <h2>{t("account created")}</h2>
      <p>{t("Your API key is shown below.")} <strong>{t("Save it now — it will not be shown again.")}</strong></p>
      <div class="api-key-box">
        <code id="api-key-display"></code>
        <button class="btn btn-secondary" id="copy-btn" onclick="copyKey()">{t("copy")}</button>
      </div>
      <p class="auth-subtle">{t("Free tier: 60 req/min, 15-min delay. Manage your account, keys, and billing from your dashboard.")}</p>
      <a href="/dashboard" class="btn btn-primary" style="margin-top:1rem; display:inline-block;">{t("Go to Dashboard")}</a>
    </div>

    <p class="auth-footer">{t("Already have an account?")} <a href="/login">{t("Log in")}</a></p>
  </section>

  <script type="application/json" id="signup-i18n" set:html={JSON.stringify(jsT)}></script>

<style>
  .auth-page {
    max-width: 420px;
    margin: 0 auto;
    padding: 4rem 0;
  }

  .auth-page h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--text-heading);
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .auth-subtitle {
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-group label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
  }

  .form-group input {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .form-group input:focus {
    border-color: var(--accent);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
    margin-top: 0.5rem;
  }

  .btn-primary {
    background: var(--accent);
    color: #000;
  }

  .btn-primary:hover {
    background: #fff;
    color: #000;
  }

  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .auth-error {
    color: var(--accent-secondary, #ff0055);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    min-height: 1.2rem;
  }

  .success-panel {
    margin-top: 1rem;
    padding: 1.5rem;
    background: var(--bg-alt);
    border: 1px solid var(--accent);
    border-radius: var(--radius);
  }

  .success-panel h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .success-panel p {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .api-key-box {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    background: #080808;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
    overflow-x: auto;
  }

  .api-key-box code {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    word-break: break-all;
    flex: 1;
  }

  .auth-subtle {
    font-size: 0.8rem !important;
    color: var(--text-muted);
  }

  .auth-subtle a {
    color: var(--accent);
  }

  .auth-footer {
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: center;
  }

  .auth-footer a {
    color: var(--accent);
  }

  .terms-check {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.4;
    cursor: pointer;
  }

  .terms-check input {
    margin-top: 0.2rem;
    accent-color: var(--accent);
    flex-shrink: 0;
  }

  .terms-check a {
    color: var(--accent);
  }
</style>

<script>
  // Already signed in — no second account push; go to the dashboard.
  try {
    if (localStorage.getItem('auth_token')) window.location.replace('/dashboard');
  } catch { /* storage blocked */ }

  const T = JSON.parse(document.getElementById('signup-i18n').textContent || '{}');

  const API_BASE = window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost'
    ? 'http://127.0.0.1:8000'
    : 'https://api.n0brains.com';

  const form = document.getElementById('signup-form');
  const errorEl = document.getElementById('error-msg');
  const submitBtn = document.getElementById('submit-btn');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.textContent = '';
    submitBtn.disabled = true;
    submitBtn.textContent = T.creating;

    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    const termsAccepted = document.getElementById('terms').checked;
    let attribution = {};
    try {
      attribution = JSON.parse(localStorage.getItem('n0brains_first_touch_v1') || '{}');
    } catch (_) {}

    try {
      const resp = await fetch(`${API_BASE}/auth/register`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password, terms_accepted: termsAccepted, attribution }),
      });

      const data = await resp.json();

      if (!resp.ok) {
        throw new Error(data.detail || T.errRegister);
      }

      // Store API key + session token
      localStorage.setItem('api_key', data.api_key);
      localStorage.setItem('tier', data.tier);
      if (data.token) localStorage.setItem('auth_token', data.token);

      // Show success panel
      form.style.display = 'none';
      document.getElementById('success-panel').style.display = 'block';
      document.getElementById('api-key-display').textContent = data.api_key;

      // If redirected from checkout, auto-trigger checkout
      const params = new URLSearchParams(window.location.search);
      if (params.get('redirect') === 'checkout') {
        const tier = params.get('tier') || 'pro';
        try {
          const checkoutResp = await fetch(`${API_BASE}/billing/checkout`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-API-Key': data.api_key },
            body: JSON.stringify({ price_id: tier }),
          });
          const checkoutData = await checkoutResp.json();
          if (checkoutData.url) {
            window.location.href = checkoutData.url;
            return;
          }
        } catch (e) {
          // Checkout failed — show the API key panel instead, user can upgrade later
        }
      }
    } catch (err) {
      errorEl.textContent = err.message;
      submitBtn.disabled = false;
      submitBtn.textContent = T.ctaCreate;
    }
  });

  window.copyKey = function() {
    const key = document.getElementById('api-key-display').textContent;
    navigator.clipboard.writeText(key).then(() => {
      document.getElementById('copy-btn').textContent = T.copyDone;
      setTimeout(() => { document.getElementById('copy-btn').textContent = T.copyLabel; }, 2000);
    });
  };
</script>
</BaseLayout>

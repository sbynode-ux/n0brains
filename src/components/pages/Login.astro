---
/* Shared body for /login and /{es,tr,ru}/login. Auth logic is untouched — only
   display strings are localized. Client-JS-set strings (button states, error
   messages) ride in as a JSON blob the script reads, since server-side t()
   can't reach JS-created text. Endpoints, localStorage keys and field
   attributes stay literal. */
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, toLocale } from "../../i18n/ui";

const locale = toLocale(Astro.currentLocale);
const t = useTranslations(locale);
const canonicalURL = new URL(Astro.url.pathname, "https://n0brains.com").href;

/* Strings the client script swaps in (button states + errors). */
const jsT = {
  logIn: t("Log In"),
  loggingIn: t("Logging in..."),
  loginFailed: t("Login failed"),
  noSession: t("Login succeeded but no session was issued. Contact support."),
};
---

<BaseLayout
  title={t("Log In")}
  description={t("Log in to your n0brains Signals account.")}
  canonicalURL={canonicalURL}
>
  <section class="auth-page">
    <h1>{t("log in")}</h1>
    <p class="auth-subtitle">{t("Retrieve your API key or manage your account.")}</p>

    <form id="login-form" class="auth-form">
      <div class="form-group">
        <label for="email">{t("email")}</label>
        <input type="email" id="email" name="email" required placeholder={t("you@example.com")} autocomplete="email" />
      </div>
      <div class="form-group">
        <label for="password">{t("password")}</label>
        <input type="password" id="password" name="password" required placeholder={t("your password")} autocomplete="current-password" />
      </div>
      <button type="submit" class="btn btn-primary" id="submit-btn">{t("Log In")}</button>
      <p class="auth-error" id="error-msg"></p>
      <p class="forgot-link"><a href="/forgot">{t("Forgot password?")}</a></p>
    </form>

    <div id="success-panel" class="success-panel" style="display:none;">
      <h2>{t("logged in")}</h2>
      <p id="welcome-msg"></p>
      <div id="keys-section">
        <p class="auth-subtle">{t("Your active API keys:")}</p>
        <div id="keys-list" class="keys-list"></div>
      </div>
      <p class="auth-subtle" style="margin-top:1rem;">{t("Tier:")} <strong id="tier-display"></strong></p>
      <a href="/#pricing" class="btn btn-primary" style="margin-top:1rem; display:inline-block;" id="upgrade-btn">{t("Upgrade to Pro")}</a>
    </div>

    <p class="auth-footer">{t("No account yet?")} <a href="/signup">{t("Create one")}</a></p>
  </section>
</BaseLayout>

<script type="application/json" id="login-i18n" set:html={JSON.stringify(jsT)}></script>

<style>
  .auth-page {
    max-width: 420px;
    margin: 0 auto;
    padding: 4rem 0;
  }

  .auth-page h1 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: var(--text-heading);
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .auth-subtitle {
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-group label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
  }

  .form-group input {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.75rem 1rem;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .form-group input:focus {
    border-color: var(--accent);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
    margin-top: 0.5rem;
  }

  .btn-primary {
    background: var(--accent);
    color: #000;
  }

  .btn-primary:hover {
    background: #fff;
    color: #000;
  }

  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .auth-error {
    color: var(--accent-secondary, #ff0055);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    min-height: 1.2rem;
  }

  .success-panel {
    margin-top: 1rem;
    padding: 1.5rem;
    background: var(--bg-alt);
    border: 1px solid var(--accent);
    border-radius: var(--radius);
  }

  .success-panel h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .success-panel p {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .keys-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .key-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: #080808;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
  }

  .key-item .key-name {
    color: var(--text-muted);
    flex: 1;
  }

  .auth-subtle {
    font-size: 0.8rem !important;
    color: var(--text-muted);
  }

  .auth-subtle a, .success-panel a {
    color: var(--accent);
  }

  .auth-footer {
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    text-align: center;
  }

  .auth-footer a {
    color: var(--accent);
  }

  .forgot-link {
    margin-top: 0.25rem;
    font-size: 0.8rem;
  }
  .forgot-link a { color: var(--text-muted); }
  .forgot-link a:hover { color: var(--accent); }

  #upgrade-btn { display: none; }
</style>

<script>
  // Already signed in — skip the form, honor ?next like a fresh login would.
  try {
    if (localStorage.getItem('auth_token')) {
      const next = new URLSearchParams(window.location.search).get('next');
      const safe = next && next.startsWith('/') && !next.startsWith('//');
      window.location.replace(safe ? next : '/dashboard');
    }
  } catch { /* storage blocked */ }

  const API_BASE = window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost'
    ? 'http://127.0.0.1:8000'
    : 'https://api.n0brains.com';

  // Localized display strings (the auth logic below is unchanged).
  const T = JSON.parse(document.getElementById('login-i18n').textContent || '{}');

  const form = document.getElementById('login-form');
  const errorEl = document.getElementById('error-msg');
  const submitBtn = document.getElementById('submit-btn');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.textContent = '';
    submitBtn.disabled = true;
    submitBtn.textContent = T.loggingIn;

    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;

    try {
      const resp = await fetch(`${API_BASE}/auth/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
        signal: AbortSignal.timeout(15000),  // don't strand the button on a blip
      });

      const data = await resp.json();

      if (!resp.ok) {
        throw new Error(data.detail || T.loginFailed);
      }

      // Store the session token, then honor ?next=/path (same-site paths
      // only) so pages like /check can send users back after login.
      localStorage.setItem('tier', data.tier || 'free');
      if (data.token) {
        localStorage.setItem('auth_token', data.token);
        const next = new URLSearchParams(window.location.search).get('next');
        const safe = next && next.startsWith('/') && !next.startsWith('//');
        window.location.href = safe ? next : '/dashboard';
        return;
      }
      // No token (server without JWT_SECRET) — surface a clear error.
      throw new Error(T.noSession);
    } catch (err) {
      errorEl.textContent = err.message;
      submitBtn.disabled = false;
      submitBtn.textContent = T.logIn;
    }
  });
</script>

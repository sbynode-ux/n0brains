---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, toLocale, navHref } from "../../i18n/ui";

const locale = toLocale(Astro.currentLocale);
const t = useTranslations(locale);
const canonicalURL = new URL(Astro.url.pathname, "https://n0brains.com").href;

// Build-time seed so crawlers / link-previews (no JS) see real numbers, not
// "loading…". Client JS still refreshes these live every 60s (progressive enhancement).
let seedBestNum = "", seedBest = "", seedBestSub = "", seedProven = "", seedSignals = "", seedBanner = "";
try {
  const res = await fetch("https://api.n0brains.com/proof");
  const d = await res.json();
  const types = Array.isArray(d.types) ? d.types : [];
  const proven = types.filter((t) => t.tradeable);
  seedProven = String(proven.length);
  const totalN = types.reduce((a, t) => a + (t.n || 0), 0);
  seedSignals = totalN ? totalN.toLocaleString("en-US") : "";
  const best = proven.slice().sort((a, b) => (b.win_rate || 0) - (a.win_rate || 0))[0];
  if (best) {
    seedBestNum = String(Math.round(best.win_rate * 100));
    seedBest = seedBestNum + "%";
    seedBestSub = best.signal_type + " · +" + (best.excess_pct ?? 0).toFixed(1) + "pts vs BTC";
    const seedSwingN = types.filter((t) => !t.tradeable && (t.swing_proven_cells || []).length).length;
    seedBanner = proven.length + " proven signal types"
      + (seedSwingN ? " · " + seedSwingN + " swing-proven at 7–30d" : "")
      + " · measured on real Hyperliquid prices";
  }
} catch (e) { /* leave placeholders; client JS fills on load */ }

/* Strings the client script injects at runtime. Server-side t() can't reach
   JS-created text, so they ride along as a JSON blob the script reads. Numbers,
   tickers, endpoints and signal_type tokens stay literal in the script. */
const jsT = {
  provenEmpty: t("0 types currently clear the bar. The gate is real — when edge decays, this page says so first."),
  winRateN: t("win rate · n="),
  avgReturn: t("avg return"),
  excessVsBtc: t("excess vs BTC"),
  ci95Low: t("95% CI low"),
  proven: t("proven"),
  noTypeClears: t("no type currently clears the gate"),
  noneRightNow: t("none right now"),
  intelOnly: t("intel only"),
  swingProven: t("swing-proven"),
  swingBadgeTitle: t("proven at swing horizons (7–30d) — measured edge at days-scale; feeds the labeled swing outlook, never the intraday trade gate"),
  bannerSwingSuffix: t("swing-proven at 7–30d"),
  coinFlipLine: t("coin-flip line"),
  proofUnavailable: t("proof unavailable"),
  fetchFailed: t("fetch failed"),
  bannerProvenOne: t("signal type forward-return proven"),
  bannerProvenMany: t("signal types forward-return proven"),
  thType: t("type"),
  thSignals: t("signals"),
  winRate: t("win rate"),
  avgReturnTitle: t("mean return of the trade itself"),
  excessVsBtcTitle: t("mean return minus BTC over the same window"),
  excessCiLow: t("excess CI low"),
  excessCiLowTitle: t("95% confidence lower bound on excess return — the conservative edge"),
  lastUpdated: t("Last updated"),
  cgCalibrating: t("every check is logged and resolved against real prices; grade performance publishes here once the deployed engine clears the verification standard"),
  cgNoChecks: t("no checks logged yet"),
  pending: t("pending"),
  provLegend: t("rows are split by origin — <b>probe</b> = our own automated calibration account (hits the same public /check around the clock so every grade accumulates a scoreable record; disclosed, never blended into the customer rows) · <b>real</b> = customer checks"),
  engine: t("engine"),
  currentWeights: t("current · weights derived from measured outcomes · calibrating fresh since 2026-07-06"),
  grade: t("grade"),
  given: t("given"),
  resolved: t("resolved"),
  archivedSummary: t("archived engine versions — earlier weight sets and their full records (v1's top band measured INVERTED at n=60; we replaced the engine and kept the receipt — that is the point of this page)"),
  archived: t("archived"),
  reScoredOn: t("re-scored on"),
  priorResolvedChecks: t("prior resolved crypto checks —"),
  notLiveRecord: t("NOT a live record"),
  nBacktest: t("n (backtest)"),
  cgUnavailable: t("check-grade calibration unavailable"),
  equityUnavailable: t("equity curve unavailable"),
  allProvenCombined: t("All proven (combined)"),
  lines: t("Lines"),
  provenSignalsOver: t("proven signals over"),
  days: t("days"),
  index: t("index"),
  perSignal: t("per signal"),
  illustrative: t("illustrative, not a live account"),
};
---

<BaseLayout
  title={t("proof")}
  description={t("n0brains live forward-return proof — every signal type measured against real post-signal price action, with win rate, excess vs BTC, and confidence intervals. The exact gate we use to flag signals. Not advice.")}
  ogImage="/og-proof.png"
  canonicalURL={canonicalURL}
>
  <section class="proof-page">
    <div class="section-label" data-reveal="fade">{t("live audit · refreshed every 60s")}</div>

    <div class="proof-hero">
      <div class="proof-hero-copy">
        <h1 class="proof-h1">
          <span class="hl"><span class="hli">{t("EVERY CALL.")}</span></span>
          <span class="hl"><span class="hli accent">{t("ON THE RECORD.")}</span></span>
        </h1>
        <p class="proof-lede">
          {t("No curated backtests. No survivor bias. Every directional signal is measured against real post-signal prices and posted here live — wins, losses, and the types we demote. This page renders the")}
          <em>{t("exact")}</em> {t("gate the pipeline uses to flag")}
          <code>conviction: strong</code>{t(", so it can never claim edge the product doesn't actually act on.")}
        </p>
      </div>
      <!-- Rotating live stat — cycles through proven types, values from /proof -->
      <div class="ph-panel" id="ph-panel" aria-live="off">
        <div class="ph-label"><span class="live-dot-sm"></span>{t("proven · live")}</div>
        <div class="ph-body" id="ph-body">
          <div class="ph-num" id="ph-num">{seedBestNum || "··"}<span class="ph-pct">%</span></div>
          <div class="ph-sub" id="ph-sub">{seedBestSub || t("measuring…")}</div>
        </div>
        <div class="ph-foot" id="ph-foot">{t("win rate · 24h forward return")}</div>
      </div>
    </div>

    <!-- Live stat band — every number from the same /proof endpoint -->
    <div class="stat-band" id="stat-band">
      <div class="stat">
        <span class="stat-num" id="st-proven">{seedProven || "–"}</span>
        <span class="stat-label">{t("proven signal types")}</span>
      </div>
      <div class="stat">
        <span class="stat-num" id="st-signals">{seedSignals || "–"}</span>
        <span class="stat-label">{t("signals measured · 30d")}</span>
      </div>
      <div class="stat">
        <span class="stat-num" id="st-best">{seedBest || "–"}</span>
        <span class="stat-label">{t("best proven win-rate")}</span>
      </div>
      <div class="stat">
        <span class="stat-num">1h–24h</span>
        <span class="stat-label">{t("per-type proven horizon · real HL prices")}</span>
      </div>
    </div>

    <div id="proof-banner" class={"proof-banner" + (seedBanner ? "" : " proof-loading")}>
      <span class="dot"></span>
      <span class="banner-text">{seedBanner || t("loading results…")}</span>
    </div>

    <!-- THE GATE — every type queues up, three criteria, two exits.
         Same flow language as the homepage pipeline. -->
    <h2 class="proof-h2">{t("The gate")}</h2>
    <p class="proof-sub">
      {t("Every signal type is forced through the same three checks, per direction, regime-aware. Pass all three → the API flags it. Fail any → it stays published here as")} <em>{t("intel only")}</em>{t(". No type is grandfathered in.")}
    </p>
    <div class="gate" id="gate">
      <div class="gate-col">
        <div class="gate-col-label">{t("candidates")} <span id="gate-n-in"></span></div>
        <div class="gate-pool" id="gate-pool"><span class="gate-chip dim">{t("loading…")}</span></div>
      </div>
      <div class="gate-flow" aria-hidden="true">
        <span class="gate-line"></span>
        <span class="gate-line"></span>
      </div>
      <div class="gate-col">
        <div class="gate-box">
          <div class="gate-box-head"><span class="live-dot-sm"></span>{t("forward-return gate")}</div>
          <div class="gate-crit"><span class="gc-check">✓</span> {t("n ≥ 30 measured signals")}</div>
          <div class="gate-crit"><span class="gc-check">✓</span> {t("beats BTC + profitable, per (type, direction)")}</div>
          <div class="gate-crit"><span class="gc-check">✓</span> {t("regime-aware — gated on the regime that holds")}</div>
          <div class="gate-crit"><span class="gc-check">✓</span> {t("expected move > round-trip cost")}</div>
        </div>
      </div>
      <div class="gate-flow" aria-hidden="true">
        <span class="gate-line"></span>
        <span class="gate-line gate-line-fail"></span>
      </div>
      <div class="gate-col">
        <div class="gate-out pass">
          <div class="gate-col-label pass">{t("proven")} → conviction: strong <span id="gate-n-pass"></span></div>
          <div class="gate-pool" id="gate-pass"></div>
        </div>
        <div class="gate-out swing" id="gate-swing-lane" hidden>
          <div class="gate-col-label swing">{t("swing-proven")} → 7–30d horizon <span id="gate-n-swing"></span></div>
          <div class="gate-pool" id="gate-swing"></div>
        </div>
        <div class="gate-out fail">
          <div class="gate-col-label">{t("intel only — stays public")} <span id="gate-n-fail"></span></div>
          <div class="gate-pool" id="gate-fail"></div>
        </div>
      </div>
    </div>

    <!-- Proven types — the headline numbers -->
    <div class="proven-cards" id="proven-cards" aria-live="polite"></div>

    <h2 class="proof-h2">{t("The full audit — failures included")}</h2>
    <p class="proof-sub">
      {t("Types that don't clear the bar stay on the board as")} <em>{t("intel only")}</em>{t(". Public demotion is the feature: when edge decays, this board says so before our marketing does.")}
    </p>
    <div class="wr-bars" id="wr-bars"></div>
    <div class="table-wrap" id="proof-table"></div>
    <p class="meta" id="proof-meta"></p>

    <!-- Methodology — the fine print, in the open -->
    <div class="method-panel">
      <div class="method-head">{t("methodology")}</div>
      <p>
        {t("Every directional signal is measured against real post-signal price action — Hyperliquid 1-hour candles — at the horizon where each type is proven (1h, 4h or 24h) over a rolling 30-day window. For each signal type we publish the win rate, the mean return of the trade itself, the mean")} <strong>{t("excess vs BTC over the same window")}</strong>{t(", and 95% confidence intervals. A type is marked")} <strong>{t("proven")}</strong> {t("only when it clears 30+ measured signals AND both beats BTC AND is profitable on its own — judged")} <strong>{t("per (type, direction) and regime")}</strong>{t(", not on the pooled blend. (So a type can read proven here while its")} <em>{t("pooled")}</em> {t("excess-return CI, shown in the table, still dips below zero — the pool mixes a winning direction with a losing one; the gate scores them separately.) Beating BTC alone isn't enough — a type that only looks good by being short in a downtrend, while still losing money, does not qualify. The live")} <code>trade_signal</code> {t("gate applies this same per-(type, direction), regime-aware test, and additionally downgrades any call whose expected move is too small to clear round-trip trading cost (fees + slippage) — a move you can't profit from after costs isn't a trade.")}
      </p>
    </div>

    <h2 class="proof-h2">{t("Edge accumulation")}</h2>
    <p class="proof-sub">
      {t("Does the per-signal edge above actually compound, or is it a few lucky outliers? Below is an illustrative account starting at index 100 that takes")} <strong>{t("every proven-type signal")}</strong>{t(", one at a time, risking")} <span id="eq-alloc">1%</span> {t("of equity per signal and compounding the realized 24h return — in fire-time order. Fixed fractional size, no leverage, no stacking.")} <strong>{t("Illustrative of edge accumulation on measured returns, not a live-traded or guaranteed account.")}</strong>
    </p>
    <div id="equity-wrap">
      <div id="equity-legend" class="equity-legend"></div>
      <div id="equity-chart" class="equity-chart">{t("loading…")}</div>
    </div>
    <p class="meta" id="equity-meta"></p>

    <h2 class="proof-h2">{t("Grade performance: published only once proven")}</h2>
    <p class="proof-sub">
      {t("Every")} <a href={navHref("/check", locale)}>{t("pre-trade check")}</a> {t("verdict is logged the moment it is issued and resolved at its stated horizon against real prices. Grade-level performance publishes here under the same standard as every other number on this page: only after the deployed engine clears our weekly verification bar on consecutive weeks. Nothing less unlocks this section.")}
    </p>
    <p class="meta">{t("Until that standard is met, no grade-performance claim is made — by design.")}</p>

    <p class="legal-updated" style="margin-top: 32px;">
      {t("A type is shown as")} <strong>{t("forward-return proven")}</strong> {t("only when its live post-signal price record clears 30+ measured signals AND both beats BTC and is profitable on its own — evaluated per (type, direction) and regime, at a 95% confidence interval above zero. These are the types we flag")} <code>conviction: strong</code> {t("in the API. Measured on real prices for informational purposes only — not financial advice, and past performance does not guarantee future results. See")} <a href="/terms">{t("terms")}</a>.
    </p>

    <!-- Conversion path -->
    <div class="proof-cta" data-reveal>
      <h3>{t("These numbers update whether they flatter us or not.")}</h3>
      <p>{t("Pipe the proven signals straight into your agent — REST, WebSocket, Webhook, MCP, or x402.")}</p>
      <div class="cta-row">
        <a href="/signup" class="btn btn-primary">{t("Start Free →")}</a>
        <a href="/docs/" class="btn btn-secondary">{t("API Docs ↗")}</a>
      </div>
    </div>

    <script type="application/json" id="proof-i18n" set:html={JSON.stringify(jsT)}></script>
  </section>
</BaseLayout>

<script>
  const T = JSON.parse(document.getElementById("proof-i18n")!.textContent || "{}");
  const ENDPOINT = "https://api.n0brains.com/proof";
  const REDUCE = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  let countedUp = false;

  // Horizon-qualified proof (#106): "proven" always names its horizon. Three
  // states — intraday tradeable (with its horizons), swing-proven (7–30d cells,
  // labeled, never the trade badge), intel-only. One compact nowrap chip: the
  // DISPLAY horizon only (the one the headline stats use); the full horizon
  // list rides in the tooltip — multi-horizon text made the chip wrap badly.
  function isSwingRow(t) {
    return !t.tradeable && !!t.swing_stats;
  }
  function badgeFor(t) {
    if (t.tradeable) {
      const all = (t.proven_horizons || []).join("/");
      const hz = t.proven_horizon || (t.proven_horizons || [])[0] || "";
      return `<span class="badge badge-yes" title="${T.proven}${all ? " @" + all : ""}">${T.proven}${hz ? " @" + hz : ""}</span>`;
    }
    if (t.swing_stats) {
      const cells = t.swing_proven_cells || [];
      const all = [...new Set(cells.flatMap((c) => c.horizons || []))].join("/");
      return `<span class="badge badge-swing" title="${T.swingBadgeTitle}${all ? " (" + all + ")" : ""}">${T.swingProven} @${t.swing_stats.horizon}</span>`;
    }
    return `<span class="badge badge-no">${T.intelOnly}</span>`;
  }
  // Effective display stats: swing-proven rows show their SWING cell's numbers
  // (win/avg/excess/CI at the horizon the proof lives at) — a swing badge next
  // to the pooled intraday coinflip row was the same stat-vs-badge mismatch
  // the 07-01 intraday display-horizon fix removed.
  function statsFor(t) {
    if (isSwingRow(t)) {
      const s = t.swing_stats;
      return { n: s.n, win_rate: s.win_rate, avg_net_pct: s.avg_net_pct,
               excess_pct: s.excess_pct, ci_low_pct: s.ci_low_pct,
               horizon: s.horizon, direction: s.direction, swing: true };
    }
    return { n: t.n, win_rate: t.win_rate, avg_net_pct: t.avg_net_pct,
             excess_pct: t.excess_pct, ci_low_pct: t.ci_low_pct,
             horizon: t.horizon, direction: null, swing: false };
  }

  function pct(v) {
    if (v === null || v === undefined) return "—";
    const n = Number(v) * 100;
    return n.toFixed(1) + "%";
  }
  function pctRaw(v) {
    if (v === null || v === undefined) return "—";
    return (Number(v) >= 0 ? "+" : "") + Number(v).toFixed(2) + "%";
  }

  function countUp(el, target, fmt, dur = 900) {
    if (REDUCE) { el.textContent = fmt(target); return; }
    const t0 = performance.now();
    const tick = (now) => {
      const p = Math.min((now - t0) / dur, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = fmt(target * eased);
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }

  function renderStats(data) {
    const proven = data.types.filter((t) => t.tradeable);
    const totalN = data.types.reduce((a, t) => a + (t.n || 0), 0);
    const best = proven.length ? Math.max(...proven.map((t) => t.win_rate || 0)) : null;
    const stP = document.getElementById("st-proven");
    const stS = document.getElementById("st-signals");
    const stB = document.getElementById("st-best");
    if (countedUp) {
      // Subsequent refreshes: update silently, no re-animation.
      stP.textContent = String(proven.length);
      stS.textContent = totalN.toLocaleString();
      stB.textContent = best === null ? "—" : (best * 100).toFixed(1) + "%";
      return;
    }
    countedUp = true;
    countUp(stP, proven.length, (v) => Math.round(v).toString());
    countUp(stS, totalN, (v) => Math.round(v).toLocaleString());
    if (best === null) stB.textContent = "—";
    else countUp(stB, best * 100, (v) => v.toFixed(1) + "%");
  }

  function renderProvenCards(data) {
    const wrap = document.getElementById("proven-cards");
    const proven = data.types
      .filter((t) => t.tradeable)
      .sort((a, b) => (b.excess_pct || 0) - (a.excess_pct || 0));
    // Swing-proven types get cards too — same shape, purple, stats AT the
    // swing horizon (direction + horizon labeled), sorted by CI-low.
    const swing = data.types
      .filter((t) => !t.tradeable && t.swing_stats)
      .map((t) => ({ ...t.swing_stats, type: t.signal_type }))
      .sort((a, b) => (b.ci_low_pct || 0) - (a.ci_low_pct || 0));
    if (!proven.length && !swing.length) {
      wrap.innerHTML = `<div class="pv-empty">${T.provenEmpty}</div>`;
      return;
    }
    const provenCards = proven.map((t, i) => `
      <div class="pv-card" style="--pvi:${i}">
        <div class="pv-head">
          <span class="pv-type">${t.signal_type}</span>
          <span class="badge badge-yes">${T.proven}</span>
        </div>
        <div class="pv-win">${pct(t.win_rate)}<span>${T.winRateN}${t.n}${t.horizon ? " · " + t.horizon : ""}</span></div>
        <div class="pv-rows">
          <div><span>${T.avgReturn}</span><b class="${t.avg_net_pct >= 0 ? "pos" : "neg"}">${pctRaw(t.avg_net_pct)}</b></div>
          <div><span>${T.excessVsBtc}</span><b class="${t.excess_pct >= 0 ? "pos" : "neg"}">${pctRaw(t.excess_pct)}</b></div>
          <div><span>${T.ci95Low}</span><b class="${t.ci_low_pct > 0 ? "pos" : "neg"}">${pctRaw(t.ci_low_pct)}</b></div>
        </div>
      </div>`).join("");
    const swingCards = swing.map((s, i) => `
      <div class="pv-card swing" style="--pvi:${proven.length + i}">
        <div class="pv-head">
          <span class="pv-type">${s.type || s.signal_type || ""}<span class="pv-dir">${s.direction} @${s.horizon}</span></span>
          <span class="badge badge-swing">${T.swingProven}</span>
        </div>
        <div class="pv-win">${pct(s.win_rate)}<span>${T.winRateN}${s.n} · ${s.horizon}</span></div>
        <div class="pv-rows">
          <div><span>${T.avgReturn}</span><b class="${s.avg_net_pct >= 0 ? "pos" : "neg"}">${pctRaw(s.avg_net_pct)}</b></div>
          <div><span>${T.excessVsBtc}</span><b class="${s.excess_pct >= 0 ? "pos" : "neg"}">${pctRaw(s.excess_pct)}</b></div>
          <div><span>${T.ci95Low}</span><b class="${s.ci_low_pct > 0 ? "pos" : "neg"}">${pctRaw(s.ci_low_pct)}</b></div>
        </div>
      </div>`).join("");
    wrap.innerHTML = provenCards + swingCards;
    // Entrance animation only on first render — 60s refreshes update silently.
    setTimeout(() => wrap.classList.add("loaded"), 1600);
  }

  /* Hero rotator — values morph in place: the win-rate rolls to the next
     number, the sub-line scramble-decodes into the next type. Nothing fades
     out; the card content is always visible mid-transition. */
  let rotTimer = null;
  let lastWin = null;

  function tweenNum(el, from, to, dur = 850) {
    const fmt = (v) => v.toFixed(1) + '<span class="ph-pct">%</span>';
    if (REDUCE) { el.innerHTML = fmt(to); return; }
    const t0 = performance.now();
    const step = (now) => {
      const p = Math.min((now - t0) / dur, 1);
      const e = 1 - Math.pow(1 - p, 3);
      el.innerHTML = fmt(from + (to - from) * e);
      if (p < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  const SCHARS = "!<>-_\\/[]{}=+*^?#0123456789";
  function scrambleTo(el, finalText, finalHTML, dur = 750) {
    if (REDUCE) { el.innerHTML = finalHTML; return; }
    const t0 = performance.now();
    const step = (now) => {
      const p = Math.min((now - t0) / dur, 1);
      const settled = Math.floor(p * finalText.length);
      let out = finalText.slice(0, settled);
      for (let k = settled; k < finalText.length; k++) {
        out += finalText[k] === " " ? " " : SCHARS[(Math.random() * SCHARS.length) | 0];
      }
      el.textContent = out;
      if (p < 1) requestAnimationFrame(step);
      else el.innerHTML = finalHTML;   // green excess locks in at the end
    };
    requestAnimationFrame(step);
  }

  function startHeroRotator(data) {
    const proven = data.types.filter((t) => t.tradeable);
    const num = document.getElementById("ph-num");
    const sub = document.getElementById("ph-sub");
    if (!num) return;
    if (!proven.length) {
      num.innerHTML = "0";
      sub.textContent = T.noTypeClears;
      return;
    }
    let i = -1;
    const show = () => {
      i = (i + 1) % proven.length;
      const t = proven[i];
      const win = t.win_rate * 100;
      // First paint rolls up from just below; afterwards rolls between values.
      tweenNum(num, lastWin === null ? Math.max(0, win - 15) : lastWin, win);
      lastWin = win;
      const txt = `${t.signal_type} · n=${t.n} · ${pctRaw(t.excess_pct)} ${T.excessVsBtc}`;
      const html = `${t.signal_type} · n=${t.n} · <b class="pos">${pctRaw(t.excess_pct)}</b> ${T.excessVsBtc}`;
      scrambleTo(sub, txt, html);
    };
    if (rotTimer) { show(); return; }   // refresh: update values, keep cadence
    show();
    if (REDUCE || proven.length < 2) return;
    rotTimer = setInterval(show, 7000);
  }

  /* THE GATE — candidates in, criteria, proven / swing-proven / intel-only out. */
  function renderGate(data) {
    const pool = document.getElementById("gate-pool");
    const pass = document.getElementById("gate-pass");
    const fail = document.getElementById("gate-fail");
    if (!pool) return;
    const chips = (arr, cls, label) => arr.map((t, i) =>
      `<span class="gate-chip ${cls}" style="--gi:${i}">${t.signal_type}${label ? `<span class="gate-hz">${label(t)}</span>` : ""}</span>`).join("");
    const proven = data.types.filter((t) => t.tradeable);
    // Swing-proven cells earn their OWN lane (not intel-only): proven at a
    // 7-30d horizon, labeled with it, highlighted — the same distinction the
    // bar board and cards make.
    const swing = data.types.filter((t) => !t.tradeable && t.swing_stats);
    const intel = data.types.filter((t) => !t.tradeable && !t.swing_stats);
    pool.innerHTML = chips(data.types, "");
    pass.innerHTML = proven.length ? chips(proven, "pass") : `<span class="gate-chip dim">${T.noneRightNow}</span>`;
    fail.innerHTML = intel.length ? chips(intel, "dim") : '<span class="gate-chip dim">—</span>';
    const swingLane = document.getElementById("gate-swing-lane");
    const swingPool = document.getElementById("gate-swing");
    if (swing.length) {
      swingLane.hidden = false;
      swingPool.innerHTML = chips(swing, "swing", (t) => " @" + t.swing_stats.horizon);
      document.getElementById("gate-n-swing").textContent = "×" + swing.length;
    } else {
      swingLane.hidden = true;
    }
    document.getElementById("gate-n-in").textContent = "×" + data.types.length;
    document.getElementById("gate-n-pass").textContent = "×" + proven.length;
    document.getElementById("gate-n-fail").textContent = "×" + intel.length;
    // Chip entrance only once; refreshes swap content silently.
    setTimeout(() => document.getElementById("gate")?.classList.add("loaded"), 1400);
  }

  /* Win-rate bar board — every type, 50% reference line, proven glows. */
  let barsAnimated = false;
  function renderBars(data) {
    const wrap = document.getElementById("wr-bars");
    if (!wrap) return;
    const rows = [...data.types].sort(
      (a, b) => (statsFor(b).win_rate || 0) - (statsFor(a).win_rate || 0));
    wrap.innerHTML = rows.map((t) => {
      const s = statsFor(t);
      const w = Math.max(0, Math.min(100, (s.win_rate || 0) * 100));
      const cls = t.tradeable ? "proven" : (s.swing ? "swing" : "demoted");
      const val = s.swing
        ? `${pct(s.win_rate)}<span class="wr-hz">@${s.horizon}</span>`
        : pct(s.win_rate);
      return `
        <div class="wr-row ${cls}">
          <span class="wr-name">${t.signal_type}</span>
          <span class="wr-track">
            <span class="wr-fill" style="width:${barsAnimated ? w : 0}%" data-w="${w}"></span>
            <span class="wr-50" title="${T.coinFlipLine}"></span>
          </span>
          <span class="wr-val">${val}</span>
          <span class="wr-badge">${badgeFor(t)}</span>
        </div>`;
    }).join("");
    if (!barsAnimated) {
      barsAnimated = true;
      requestAnimationFrame(() => requestAnimationFrame(() => {
        wrap.querySelectorAll(".wr-fill").forEach((f) => {
          f.style.width = f.dataset.w + "%";
        });
      }));
    }
  }

  function render(data) {
    const banner = document.getElementById("proof-banner");
    const table  = document.getElementById("proof-table");
    const meta   = document.getElementById("proof-meta");

    if (!data || data.error || !data.types) {
      banner.className = "proof-banner proof-unknown";
      banner.querySelector(".banner-text").textContent =
        T.proofUnavailable + " (" + (data?.error || T.fetchFailed) + ")";
      return;
    }

    renderStats(data);
    startHeroRotator(data);
    renderGate(data);
    renderBars(data);
    renderProvenCards(data);

    const tradeable = data.types.filter((t) => t.tradeable);
    const swingN = data.types.filter(
      (t) => !t.tradeable && (t.swing_proven_cells || []).length).length;
    banner.className = "proof-banner proof-up";
    banner.querySelector(".banner-text").textContent =
      tradeable.length + " " + (tradeable.length === 1 ? T.bannerProvenOne : T.bannerProvenMany)
      + (swingN ? " · " + swingN + " " + T.bannerSwingSuffix : "");

    let rows = "";
    for (const t of data.types) {
      const s = statsFor(t);
      const cls = t.tradeable ? "row-tradeable"
                : (s.swing ? "row-swing" : "row-untradeable");
      const flag = badgeFor(t);
      // Swing rows display THEIR cell's numbers (direction + horizon labeled);
      // everything else keeps the intraday display horizon.
      const typeCell = s.swing
        ? `${t.signal_type} <span class="type-hz">${s.direction} @${s.horizon}</span>`
        : t.signal_type;
      // CI shown as the lower bound on excess return — the conservative edge.
      const ciCls = s.ci_low_pct > 0 ? "pos" : "neg";
      rows += `
        <tr class="${cls}">
          <td class="type">${typeCell}</td>
          <td>${s.n}</td>
          <td>${pct(s.win_rate)}</td>
          <td class="${s.avg_net_pct >= 0 ? "pos" : "neg"}">${pctRaw(s.avg_net_pct)}</td>
          <td class="${s.excess_pct >= 0 ? "pos" : "neg"}">${pctRaw(s.excess_pct)}</td>
          <td class="${ciCls}">${pctRaw(s.ci_low_pct)}</td>
          <td>${flag}</td>
        </tr>`;
    }
    table.innerHTML = `
      <table class="proof-table">
        <thead>
          <tr><th>${T.thType}</th><th>${T.thSignals}</th><th>${T.winRate}</th>
              <th title="${T.avgReturnTitle}">${T.avgReturn}</th>
              <th title="${T.excessVsBtcTitle}">${T.excessVsBtc}</th>
              <th title="${T.excessCiLowTitle}">${T.excessCiLow}</th>
              <th></th></tr>
        </thead>
        <tbody>${rows}</tbody>
      </table>`;

    if (data.types[0] && data.types[0].updated_at) {
      const latest = Math.max(...data.types.map((t) => t.updated_at || 0));
      meta.textContent = T.lastUpdated + " " + new Date(latest * 1000).toISOString();
    }
  }

  async function load() {
    try {
      const r = await fetch(ENDPOINT, { cache: "no-store" });
      render(await r.json());
    } catch (e) {
      render({ error: String(e) });
    }
  }

  load();
  setInterval(load, 60_000);

  // ── Pre-trade check grade calibration ("We grade our own grades") ──
  const CG_COLOR = { "A": "#4ade80", "B+": "#7ac943", "B": "#c9b843", "C": "#e0983a", "D": "#e0663a", "F": "#e03a3a" };
  async function loadCheckGrades() {
    const wrap = document.getElementById("check-grades-table");
    const meta = document.getElementById("check-grades-meta");
    if (!wrap) return;
    try {
      const r = await fetch(ENDPOINT);
      const d = await r.json();
      const cg = d.check_grades;
      if (!cg || !cg.grades || !cg.grades.length) {
        const st = d.check_grade_status || {};
        wrap.innerHTML = (st.claims_published === false || st.status === "calibration_in_progress")
          ? `<span class='meta'>${T.cgCalibrating}</span>`
          : `<span class='meta'>${T.cgNoChecks}</span>`;
        if (meta) meta.textContent = "";
        return;
      }
      // rows are split by ENGINE VERSION — each set of weights is its own
      // claim and calibrates fresh; old versions stay published (that's the
      // point of the record). Group them with labeled headers so the split
      // reads as versions, not repetition.
      const rowHtml = (g) => {
        const c = CG_COLOR[g.grade] || "inherit";
        const ret = g.avg_ret_pct == null ? "—"
          : `<span style="color:${g.avg_ret_pct >= 0 ? "#4ade80" : "#e03a3a"}">${g.avg_ret_pct > 0 ? "+" : ""}${g.avg_ret_pct}%</span>`;
        const wr = g.win_rate == null ? "—" : `${(g.win_rate * 100).toFixed(0)}%`;
        const pending = g.n_total - g.n_resolved;
        const prov = g.provenance
          ? ` <span class="cg-prov">${g.provenance}</span>`
          : "";
        return `<tr>
          <td><b style="color:${c}">${g.grade}</b>${prov}</td>
          <td>${g.n_total}</td>
          <td>${g.n_resolved}${pending ? ` <span class="meta">(+${pending} ${T.pending})</span>` : ""}</td>
          <td>${wr}</td>
          <td>${ret}</td>
        </tr>`;
      };
      const byVer = {};
      for (const g of cg.grades) (byVer[g.engine_version || "v1"] ||= []).push(g);
      // provenance split (attribution honesty): every grade can appear twice
      // per version — real customer checks vs our disclosed calibration probe.
      // Sort real-first within each grade and say what the labels mean, or
      // the table reads as duplicated letters.
      const GRADE_ORDER = { "A": 0, "B+": 1, "B": 2, "C": 3, "D": 4, "F": 5 };
      for (const v of Object.keys(byVer))
        byVer[v].sort((a, b) => (GRADE_ORDER[a.grade] ?? 9) - (GRADE_ORDER[b.grade] ?? 9)
          || String(a.provenance || "").localeCompare(String(b.provenance || "")));
      const provLegend = cg.grades.some((g) => g.provenance)
        ? `<p class="meta" style="margin:0.3rem 0 0.5rem;font-size:0.72rem">${T.provLegend}</p>`
        : "";
      const vers = Object.keys(byVer).sort().reverse();   // newest first
      const cur = vers[0];
      const THEAD = `<thead><tr><th>${T.grade}</th><th>${T.given}</th><th>${T.resolved}</th>
        <th>${T.winRate}</th><th>${T.avgReturn}</th></tr></thead>`;
      let html = `
        <p class="meta" style="margin:0.4rem 0 0.3rem">${T.engine} ${cur} — ${T.currentWeights}</p>
        ${provLegend}
        <table class="cg-table">${THEAD}<tbody>${byVer[cur].map(rowHtml).join("")}</tbody></table>`;
      const archived = vers.slice(1);
      if (archived.length) {
        html += `<details style="margin-top:0.8rem"><summary class="meta"
          style="cursor:pointer">${T.archivedSummary}</summary>`
          + archived.map((v) => `
            <p class="meta" style="margin:0.8rem 0 0.3rem">${T.engine} ${v} — ${T.archived}</p>
            <table class="cg-table">${THEAD}<tbody>${byVer[v].map(rowHtml).join("")}</tbody></table>`).join("")
          + `</details>`;
      }
      // ── fenced BACKTEST block (explicitly not a live record) ──
      const bt = d.check_grades_backtest;
      if (bt && bt.grades && bt.grades.length) {
        const btRows = bt.grades.map((g) => {
          const c = CG_COLOR[g.grade] || "inherit";
          const ret = g.avg_ret_pct == null ? "—"
            : `<span style="color:${g.avg_ret_pct >= 0 ? "#4ade80" : "#e03a3a"}">${g.avg_ret_pct > 0 ? "+" : ""}${g.avg_ret_pct}%</span>`;
          const wr = g.win_rate == null ? "—" : `${(g.win_rate * 100).toFixed(0)}%`;
          return `<tr><td><b style="color:${c}">${g.grade}</b></td>
            <td>${g.n}</td><td>${wr}</td><td>${ret}</td></tr>`;
        }).join("");
        html += `<div style="margin-top:1.4rem;border:1px dashed var(--border);
            padding:0.9rem 1rem;border-radius:6px;opacity:0.92">
          <p class="meta" style="margin:0 0 0.5rem;letter-spacing:0.05em">
            ⎇ BACKTEST · ${T.engine} ${bt.engine_version} ${T.reScoredOn} ${bt.n.toLocaleString()}
            ${T.priorResolvedChecks} <b>${T.notLiveRecord}</b></p>
          <table class="cg-table"><thead><tr><th>${T.grade}</th><th>${T.nBacktest}</th><th>${T.winRate}</th>
            <th>${T.avgReturn}</th></tr></thead><tbody>${btRows}</tbody></table>
          <p class="meta" style="margin:0.6rem 0 0;font-size:0.72rem">${bt.note}</p>
        </div>`;
      }
      wrap.innerHTML = html;
      meta.textContent = cg.note || "";
    } catch (e) {
      wrap.innerHTML = `<span class='meta'>${T.cgUnavailable}</span>`;
    }
  }
  loadCheckGrades();
  setInterval(loadCheckGrades, 120_000);

  // ── Equity curve (illustrative edge accumulation) ──────────────────
  const EQUITY_ENDPOINT = "https://api.n0brains.com/proof/equity";
  const TYPE_COLORS = ["#4ade80", "#60a5fa", "#f59e0b", "#c084fc", "#f472b6"];

  function buildPath(points, x0, y0, w, h, tMin, tMax, eqMin, eqMax) {
    if (!points.length) return "";
    const sx = (t) => x0 + ((t - tMin) / (tMax - tMin || 1)) * w;
    const sy = (e) => y0 + h - ((e - eqMin) / (eqMax - eqMin || 1)) * h;
    // Downsample to ~300 points so the SVG path stays light.
    const step = Math.max(1, Math.floor(points.length / 300));
    let d = "";
    for (let i = 0; i < points.length; i += step) {
      const p = points[i];
      d += (d ? "L" : "M") + sx(p.t).toFixed(1) + "," + sy(p.equity).toFixed(1) + " ";
    }
    const last = points[points.length - 1];
    d += "L" + sx(last.t).toFixed(1) + "," + sy(last.equity).toFixed(1);
    return d;
  }

  function renderEquity(d) {
    const chart = document.getElementById("equity-chart");
    const legend = document.getElementById("equity-legend");
    const meta = document.getElementById("equity-meta");
    const allocEl = document.getElementById("eq-alloc");
    if (!d || d.error || !d.combined || !d.combined.length) {
      chart.innerHTML = `<div class='tier-err'>${T.equityUnavailable}</div>`;
      return;
    }
    if (allocEl && d.alloc_frac_per_signal != null) {
      allocEl.textContent = (d.alloc_frac_per_signal * 100).toFixed(d.alloc_frac_per_signal < 0.01 ? 1 : 0) + "%";
    }

    const W = 720, H = 300, padL = 48, padR = 16, padT = 16, padB = 28;
    const w = W - padL - padR, h = H - padT - padB;

    // Series: combined + each proven type. "All proven" gets a bright, thick
    // white line so it reads as the headline series vs the thinner per-type lines.
    const COMBINED_COLOR = "#ffffff";
    const COMBINED_NAME = T.allProvenCombined;
    const series = [{ name: COMBINED_NAME, points: d.combined, color: COMBINED_COLOR, width: 2.6 }];
    const types = Object.keys(d.by_type || {});
    types.forEach((t, i) => {
      series.push({ name: t, points: d.by_type[t], color: TYPE_COLORS[i % TYPE_COLORS.length], width: 1.6 });
    });

    let tMin = Infinity, tMax = -Infinity, eqMin = Infinity, eqMax = -Infinity;
    for (const s of series) for (const p of s.points) {
      if (p.t < tMin) tMin = p.t; if (p.t > tMax) tMax = p.t;
      if (p.equity < eqMin) eqMin = p.equity; if (p.equity > eqMax) eqMax = p.equity;
    }
    // Pad the y-range a touch and always include the 100 baseline.
    eqMin = Math.min(eqMin, 100); eqMax = Math.max(eqMax, 100);
    const yPad = (eqMax - eqMin) * 0.08 || 1; eqMin -= yPad; eqMax += yPad;

    const yBase = padT + h - ((100 - eqMin) / (eqMax - eqMin || 1)) * h;
    const gridVals = [eqMin, (eqMin + eqMax) / 2, eqMax];
    let grid = "";
    for (const gv of gridVals) {
      const gy = padT + h - ((gv - eqMin) / (eqMax - eqMin || 1)) * h;
      grid += `<line x1="${padL}" y1="${gy.toFixed(1)}" x2="${W - padR}" y2="${gy.toFixed(1)}" class="eq-grid"/>`;
      grid += `<text x="${padL - 6}" y="${(gy + 3).toFixed(1)}" class="eq-axis" text-anchor="end">${gv.toFixed(0)}</text>`;
    }

    let paths = "";
    for (const s of series) {
      const dPath = buildPath(s.points, padL, padT, w, h, tMin, tMax, eqMin, eqMax);
      paths += `<path d="${dPath}" fill="none" stroke="${s.color}" stroke-width="${s.width}"/>`;
    }

    chart.innerHTML = `
      <svg viewBox="0 0 ${W} ${H}" class="eq-svg" preserveAspectRatio="xMidYMid meet">
        ${grid}
        <line x1="${padL}" y1="${yBase.toFixed(1)}" x2="${W - padR}" y2="${yBase.toFixed(1)}" class="eq-base"/>
        ${paths}
      </svg>`;

    // Legend built straight from `series` so colors + labels always match the
    // chart lines exactly. Swatch is a short line segment (matching the drawn
    // line), not a square, so "this color = this line" is unambiguous. Each
    // entry shows the series' final return.
    const byRet = d.by_type_return_pct || {};
    const retFor = (s) => s.name === COMBINED_NAME
      ? d.combined_return_pct
      : byRet[s.name];
    legend.innerHTML =
      `<span class="eq-leg-title">${T.lines}</span>` +
      series.map((s) => {
        const r = retFor(s);
        const rv = (r === null || r === undefined) ? "" :
          `<b class="${r >= 0 ? "pos" : "neg"}">${pctRaw(r)}</b>`;
        // Fully inline the swatch styles: this span is injected via innerHTML, so
        // Astro's SCOPED CSS (.eq-swatch[data-astro-cid-…]) never matches it —
        // the dimensions/border must live on the element itself, not in <style>.
        const sw = `display:inline-block;width:14px;height:14px;border-radius:3px;`
          + `flex:0 0 auto;border:1px solid rgba(255,255,255,0.25);background:${s.color};`;
        return `<span class="eq-leg-item">` +
          `<span class="eq-swatch" style="${sw}"></span>` +
          `<span class="eq-leg-name">${s.name}</span>${rv}</span>`;
      }).join("");

    if (meta) {
      meta.textContent =
        `${d.n_signals} ${T.provenSignalsOver} ${d.window_days} ${T.days} (~${d.signals_per_day}/day) · ` +
        `${T.index} 100 → ${d.combined_final_index} · ${d.alloc_frac_per_signal != null ? (d.alloc_frac_per_signal * 100).toFixed(d.alloc_frac_per_signal < 0.01 ? 1 : 0) + "% " + T.perSignal : ""} · ` +
        `${T.illustrative}`;
    }
  }

  async function loadEquity() {
    try {
      const r = await fetch(EQUITY_ENDPOINT, { cache: "no-store" });
      renderEquity(await r.json());
    } catch (e) {
      renderEquity({ error: String(e) });
    }
  }
  loadEquity();
  setInterval(loadEquity, 120_000);
</script>

<style>
  .proof-page { max-width: 1000px; margin: 0 auto; }

  .proof-h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 400; line-height: 0.95; letter-spacing: 0.02em;
    color: var(--text-heading); margin-bottom: 1.25rem;
  }
  .proof-h1 .hl { display: block; overflow: hidden; padding-bottom: 0.05em; }
  .proof-h1 .hli {
    display: block; transform: translateY(110%);
    animation: proofLineUp 0.8s var(--ease-out) forwards;
  }
  .proof-h1 .hl:nth-child(2) .hli { animation-delay: 0.14s; }
  @keyframes proofLineUp { to { transform: translateY(0); } }
  .proof-h1 .accent { color: var(--accent); text-shadow: 0 0 36px var(--accent-glow-strong); }

  .proof-lede {
    font-size: 1.05rem; color: var(--text); max-width: 640px;
    line-height: 1.65; margin-bottom: 2.25rem;
    opacity: 0; transform: translateY(10px);
    animation: fadeUp 0.6s var(--ease-out) 0.35s forwards;
  }
  .proof-lede strong { color: var(--text-heading); }

  /* Hero grid: copy left, live rotating stat right */
  .proof-hero {
    display: grid; grid-template-columns: 1.4fr 1fr;
    gap: 2.5rem; align-items: center; margin-bottom: 2.25rem;
  }
  @media (max-width: 860px) { .proof-hero { grid-template-columns: 1fr; gap: 1.5rem; } }
  .proof-hero .proof-lede { margin-bottom: 0; }

  .ph-panel {
    border: 1px solid var(--border-accent); border-radius: var(--radius);
    background:
      radial-gradient(ellipse 80% 100% at 50% 0%, rgba(0,255,65,0.06), transparent 70%),
      var(--bg-card);
    box-shadow: 0 0 44px -16px var(--accent-glow-strong);
    padding: 1.4rem 1.6rem 1.2rem; text-align: left;
    opacity: 0; animation: fadeUp 0.6s var(--ease-out) 0.5s forwards;
  }
  /* Content morphs in place (number tween + text scramble) — no fade. */
  .ph-label {
    font-family: var(--font-mono); font-size: 0.62rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.2em; color: var(--accent);
    display: flex; align-items: center; gap: 8px; margin-bottom: 0.5rem;
  }
  .live-dot-sm {
    width: 7px; height: 7px; border-radius: 50%; background: var(--accent);
    display: inline-block; animation: phPulse 2s infinite;
  }
  @keyframes phPulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
  .ph-num {
    font-family: var(--font-display); font-size: clamp(4rem, 7vw, 6rem);
    line-height: 0.95; color: var(--text-heading); letter-spacing: 0.01em;
  }
  :global(.ph-pct) { font-size: 0.45em; color: var(--accent); }
  .ph-sub {
    font-family: var(--font-mono); font-size: 0.8rem; color: var(--text);
    margin-top: 0.5rem; min-height: 1.2em;
  }
  :global(.ph-sub b.pos) { color: #4ade80; }
  .ph-foot {
    font-family: var(--font-mono); font-size: 0.6rem; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--text-faint); margin-top: 0.6rem;
    padding-top: 0.6rem; border-top: 1px dashed rgba(255,255,255,0.07);
  }

  /* THE GATE */
  .gate {
    display: grid; grid-template-columns: 1fr 44px 1.15fr 44px 1.2fr;
    align-items: center; margin: 1.5rem 0 3rem;
  }
  @media (max-width: 860px) {
    .gate { grid-template-columns: 1fr; }
    .gate-flow { flex-direction: row !important; height: 40px; justify-content: center; }
    .gate-line { width: 2px !important; height: 100% !important; }
    .gate-line::after {
      background: repeating-linear-gradient(180deg, transparent 0 12px, var(--accent) 12px 20px) !important;
      animation-name: gateDashV !important;
    }
  }
  .gate-col { min-width: 0; }
  .gate-col-label {
    font-family: var(--font-mono); font-size: 0.62rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.18em; color: var(--text-muted);
    margin-bottom: 0.6rem;
  }
  .gate-col-label.pass { color: var(--accent); }
  .gate-col-label.swing { color: #c084fc; }
  .gate-out.swing { margin-top: 0.9rem; }
  .gate-pool { display: flex; flex-wrap: wrap; gap: 6px; }
  :global(.gate-chip) {
    font-family: var(--font-mono); font-size: 0.66rem;
    border: 1px solid var(--border); border-radius: 3px;
    padding: 3px 8px; color: var(--text);
    opacity: 0; animation: gateChipIn 0.4s var(--ease-out) calc(var(--gi, 0) * 0.05s) forwards;
  }
  :global(.gate-chip.pass) {
    border-color: var(--border-accent); color: var(--accent);
    background: rgba(0,255,65,0.05);
